#!/usr/bin/env python3
"""drawio-lint — validate drawio XML against k1s0 authoring rules.

Checks:
  1. White background rect is the first non-base vertex, sits at (0,0), no stroke.
  2. No edge with white stroke (#FFFFFF / white).
  3. orthogonalEdgeStyle edges declare explicit waypoints.
  4. Edge segments do not intersect non-endpoint vertex bboxes.
  5. Labeled edge source-target distance >= 1.5 * approximate label width.
  6. Single <diagram> element (one figure per file).

  A1. Edge label bbox does not overlap unrelated vertices / other edges.
  A2. Text-style vertices do not overlap each other.
  A3. No vertex bbox extends past pageWidth/pageHeight.
  A4. No duplicate cell ids; edges have resolvable endpoints.
  A5. No self-loop / zero-length edges.
  A6. Vertex parent references resolve; child fits within parent bbox.
  A7. fontColor / strokeColor meets WCAG AA (>= 4.5:1) on white background.
  A8. Vertex (fill, stroke) pair stays within figure-layer-convention palette
      (or is white/none/transparent).
  A9. No raster image embedding (shape=image / image=data:).

Exits non-zero on any violation. Use --strict to elevate warnings to errors.
"""

from __future__ import annotations

import argparse
import base64
import re
import sys
import urllib.parse
import xml.etree.ElementTree as ET
import zlib
from collections import Counter
from dataclasses import dataclass, field
from pathlib import Path


# Layer palette from figure-layer-convention skill (fill, stroke) pairs.
LAYER_PALETTE: dict[str, tuple[str, str]] = {
    "app":   ("#fff2cc", "#d79b00"),
    "net":   ("#dae8fc", "#6c8ebf"),
    "infra": ("#f5f5f5", "#666666"),
    "data":  ("#e1d5e7", "#9673a6"),
}
NEUTRAL_FILLS = {"", "none", "#ffffff", "white"}
NEUTRAL_STROKES = {"", "none", "#333333", "#666666"}

# WCAG AA contrast ratio threshold for normal text on white background.
CONTRAST_AA = 4.5
CONTRAST_RECOMMENDED = 7.5  # AAA-ish; #333333 yields ~12.6.

# Self-loop / zero-length edge threshold (px).
MIN_EDGE_LEN = 4.0


@dataclass
class Vertex:
    id: str
    parent: str
    x: float
    y: float
    w: float
    h: float
    style: str

    @property
    def cx(self) -> float:
        return self.x + self.w / 2

    @property
    def cy(self) -> float:
        return self.y + self.h / 2


@dataclass
class Edge:
    id: str
    parent: str
    source: str | None
    target: str | None
    style: str
    value: str
    source_pt: tuple[float, float] | None
    target_pt: tuple[float, float] | None
    waypoints: list[tuple[float, float]] = field(default_factory=list)


def parse_style(style: str) -> dict[str, str]:
    out: dict[str, str] = {}
    for kv in style.split(";"):
        if "=" in kv:
            k, _, v = kv.partition("=")
            out[k.strip()] = v.strip()
    return out


def normalize_color(c: str) -> str:
    c = (c or "").strip().lower()
    if c in ("white",):
        return "#ffffff"
    if c in ("black",):
        return "#000000"
    if re.fullmatch(r"#[0-9a-f]{3}", c):
        return "#" + "".join(ch * 2 for ch in c[1:])
    return c


def load_graph(path: Path) -> tuple[ET.Element, int]:
    tree = ET.parse(path)
    root = tree.getroot()
    if root.tag == "mxGraphModel":
        return root, 1
    diagrams = list(root.findall(".//diagram"))
    if not diagrams:
        raise RuntimeError("no <diagram> element")
    inner = diagrams[0].find("mxGraphModel")
    if inner is not None:
        return inner, len(diagrams)
    text = (diagrams[0].text or "").strip()
    if not text:
        raise RuntimeError("empty <diagram>")
    raw = base64.b64decode(text)
    decompressed = zlib.decompress(raw, -15)
    decoded = urllib.parse.unquote(decompressed.decode("utf-8"))
    return ET.fromstring(decoded), len(diagrams)


def page_size(graph: ET.Element) -> tuple[float, float]:
    try:
        pw = float(graph.get("pageWidth", "0"))
        ph = float(graph.get("pageHeight", "0"))
    except ValueError:
        pw = ph = 0.0
    return pw, ph


def collect(
    graph: ET.Element,
) -> tuple[list[Vertex], list[Edge], list[str]]:
    """Return vertices, edges, and the list of every cell id (for dup check)."""
    vertices: list[Vertex] = []
    edges: list[Edge] = []
    all_ids: list[str] = []
    root = graph.find("root")
    if root is None:
        raise RuntimeError("no <root>")
    for cell in root.findall("mxCell"):
        cid = cell.get("id", "")
        all_ids.append(cid)
        parent = cell.get("parent", "")
        if cell.get("vertex") == "1":
            geom = cell.find("mxGeometry")
            if geom is None:
                continue
            try:
                x = float(geom.get("x", "0"))
                y = float(geom.get("y", "0"))
                w = float(geom.get("width", "0"))
                h = float(geom.get("height", "0"))
            except ValueError:
                continue
            vertices.append(
                Vertex(
                    id=cid, parent=parent,
                    x=x, y=y, w=w, h=h,
                    style=cell.get("style", ""),
                )
            )
        elif cell.get("edge") == "1":
            geom = cell.find("mxGeometry")
            sp = tp = None
            wps: list[tuple[float, float]] = []
            if geom is not None:
                for pt in geom.findall("mxPoint"):
                    role = pt.get("as", "")
                    try:
                        px = float(pt.get("x", "0"))
                        py = float(pt.get("y", "0"))
                    except ValueError:
                        continue
                    if role == "sourcePoint":
                        sp = (px, py)
                    elif role == "targetPoint":
                        tp = (px, py)
                arr = geom.find("Array[@as='points']")
                if arr is not None:
                    for pt in arr.findall("mxPoint"):
                        try:
                            wps.append(
                                (float(pt.get("x", "0")), float(pt.get("y", "0")))
                            )
                        except ValueError:
                            pass
            edges.append(
                Edge(
                    id=cid, parent=parent,
                    source=cell.get("source"),
                    target=cell.get("target"),
                    style=cell.get("style", ""),
                    value=cell.get("value") or "",
                    source_pt=sp,
                    target_pt=tp,
                    waypoints=wps,
                )
            )
    return vertices, edges, all_ids


def segment_rect_intersects(
    x0: float, y0: float, x1: float, y1: float,
    xmin: float, ymin: float, xmax: float, ymax: float,
    eps: float = 1e-6,
) -> bool:
    """Liang-Barsky: True iff segment crosses the rectangle interior."""
    dx = x1 - x0
    dy = y1 - y0
    p = (-dx, dx, -dy, dy)
    q = (x0 - xmin, xmax - x0, y0 - ymin, ymax - y0)
    t_enter = 0.0
    t_exit = 1.0
    for pi, qi in zip(p, q):
        if abs(pi) < eps:
            if qi < 0:
                return False
        else:
            t = qi / pi
            if pi < 0:
                if t > t_exit:
                    return False
                if t > t_enter:
                    t_enter = t
            else:
                if t < t_enter:
                    return False
                if t < t_exit:
                    t_exit = t
    return t_exit - t_enter > eps


def segments_intersect(
    a: tuple[float, float], b: tuple[float, float],
    c: tuple[float, float], d: tuple[float, float],
    eps: float = 1e-6,
) -> bool:
    def cross(p, q, r):
        return (q[0] - p[0]) * (r[1] - p[1]) - (q[1] - p[1]) * (r[0] - p[0])

    d1 = cross(c, d, a)
    d2 = cross(c, d, b)
    d3 = cross(a, b, c)
    d4 = cross(a, b, d)
    if ((d1 > eps and d2 < -eps) or (d1 < -eps and d2 > eps)) and (
        (d3 > eps and d4 < -eps) or (d3 < -eps and d4 > eps)
    ):
        return True
    return False


def label_text(value: str) -> str:
    text = re.sub(r"<[^>]+>", "", value)
    text = (
        text.replace("&nbsp;", " ")
        .replace("&amp;", "&")
        .replace("&lt;", "<")
        .replace("&gt;", ">")
    )
    return text.strip()


def label_width(text: str, font_size: float) -> float:
    full = sum(1 for ch in text if ord(ch) > 0x7F)
    half = len(text) - full
    return full * font_size + half * font_size * 0.55


def is_transparent_annotation(v: Vertex) -> bool:
    st = parse_style(v.style)
    fill = normalize_color(st.get("fillColor", ""))
    stroke = normalize_color(st.get("strokeColor", ""))
    if fill == "none" and stroke == "none":
        return True
    starts_text = v.style.lstrip().startswith("text;") or v.style.lstrip().startswith(
        "text "
    )
    if starts_text and fill in ("", "none") and stroke in ("", "none"):
        return True
    return False


def is_text_vertex(v: Vertex) -> bool:
    if v.style.lstrip().startswith("text;") or v.style.lstrip().startswith("text "):
        return True
    return is_transparent_annotation(v)


def relative_luminance(hex_color: str) -> float | None:
    c = normalize_color(hex_color)
    if not re.fullmatch(r"#[0-9a-f]{6}", c):
        return None
    r = int(c[1:3], 16) / 255.0
    g = int(c[3:5], 16) / 255.0
    b = int(c[5:7], 16) / 255.0

    def lin(v: float) -> float:
        return v / 12.92 if v <= 0.03928 else ((v + 0.055) / 1.055) ** 2.4

    return 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b)


def contrast_on_white(hex_color: str) -> float | None:
    L = relative_luminance(hex_color)
    if L is None:
        return None
    return (1.0 + 0.05) / (L + 0.05)


def contains(outer: Vertex, inner: Vertex) -> bool:
    return (
        outer.x <= inner.x
        and outer.y <= inner.y
        and outer.x + outer.w >= inner.x + inner.w
        and outer.y + outer.h >= inner.y + inner.h
        and outer.id != inner.id
    )


def contains_point(outer: Vertex, px: float, py: float) -> bool:
    return outer.x <= px <= outer.x + outer.w and outer.y <= py <= outer.y + outer.h


def lint_one(path: Path) -> tuple[list[str], list[str]]:
    violations: list[str] = []
    warnings: list[str] = []

    graph, ndiagrams = load_graph(path)
    if ndiagrams > 1:
        violations.append(
            f"multi-page drawio ({ndiagrams} diagrams) — split into separate files"
        )

    pw, ph = page_size(graph)
    vertices, edges, all_ids = collect(graph)
    non_base = [v for v in vertices if v.id not in ("0", "1")]
    if not non_base:
        violations.append("no vertices found")
        return violations, warnings

    bg = non_base[0]
    bg_style = parse_style(bg.style)
    if normalize_color(bg_style.get("fillColor", "")) not in ("#ffffff",):
        violations.append(
            f"first vertex '{bg.id}' is not a white background rect "
            f"(fillColor={bg_style.get('fillColor', '<none>')})"
        )
    if normalize_color(bg_style.get("strokeColor", "none")) != "none":
        warnings.append(
            f"background rect '{bg.id}' has visible stroke "
            f"({bg_style.get('strokeColor')})"
        )
    if bg.x != 0 or bg.y != 0:
        warnings.append(
            f"background rect '{bg.id}' should sit at (0,0); found ({bg.x},{bg.y})"
        )

    bg_id = bg.id
    vmap = {v.id: v for v in vertices}

    # --- A4: duplicate ids -----------------------------------------------
    dup_counts = Counter(all_ids)
    for cid, n in dup_counts.items():
        if n > 1 and cid:
            violations.append(f"duplicate cell id '{cid}' appears {n} times")

    # --- A9: raster image embedding --------------------------------------
    for v in vertices:
        st_raw = v.style.lstrip().lower()
        if st_raw.startswith("shape=image") or ";shape=image" in st_raw:
            violations.append(
                f"vertex '{v.id}' embeds a raster image (shape=image) — SVG only"
            )
        st = parse_style(v.style)
        img = st.get("image", "")
        if img.lower().startswith("data:"):
            violations.append(
                f"vertex '{v.id}' embeds a raster via data: URI — SVG only"
            )

    # --- white-stroke / orthogonal-without-waypoints (existing rules) ---
    for e in edges:
        st = parse_style(e.style)
        sc = normalize_color(st.get("strokeColor", ""))
        if sc == "#ffffff":
            violations.append(f"edge '{e.id}' has white stroke")
        if st.get("edgeStyle") == "orthogonalEdgeStyle" and not e.waypoints:
            violations.append(
                f"edge '{e.id}' uses orthogonalEdgeStyle without explicit waypoints"
            )

    # --- A4 (cont): edge endpoint resolvability --------------------------
    for e in edges:
        if e.source and e.source not in vmap:
            violations.append(
                f"edge '{e.id}' references unknown source vertex '{e.source}'"
            )
        if e.target and e.target not in vmap:
            violations.append(
                f"edge '{e.id}' references unknown target vertex '{e.target}'"
            )
        if not e.source and not e.source_pt:
            violations.append(f"edge '{e.id}' has no source vertex or sourcePoint")
        if not e.target and not e.target_pt:
            violations.append(f"edge '{e.id}' has no target vertex or targetPoint")

    # --- A5: self-loop / zero-length edges -------------------------------
    for e in edges:
        if e.source and e.target and e.source == e.target:
            violations.append(f"edge '{e.id}' is a self-loop (source==target)")
            continue
        # Compute polyline length.
        pts: list[tuple[float, float]] = []
        if e.source and e.source in vmap:
            pts.append((vmap[e.source].cx, vmap[e.source].cy))
        elif e.source_pt:
            pts.append(e.source_pt)
        pts.extend(e.waypoints)
        if e.target and e.target in vmap:
            pts.append((vmap[e.target].cx, vmap[e.target].cy))
        elif e.target_pt:
            pts.append(e.target_pt)
        if len(pts) >= 2:
            total = sum(
                ((pts[i + 1][0] - pts[i][0]) ** 2
                 + (pts[i + 1][1] - pts[i][1]) ** 2) ** 0.5
                for i in range(len(pts) - 1)
            )
            if total < MIN_EDGE_LEN:
                violations.append(
                    f"edge '{e.id}' has zero-length polyline ({total:.1f}px)"
                )

    # --- A6: parent reference / containment ------------------------------
    valid_parents = {"0", "1", ""} | {v.id for v in vertices}
    for v in vertices:
        if v.parent and v.parent not in valid_parents:
            violations.append(
                f"vertex '{v.id}' has unknown parent '{v.parent}'"
            )
        if v.parent and v.parent not in ("0", "1", "") and v.parent in vmap:
            p = vmap[v.parent]
            # In drawio, child x/y is parent-relative. Bounds check accordingly.
            if (
                v.x < -0.5
                or v.y < -0.5
                or v.x + v.w > p.w + 0.5
                or v.y + v.h > p.h + 0.5
            ):
                warnings.append(
                    f"vertex '{v.id}' extends outside parent '{p.id}' bbox "
                    f"(child {v.x},{v.y} {v.w}x{v.h} vs parent {p.w}x{p.h})"
                )

    # --- A3: page-bounds containment -------------------------------------
    if pw > 0 and ph > 0:
        for v in non_base:
            # Skip children of containers; their coords are parent-relative.
            if v.parent and v.parent not in ("0", "1", "") and v.parent in vmap:
                continue
            if (
                v.x < -0.5
                or v.y < -0.5
                or v.x + v.w > pw + 0.5
                or v.y + v.h > ph + 0.5
            ):
                violations.append(
                    f"vertex '{v.id}' extends outside page bounds "
                    f"({pw:.0f}x{ph:.0f}); bbox ({v.x},{v.y} {v.w}x{v.h})"
                )

    # --- A7: contrast on white background --------------------------------
    palette_strokes = {
        normalize_color(s) for _, s in LAYER_PALETTE.values()
    }

    def check_contrast(target: str, kind: str, owner_id: str) -> None:
        c = normalize_color(target)
        if not c or c == "none":
            return
        # Layer-palette stroke colors are sanctioned decoration; allow them
        # for vertex/edge stroke but keep fontColor strict (text legibility).
        if kind == "strokeColor" and c in palette_strokes:
            return
        ratio = contrast_on_white(c)
        if ratio is None:
            return
        if ratio < CONTRAST_AA:
            violations.append(
                f"{kind} '{c}' on '{owner_id}' fails WCAG AA "
                f"(contrast {ratio:.1f}:1 < {CONTRAST_AA})"
            )
        elif ratio < CONTRAST_RECOMMENDED:
            warnings.append(
                f"{kind} '{c}' on '{owner_id}' below recommended "
                f"(contrast {ratio:.1f}:1; aim for #333333 / >= {CONTRAST_RECOMMENDED}:1)"
            )

    for v in vertices:
        if v.id == bg_id:
            continue
        st = parse_style(v.style)
        check_contrast(st.get("fontColor", ""), "fontColor", v.id)
        # Skip strokeColor for the text-only annotations (often fillColor=none).
        if not is_text_vertex(v):
            check_contrast(st.get("strokeColor", ""), "strokeColor", v.id)

    for e in edges:
        st = parse_style(e.style)
        check_contrast(st.get("strokeColor", ""), "strokeColor", e.id)
        check_contrast(st.get("fontColor", ""), "fontColor", e.id)

    # --- A8: layer palette adherence -------------------------------------
    palette_pairs = set(
        (normalize_color(f), normalize_color(s)) for f, s in LAYER_PALETTE.values()
    )
    for v in vertices:
        if v.id == bg_id:
            continue
        if is_text_vertex(v):
            continue
        st = parse_style(v.style)
        fill = normalize_color(st.get("fillColor", ""))
        stroke = normalize_color(st.get("strokeColor", ""))
        if fill in NEUTRAL_FILLS and stroke in NEUTRAL_STROKES:
            continue
        # Allow default-themed (fill empty) shapes.
        if fill in ("", "none"):
            continue
        if (fill, stroke) in palette_pairs:
            continue
        warnings.append(
            f"vertex '{v.id}' uses palette pair (fill={fill or '<none>'}, "
            f"stroke={stroke or '<none>'}) outside figure-layer-convention"
        )

    # --- existing edge intersection (rule 4) -----------------------------
    for e in edges:
        pts = []
        if e.source and e.source in vmap:
            v = vmap[e.source]
            pts.append((v.cx, v.cy))
        elif e.source_pt:
            pts.append(e.source_pt)
        pts.extend(e.waypoints)
        if e.target and e.target in vmap:
            v = vmap[e.target]
            pts.append((v.cx, v.cy))
        elif e.target_pt:
            pts.append(e.target_pt)
        if len(pts) < 2:
            continue
        ignore = {e.source, e.target, bg_id, "0", "1", None}
        src_v = vmap.get(e.source) if e.source else None
        tgt_v = vmap.get(e.target) if e.target else None
        sp = (src_v.cx, src_v.cy) if src_v else e.source_pt
        tp = (tgt_v.cx, tgt_v.cy) if tgt_v else e.target_pt
        for i in range(len(pts) - 1):
            x0, y0 = pts[i]
            x1, y1 = pts[i + 1]
            for v in vertices:
                if v.id in ignore:
                    continue
                if src_v and contains(v, src_v):
                    continue
                if tgt_v and contains(v, tgt_v):
                    continue
                if sp and contains_point(v, sp[0], sp[1]):
                    continue
                if tp and contains_point(v, tp[0], tp[1]):
                    continue
                pad = 0.5
                if segment_rect_intersects(
                    x0, y0, x1, y1,
                    v.x + pad, v.y + pad,
                    v.x + v.w - pad, v.y + v.h - pad,
                ):
                    msg = (
                        f"edge '{e.id}' segment {i} crosses vertex '{v.id}' bbox"
                    )
                    if is_transparent_annotation(v):
                        warnings.append(msg + " (transparent annotation)")
                    else:
                        violations.append(msg)

    # --- existing label-distance rule (rule 5) ---------------------------
    for e in edges:
        text = label_text(e.value)
        if not text:
            continue
        st = parse_style(e.style)
        try:
            fs = float(st.get("fontSize", "12"))
        except ValueError:
            fs = 12.0
        lw = label_width(text, fs)
        if lw <= 0:
            continue
        if e.source and e.source in vmap:
            sx, sy = vmap[e.source].cx, vmap[e.source].cy
        elif e.source_pt:
            sx, sy = e.source_pt
        else:
            continue
        if e.target and e.target in vmap:
            tx, ty = vmap[e.target].cx, vmap[e.target].cy
        elif e.target_pt:
            tx, ty = e.target_pt
        else:
            continue
        dist = ((sx - tx) ** 2 + (sy - ty) ** 2) ** 0.5
        if dist < lw * 1.5:
            violations.append(
                f"edge '{e.id}' label '{text[:24]}' width≈{lw:.0f}px violates 1.5x rule "
                f"(source-target distance {dist:.0f}px)"
            )

    # --- A1: edge label bbox vs other vertices / other edges -------------
    for e in edges:
        text = label_text(e.value)
        if not text:
            continue
        st = parse_style(e.style)
        try:
            fs = float(st.get("fontSize", "12"))
        except ValueError:
            fs = 12.0
        lw = label_width(text, fs)
        lh = fs * 1.4
        if lw <= 0:
            continue
        # Approximate label center: edge polyline midpoint.
        pts = []
        if e.source and e.source in vmap:
            pts.append((vmap[e.source].cx, vmap[e.source].cy))
        elif e.source_pt:
            pts.append(e.source_pt)
        pts.extend(e.waypoints)
        if e.target and e.target in vmap:
            pts.append((vmap[e.target].cx, vmap[e.target].cy))
        elif e.target_pt:
            pts.append(e.target_pt)
        if len(pts) < 2:
            continue
        total = sum(
            ((pts[i + 1][0] - pts[i][0]) ** 2
             + (pts[i + 1][1] - pts[i][1]) ** 2) ** 0.5
            for i in range(len(pts) - 1)
        )
        if total <= 0:
            continue
        # Walk to midpoint.
        target_d = total / 2
        acc = 0.0
        cx = cy = 0.0
        for i in range(len(pts) - 1):
            x0, y0 = pts[i]
            x1, y1 = pts[i + 1]
            seg = ((x1 - x0) ** 2 + (y1 - y0) ** 2) ** 0.5
            if acc + seg >= target_d:
                t = (target_d - acc) / seg if seg else 0
                cx = x0 + (x1 - x0) * t
                cy = y0 + (y1 - y0) * t
                break
            acc += seg
        else:
            cx, cy = pts[-1]
        lx0, ly0 = cx - lw / 2, cy - lh / 2
        lx1, ly1 = cx + lw / 2, cy + lh / 2

        # vs other vertices (skip own endpoints, bg, transparent annotations,
        # and vertices that contain the endpoint).
        ignore = {e.source, e.target, bg_id, "0", "1", None}
        src_v = vmap.get(e.source) if e.source else None
        tgt_v = vmap.get(e.target) if e.target else None
        for v in vertices:
            if v.id in ignore:
                continue
            if is_text_vertex(v):
                continue
            if src_v and contains(v, src_v):
                continue
            if tgt_v and contains(v, tgt_v):
                continue
            if not (lx1 < v.x or lx0 > v.x + v.w or ly1 < v.y or ly0 > v.y + v.h):
                violations.append(
                    f"edge '{e.id}' label '{text[:24]}' bbox overlaps vertex '{v.id}'"
                )

        # vs other edges' segments
        for other in edges:
            if other.id == e.id:
                continue
            opts = []
            if other.source and other.source in vmap:
                opts.append((vmap[other.source].cx, vmap[other.source].cy))
            elif other.source_pt:
                opts.append(other.source_pt)
            opts.extend(other.waypoints)
            if other.target and other.target in vmap:
                opts.append((vmap[other.target].cx, vmap[other.target].cy))
            elif other.target_pt:
                opts.append(other.target_pt)
            if len(opts) < 2:
                continue
            for i in range(len(opts) - 1):
                if segment_rect_intersects(
                    opts[i][0], opts[i][1], opts[i + 1][0], opts[i + 1][1],
                    lx0, ly0, lx1, ly1,
                ):
                    warnings.append(
                        f"edge '{e.id}' label '{text[:24]}' bbox crosses "
                        f"edge '{other.id}' segment {i}"
                    )
                    break
            else:
                continue
            break

    # --- A2: text vertices overlap each other ----------------------------
    text_vs = [v for v in vertices if v.id != bg_id and is_text_vertex(v)]
    for i, a in enumerate(text_vs):
        for b in text_vs[i + 1 :]:
            # Skip parent/child relationships.
            if a.parent == b.id or b.parent == a.id:
                continue
            if not (
                a.x + a.w <= b.x or b.x + b.w <= a.x
                or a.y + a.h <= b.y or b.y + b.h <= a.y
            ):
                warnings.append(
                    f"text vertex '{a.id}' overlaps text vertex '{b.id}'"
                )

    return violations, warnings


def main(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(prog="drawio-lint")
    ap.add_argument("paths", nargs="+", type=Path)
    ap.add_argument(
        "--strict", action="store_true", help="treat warnings as errors"
    )
    args = ap.parse_args(argv)

    failed = 0
    for path in args.paths:
        try:
            violations, warnings = lint_one(path)
        except Exception as e:
            print(f"{path}: parse error: {e}", file=sys.stderr)
            failed += 1
            continue
        for v in violations:
            print(f"{path}: ERROR {v}", file=sys.stderr)
        for w in warnings:
            print(f"{path}: WARN  {w}", file=sys.stderr)
        if violations:
            failed += 1
        elif args.strict and warnings:
            failed += 1
        else:
            print(f"{path}: ok")
    return 1 if failed else 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

        </mxCell>
        <mxCell id="title" value="本番環境 物理構成図" style="text;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="12" width="500" height="32" as="geometry" />
        </mxCell>
        <!-- Social LAN area (top) -->
        <mxCell id="lan_box" value="社内 LAN" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">

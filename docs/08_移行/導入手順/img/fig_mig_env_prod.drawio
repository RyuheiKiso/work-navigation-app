          <mxGeometry x="200" y="170" width="700" height="320" as="geometry" />
        </mxCell>
        <!-- IIS inside WS -->
        <mxCell id="iis_box" value="IIS&lt;br&gt;マスタメンテ React&lt;br&gt;（静的ホスティング）&lt;br&gt;ポート 443（HTTPS）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">

<mxfile host="app.diagrams.net" agent="work-navigation-app" version="22.0.0">
  <diagram id="premortem05" name="Pre-mortem 主原因マップ">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="図 05: Pre-mortem 主原因マップ — 2 年後（2028-05）に本プロジェクトが失敗した時の 5 シナリオ。各シナリオに早期検知シグナルと回避策を併記。" style="text;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="凡例: 主原因類型は §16.1〜§16.5 の A〜F に対応。回避策は §16 で挙げた O〜S（楔撤退・短サイクル化・外部支援・撤退・ガバナンス変更）。" style="text;align=left;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="20" y="860" width="1360" height="20" as="geometry" />
        </mxCell>

        <mxCell id="center" value="2028-05&#xa;本プロジェクトは&#xa;失敗した" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FCE8E6;strokeColor=#C5221F;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="380" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="シナリオ 1（類型 A）&#xa;メンテナ興味喪失・私生活変化&#xa;&#xa;検知: 月次コミット・Issue 反応の低下（K5, K8）&#xa;回避: 機能絞り／短サイクル／外部支援／撤退／ガバナンス変更" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="380" height="160" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="シナリオ 2（類型 B）★最有力&#xa;現場 UX 不一致 → 紙へ回帰&#xa;&#xa;検知: 起動回数 ／ 作業者あたりの減少（K3）&#xa;回避: §6.3 数値見直し ／ 端末選定下限引き上げ ／ 撤退" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FCE8E6;strokeColor=#C5221F;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;strokeWidth=3" vertex="1" parent="1">
          <mxGeometry x="940" y="80" width="380" height="160" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="シナリオ 3（類型 G、楔崩壊）&#xa;ばらつき主因が楔の介入対象外（H6 崩壊）&#xa;&#xa;検知: K2（標準偏差が紙比で改善しない）&#xa;回避: 楔 Job を J-A から J-B（多品種混流切替）へ切替／改善ループ機能を主機能に格上げ／撤退" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F4EA;strokeColor=#137333;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="380" height="160" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="シナリオ 4（類型 D／E）&#xa;商用 SaaS 機能強化 ／ フォーク派生に主導権喪失&#xa;&#xa;検知: 競合機能リリースの四半期モニタリング（K6）&#xa;回避: Moat を設計の正しさに保つ ／ AGPL 化 ／ 撤退" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#1A73E8;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="940" y="640" width="380" height="160" as="geometry" />
        </mxCell>

        <mxCell id="s5" value="シナリオ 5（類型 C）&#xa;楔現場の基幹連動が想定より多様（H8 崩壊）&#xa;&#xa;検知: K4（連動アダプタ追加要件 Issue の増加）&#xa;回避: アダプタ仕様凍結／導入先実装への完全委譲／撤退" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F1F3F4;strokeColor=#5F6368;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="510" y="640" width="380" height="160" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0;entryY=0.5;" edge="1" parent="1" source="s1" target="center">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=1;entryY=0.5;strokeWidth=3;strokeColor=#C5221F" edge="1" parent="1" source="s2" target="center">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;exitX=0.5;exitY=0;entryX=0;entryY=0.5;" edge="1" parent="1" source="s3" target="center">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;exitX=0.5;exitY=0;entryX=1;entryY=0.5;" edge="1" parent="1" source="s4" target="center">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="s5" target="center">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="note" value="★ シナリオ 2 を最有力と判定する根拠: §3.2 の一次情報欠落。現場 UX の現実的な制約は仮説 H2／H4／H7 でしか担保されておらず、検証されていない。" style="text;align=center;fontSize=11;fontStyle=2;fontColor=#C5221F" vertex="1" parent="1">
          <mxGeometry x="20" y="280" width="1360" height="40" as="geometry" />
        </mxCell>

        <mxCell id="common" value="5 本に共通する最終回避策: 楔（J-A 段取り替え×単位作業×ライン生産）への即時撤退（§16.7）" style="text;align=center;fontSize=11;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="20" y="520" width="1360" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

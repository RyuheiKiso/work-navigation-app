{
  "$wna": "対応 § ロードマップ §31 §31.1 §31.2 §31.5",
  "$wna_note": "JSON は構文上コメント不可のため、メタ情報を $wna プレフィクスで記載する。",
  "title": "work-navigation-app SLO Dashboard",
  "uid": "wna-slo",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["wna", "slo", "§31"],
  "timezone": "browser",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "SLI-01 端末画面遷移成功率（中央値≤200ms かつエラーなし）",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "wna_terminal_screen_transition_success_ratio",
          "legendFormat": "達成率"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.99 },
            { "color": "green", "value": 0.995 }
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      }
    },
    {
      "id": 2,
      "title": "SLI-02 タッチ応答 ≤ 100ms 達成率",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "targets": [{ "expr": "wna_terminal_touch_response_within_100ms_ratio", "legendFormat": "達成率" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "id": 3,
      "title": "SLI-03 作業実績の永続化成功率（≤200ms）",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "targets": [{ "expr": "wna_terminal_record_persistence_within_200ms_ratio", "legendFormat": "達成率" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "id": 4,
      "title": "SLI-04 同期スループット（≥100件/分の時間割合）",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "targets": [{ "expr": "wna_backend_sync_throughput_above_100_per_min_ratio", "legendFormat": "達成率" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "id": 5,
      "title": "SLI-05 バックエンド p95 応答時間",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, wna_backend_request_duration_seconds_bucket{op=\"read\"})", "legendFormat": "read p95" },
        { "expr": "histogram_quantile(0.95, wna_backend_request_duration_seconds_bucket{op=\"write\"})", "legendFormat": "write p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "SLI-06 監査ログ追記不変性違反",
      "type": "stat",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 8 },
      "targets": [{ "expr": "sum(increase(wna_audit_immutability_violations_total[24h]))", "legendFormat": "24h 違反数" }],
      "options": {
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]
        }
      },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "SLI-07 同期競合 DLQ 遷移率",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 8 },
      "targets": [{ "expr": "rate(wna_backend_sync_dlq_total[1h]) / rate(wna_backend_sync_received_total[1h])", "legendFormat": "DLQ 比率" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 8,
      "title": "SLI-08 認証失敗率（同 ID 5 回以上/短時間）",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(wna_auth_failures_total[5m])", "legendFormat": "認証失敗 /秒" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 9,
      "title": "SLI-09 アドオン kill 件数（CPU/メモリ/時間超過）",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
      "targets": [{ "expr": "increase(wna_addon_kill_total[1h])", "legendFormat": "{{reason}}" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10,
      "title": "SLI-10 バッテリー消費 ≤ 80% / 8h 達成率",
      "type": "stat",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 6 },
      "targets": [{ "expr": "wna_terminal_battery_consumption_within_target_ratio", "legendFormat": "達成率" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "id": 11,
      "title": "エラー予算消費（SLO-01 99.5% / 30日）",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 20, "w": 6, "h": 6 },
      "targets": [
        { "expr": "(1 - wna_terminal_screen_transition_success_ratio_30d) / 0.005", "legendFormat": "予算消費" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    }
  ]
}

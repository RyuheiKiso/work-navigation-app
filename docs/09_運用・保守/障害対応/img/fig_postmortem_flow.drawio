<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="ポストモーテム作成フロー（OPS-063/064）" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="32" as="geometry" />
        </mxCell>

        <!-- Start: F4 complete -->
        <mxCell id="start" value="F4 復旧完了" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="510" y="80" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Step: RCA speed report -->
        <mxCell id="step1" value="RCA 速報作成&#xa;（復旧後 15 分以内）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="490" y="170" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Step: INC record -->
        <mxCell id="step2" value="INC 記録に&#xa;「ポストモーテム必要」を記録" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="490" y="270" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Decision: P1 or P2? -->
        <mxCell id="dec1" value="P1 / P2 インシデント?" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="490" y="370" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- P3/P4 skip -->
        <mxCell id="p34" value="P3/P4: 再発頻度確認&#xa;2週間に3回以上→実施" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="800" y="385" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Step: create PM file -->
        <mxCell id="step3" value="ポストモーテムファイル作成&#xa;docs/ポストモーテム/&#xa;YYYY-MM-DD_PX_&lt;slug&gt;.md" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="490" y="490" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- Step: 5-why analysis -->
        <mxCell id="step4" value="5-Why 分析 / タイムライン作成&#xa;（Just Culture: ロール名のみ使用）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="490" y="600" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- Step: action items -->
        <mxCell id="step5" value="改善処置 (Action Items) 策定&#xa;担当者・期限を明記" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="200" y="600" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- Step: INC register -->
        <mxCell id="step6" value="INC 索引（12 章）に登録&#xa;PM-YYYY-NNN 採番" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="490" y="710" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="ポストモーテム完了&#xa;クローズ" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="510" y="740" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Just Culture note -->
        <mxCell id="note1" value="Just Culture 原則（OPS-065）&#xa;・個人名 → ロール名&#xa;・人為ミス結論 禁止&#xa;・人事評価に使用 禁止" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" edge="1" source="start" target="step1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" source="step1" target="step2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" source="step2" target="dec1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" source="dec1" target="step3" value="はい" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" source="dec1" target="p34" value="いいえ (P3/P4)" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="910" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e6" edge="1" source="step3" target="step4" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" source="step4" target="step5" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="635" />
              <mxPoint x="310" y="635" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e8" edge="1" source="step5" target="step6" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="310" y="740" />
              <mxPoint x="600" y="740" />

<mxfile host="app.diagrams.net" agent="work-navigation-app" version="22.0.0">
  <diagram id="c4l2container01" name="C4_L2_Container">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="図 02: Container (C4 L2) — work-navigation-app の内部構成。点線囲みが本システムの境界。外部は Keycloak と基幹システム。" style="text;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1220" height="30" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="凡例: C4 L2 / 矩形=Container（OS プロセスまたはアプリ単位） / 点線囲み=システム境界 / 太枠=Custom 領域（独自性集中、企画書 §9.2） / 灰色=External / 矢印ラベル=プロトコル・データ" style="text;align=left;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="740" width="1220" height="20" as="geometry" />
        </mxCell>

        <mxCell id="boundary" value="work-navigation-app 境界" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1A73E8;dashed=1;fontSize=12;fontStyle=2;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="900" height="640" as="geometry" />
        </mxCell>

        <mxCell id="operator" value="直接作業者" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#1A73E8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="author" value="手順作成者&#xa;改訂者" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#1A73E8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="100" y="500" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="terminal" value="端末アプリ&#xa;[Container: Tauri]&#xa;Android / Windows&#xa;React UI 共有（再生専用）&#xa;企画書 §8.2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;fontSize=11;strokeWidth=3" vertex="1" parent="1">
          <mxGeometry x="280" y="170" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="sqlite" value="端末ローカル DB&#xa;[Container: SQLite]&#xa;手順キャッシュ／実績キュー&#xa;メディアキャッシュ&#xa;企画書 §8.2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="540" y="170" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="spa" value="メンテナンス Web SPA&#xa;[Container: React]&#xa;ADR-0004&#xa;手順作成・改訂・ダッシュボード&#xa;企画書 §8.3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F4EA;strokeColor=#137333;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="280" y="470" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="api" value="API バックエンド&#xa;[Container: 言語未定]&#xa;REST / GraphQL&#xa;同期エンジン（差分・WS/SSE）&#xa;TWI-JI 三段強制&#xa;企画書 §8.3 §8.4.3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;fontSize=11;strokeWidth=3" vertex="1" parent="1">
          <mxGeometry x="540" y="370" width="220" height="160" as="geometry" />
        </mxCell>

        <mxCell id="pg" value="PostgreSQL&#xa;[Container]&#xa;ADR-0005&#xa;DSL ／ 実績イベント ／&#xa;ラージオブジェクト（pg_largeobject、メディア） ／&#xa;MATERIALIZED VIEW ／ ハッシュチェーン監査ログ&#xa;企画書 §8.4.2 §13.9" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E6F4EA;strokeColor=#137333;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="540" y="580" width="320" height="120" as="geometry" />
        </mxCell>


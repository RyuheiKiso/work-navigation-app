<mxfile host="app.diagrams.net" agent="work-navigation-app" version="22.0.0">
  <diagram id="c4l1context01" name="C4_L1_Context">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="図 01: System Context (C4 L1) — work-navigation-app の全境界。中心が本システム、周囲は人物（Person）と外部システム（External）。" style="text;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1020" height="30" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="凡例: C4 L1 / 実線=主要連携 / 矩形=System or External / 楕円=Person / 太線中央矩形=本システム" style="text;align=left;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="1020" height="20" as="geometry" />
        </mxCell>

        <mxCell id="operator" value="直接作業者&#xa;（オペレータ）&#xa;[Person]&#xa;手順を端末で再生し&#xa;実績を入力する" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#1A73E8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="180" height="120" as="geometry" />
        </mxCell>

        <mxCell id="author" value="手順作成者・改訂者&#xa;（IE / 班長 / 品証）&#xa;[Person]&#xa;Web で手順を作成・改訂し&#xa;実績ダッシュボードを見る" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#1A73E8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="180" height="120" as="geometry" />
        </mxCell>

        <mxCell id="system" value="work-navigation-app&#xa;[Software System]&#xa;ライン生産現場の段取り替え時に&#xa;単位作業をナビゲーションする OSS。&#xa;端末アプリ＋メンテナンス Web＋共通基盤" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;fontSize=12;strokeWidth=4" vertex="1" parent="1">
          <mxGeometry x="400" y="240" width="300" height="140" as="geometry" />
        </mxCell>

        <mxCell id="mes" value="基幹システム / MES&#xa;[External System]&#xa;生産計画・順序情報を供給&#xa;実績を返す&#xa;（REST / GraphQL、現場側で API 提供）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F1F3F4;strokeColor=#5F6368;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="850" y="120" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="keycloak" value="Keycloak&#xa;[External System]&#xa;認証・認可（OIDC）&#xa;ID／パスワード&#xa;ADR-0011 で確定" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F1F3F4;strokeColor=#5F6368;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="850" y="380" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="e_op_sys" value="単位作業を再生&#xa;実績を入力" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;fontSize=10" edge="1" parent="1" source="operator" target="system">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_au_sys" value="手順を作成・改訂&#xa;ダッシュボード閲覧" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.7;fontSize=10" edge="1" parent="1" source="author" target="system">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_sys_mes" value="生産計画取込&#xa;実績返却（任意）" style="endArrow=classic;html=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5;fontSize=10" edge="1" parent="1" source="system" target="mes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_sys_kc" value="OIDC 認証委譲&#xa;（PKCE 必須）" style="endArrow=classic;html=1;exitX=1;exitY=0.7;entryX=0;entryY=0.5;fontSize=10" edge="1" parent="1" source="system" target="keycloak">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

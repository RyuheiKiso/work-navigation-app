<mxfile>
  <diagram name="リワーク状態遷移" id="page-1">
    <mxGraphModel pageWidth="1200" pageHeight="760" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="760" as="geometry" />
        </mxCell>
        <mxCell id="title" value="リワーク状態遷移（BF-08 / FR-ST-013/014）" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="640" height="32" as="geometry" />
        </mxCell>
        <!-- ===== MAIN FLOW (left column) ===== -->
        <mxCell id="s_pd" value="PENDING_DISPOSITION&#xa;不適合起票・MRB判定待ち" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_dd" value="DISPOSITION_DECIDED&#xa;判定確定（二者電子サイン）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_rip" value="REWORK_IN_PROGRESS&#xa;リワーク作業中（新case_id）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_rc" value="REWORK_COMPLETED&#xa;リワーク完了・再検査待ち" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_vip" value="VERIFICATION_IN_PROGRESS&#xa;再検査中（別worker_id必須）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="200" height="60" as="geometry" />
        </mxCell>
        <!-- ===== TERMINAL STATES (right column) ===== -->
        <!-- From DISPOSITION_DECIDED -->
        <mxCell id="s_cs" value="CLOSED_SCRAP&#xa;廃却完了（物理削除禁止）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="380" y="160" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_cr" value="CLOSED_RETURN&#xa;仕入先返却完了" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="380" y="240" width="200" height="60" as="geometry" />
        </mxCell>
        <!-- From VERIFICATION_IN_PROGRESS -->
        <mxCell id="s_cor" value="CLOSED_OK_RELEASE&#xa;再検査合格・出荷可" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="380" y="490" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_cd" value="CLOSED_DOWNGRADE&#xa;B級品として出荷可" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="380" y="570" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_rrn" value="RE_REWORK_NEEDED&#xa;再検査不合格・再ディスポへ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="380" y="650" width="200" height="60" as="geometry" />
        </mxCell>
        <!-- ===== MAIN FLOW TRANSITIONS ===== -->
        <!-- pd → dd (vertical 80px gap) -->
        <mxCell id="e1" value="承認完了" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="140" as="sourcePoint" />
            <mxPoint x="140" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- dd → rip (vertical 80px gap) -->
        <mxCell id="e2" value="着手宣言" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="280" as="sourcePoint" />
            <mxPoint x="140" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- rip → rc (vertical 80px gap) -->
        <mxCell id="e3" value="完了" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="420" as="sourcePoint" />
            <mxPoint x="140" y="500" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- rc → vip (vertical 80px gap) -->
        <mxCell id="e4" value="QR照合" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="560" as="sourcePoint" />
            <mxPoint x="140" y="640" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- ===== DISPOSITION BRANCHES ===== -->
        <!-- dd → cs (SCRAP) -->
        <mxCell id="e9" value="SCRAP" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="240" as="sourcePoint" />
            <mxPoint x="380" y="190" as="targetPoint" />
            <Array as="points">
              <mxPoint x="310" y="240" />
              <mxPoint x="310" y="190" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- dd → cr (RETURN) -->
        <mxCell id="e10" value="RETURN" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="260" as="sourcePoint" />
            <mxPoint x="380" y="270" as="targetPoint" />
            <Array as="points">
              <mxPoint x="316" y="260" />
              <mxPoint x="316" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- ===== VERIFICATION BRANCHES ===== -->
        <!-- vip → cor (OK) -->
        <mxCell id="e5" value="OK" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="660" as="sourcePoint" />
            <mxPoint x="380" y="520" as="targetPoint" />
            <Array as="points">
              <mxPoint x="320" y="660" />
              <mxPoint x="320" y="520" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- vip → cd (DOWNGRADE) -->
        <mxCell id="e6" value="格下げ" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="670" as="sourcePoint" />
            <mxPoint x="380" y="600" as="targetPoint" />
            <Array as="points">
              <mxPoint x="325" y="670" />
              <mxPoint x="325" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- vip → rrn (RE_REWORK_NEEDED) -->
        <mxCell id="e7" value="再リワーク" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="680" as="sourcePoint" />
            <mxPoint x="380" y="680" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- ===== LOOP BACK: rrn → pd ===== -->
        <mxCell id="e8" value="前進遷移" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;dashed=1;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="680" as="sourcePoint" />
            <mxPoint x="240" y="110" as="targetPoint" />
            <Array as="points">
              <mxPoint x="650" y="680" />
              <mxPoint x="650" y="80" />
              <mxPoint x="240" y="80" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- ===== LEGEND ===== -->
        <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="720" y="360" width="440" height="360" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" value="凡例・設計方針" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="730" y="368" width="140" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="● CLOSED_* 状態からの逆遷移は全て禁止&#xa;● 前進遷移（点線）: RE_REWORK_NEEDED →&#xa;　PENDING_DISPOSITION（逆遷移ではなく前進）&#xa;● 同一 parent_lot_id の rework 回数上限:&#xa;　CFG-026（デフォルト3回）超過で SCRAP 強制提案&#xa;● 元 WorkExecution（parent_case_id）は不可侵&#xa;　リワークは新 case_id（rework_case_id）で記録&#xa;● SCRAP_AFTER_REWORK: VERIFICATION_IN_PROGRESS&#xa;　から CLOSED_SCRAP への遷移も定義済み&#xa;　（DISPOSITION_DECIDED 側の CLOSED_SCRAP と同一）&#xa;● SCRAP/RETURN: Append-only 記録・取消不可&#xa;● 二者電子サイン: 同一 worker_id 不可（ERR-BIZ-021）&#xa;● 再検査者 ≠ リワーク実施者（ERR-BIZ-023）" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="730" y="395" width="420" height="310" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

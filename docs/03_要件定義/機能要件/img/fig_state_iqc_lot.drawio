<mxfile>
  <diagram name="受入検査ロット状態遷移" id="page-1">
    <mxGraphModel pageWidth="1200" pageHeight="680" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="680" as="geometry" />
        </mxCell>
        <mxCell id="title" value="受入検査ロット状態遷移（IQC / FR-IQ）" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="600" height="32" as="geometry" />
        </mxCell>
        <!-- ===== STATE NODES ===== -->
        <!-- Row 1: main flow -->
        <mxCell id="s_pending" value="PENDING&#xa;受入待ち" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_inspecting" value="INSPECTING&#xa;検査実施中" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="280" y="200" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_passed" value="PASSED&#xa;合格・後工程解放可" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- Row 2: rejected branch -->
        <mxCell id="s_rejected" value="REJECTED&#xa;不合格（4区分判定待ち）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="280" y="370" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- Row 3: terminal states (right column) -->
        <mxCell id="s_concession" value="CONDITIONAL_PASS&#xa;特採承認済" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="540" y="320" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_screening" value="SCREENING_REQUIRED&#xa;選別実施中" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="540" y="400" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_returned" value="RETURNED&#xa;仕入先返却完了" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="540" y="480" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_scrapped" value="SCRAPPED&#xa;廃却完了" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="540" y="560" width="190" height="60" as="geometry" />
        </mxCell>
        <!-- ===== TRANSITIONS ===== -->
        <!-- PENDING → INSPECTING (horizontal, label middle) -->
        <mxCell id="e_pi" value="受入登録" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="230" as="sourcePoint" />
            <mxPoint x="280" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- INSPECTING → PASSED (horizontal, label middle) -->
        <mxCell id="e_ip" value="合格" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="230" as="sourcePoint" />
            <mxPoint x="520" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- INSPECTING → REJECTED (vertical down) -->
        <mxCell id="e_ir" value="不合格" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="260" as="sourcePoint" />
            <mxPoint x="350" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- REJECTED → CONDITIONAL_PASS -->
        <!-- Source: right side of REJECTED at (440, 388), target: left of CONCESSION at (540, 350) -->
        <mxCell id="e_rc" value="特採承認" style="endArrow=classic;endFill=1;html=1;strokeColor=#d79b00;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="440" y="388" as="sourcePoint" />
            <mxPoint x="540" y="350" as="targetPoint" />
            <Array as="points">
              <mxPoint x="500" y="388" />
              <mxPoint x="500" y="350" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- REJECTED → SCREENING_REQUIRED (horizontal right) -->
        <mxCell id="e_rs" value="選別判定" style="endArrow=classic;endFill=1;html=1;strokeColor=#d79b00;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="440" y="410" as="sourcePoint" />
            <mxPoint x="540" y="430" as="targetPoint" />
            <Array as="points">
              <mxPoint x="500" y="410" />
              <mxPoint x="500" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- REJECTED → RETURNED -->
        <mxCell id="e_rr" value="返品判定" style="endArrow=classic;endFill=1;html=1;strokeColor=#666666;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="440" y="420" as="sourcePoint" />
            <mxPoint x="540" y="510" as="targetPoint" />
            <Array as="points">
              <mxPoint x="494" y="420" />
              <mxPoint x="494" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- REJECTED → SCRAPPED -->
        <mxCell id="e_rsc" value="廃却判定" style="endArrow=classic;endFill=1;html=1;strokeColor=#666666;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="440" y="428" as="sourcePoint" />
            <mxPoint x="540" y="590" as="targetPoint" />
            <Array as="points">
              <mxPoint x="488" y="428" />
              <mxPoint x="488" y="590" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- CONDITIONAL_PASS → REJECTED (dashed, 期限切れ) -->
        <mxCell id="e_cr" value="特採期限超過" style="endArrow=classic;endFill=1;html=1;strokeColor=#d79b00;dashed=1;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="540" y="360" as="sourcePoint" />
            <mxPoint x="440" y="380" as="targetPoint" />
            <Array as="points">
              <mxPoint x="510" y="360" />
              <mxPoint x="510" y="380" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- ===== LEGEND / NOTES ===== -->
        <mxCell id="legend_title" value="凡例・補足" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="780" y="200" width="120" height="24" as="geometry" />
        </mxCell>
        <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="780" y="230" width="390" height="200" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="● PASSED / CONDITIONAL_PASS のみ後工程での材料&#xa;　QR スキャンが通過（FR-IQ-009）&#xa;● その他のステータスは ERR-BIZ-016 でブロック&#xa;● IQC 未実施は ERR-BIZ-017 でブロック&#xa;● SCRAPPED / RETURNED は取り消し不可（Append-only）&#xa;● 特採有効期限超過で自動的に REJECTED へ遷移（点線）&#xa;● 選別完了後、合格個体の子ロット（split_lot）が PASSED" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="790" y="240" width="370" height="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

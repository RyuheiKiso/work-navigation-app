<mxfile>
  <diagram name="Outbox送信状態遷移" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Outbox 送信 状態遷移図" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="32" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="" style="ellipse;aspect=fixed;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="310" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- States -->
        <mxCell id="pend"    value="PENDING"  style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1"><mxGeometry x="160" y="288" width="180" height="70" as="geometry" /></mxCell>
        <mxCell id="sending" value="SENDING"  style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1"><mxGeometry x="470" y="288" width="180" height="70" as="geometry" /></mxCell>
        <mxCell id="sent"    value="SENT"     style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1"><mxGeometry x="800" y="160" width="180" height="70" as="geometry" /></mxCell>
        <mxCell id="failed"  value="FAILED"   style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1"><mxGeometry x="800" y="420" width="180" height="70" as="geometry" /></mxCell>
        <mxCell id="dlq"     value="DLQ"      style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1"><mxGeometry x="1000" y="560" width="180" height="70" as="geometry" /></mxCell>

        <!-- Start → PENDING -->
        <mxCell id="e_start" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="325" as="sourcePoint" /><mxPoint x="160" y="325" as="targetPoint" /></mxGeometry></mxCell>

        <!-- PENDING → SENDING: 送信開始 -->
        <mxCell id="e_p_s" value="送信開始" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="pend" target="sending" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="340" y="323" /><mxPoint x="470" y="323" /></Array></mxGeometry></mxCell>

        <!-- SENDING → SENT: ACK受信 -->
        <mxCell id="e_s_sent" value="ACK 受信" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="sending" target="sent" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="650" y="305" /><mxPoint x="800" y="195" /></Array></mxGeometry></mxCell>

        <!-- SENDING → FAILED: タイムアウト/エラー -->
        <mxCell id="e_s_fail" value="タイムアウト/エラー" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="sending" target="failed" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="650" y="358" /><mxPoint x="800" y="455" /></Array></mxGeometry></mxCell>

        <!-- FAILED → SENDING: リトライ(<3回) -->
        <mxCell id="e_fail_s" value="リトライ（&lt;3回）" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="failed" target="sending" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="800" y="435" /><mxPoint x="740" y="435" /><mxPoint x="740" y="358" /><mxPoint x="650" y="358" /></Array></mxGeometry></mxCell>

        <!-- FAILED → DLQ: リトライ上限超過 -->
        <mxCell id="e_fail_dlq" value="リトライ上限超過" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="failed" target="dlq" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="980" y="455" /><mxPoint x="1090" y="560" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

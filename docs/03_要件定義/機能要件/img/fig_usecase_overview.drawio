        <mxCell id="e_op_004" edge="1" source="actor_op" target="uc004" style="endArrow=none;html=1;strokeColor=#333333;edgeStyle=none;" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="65" y="85" /><mxPoint x="65" y="300" /><mxPoint x="120" y="300" /></Array></mxGeometry></mxCell>


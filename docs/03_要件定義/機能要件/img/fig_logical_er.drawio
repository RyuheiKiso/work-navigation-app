<mxfile>
  <diagram name="論理ER図" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1400" height="900" as="geometry" />
        </mxCell>
        <mxCell id="title" value="論理 ER 図（主要エンティティ）" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="450" y="10" width="500" height="32" as="geometry" />
        </mxCell>

        <!-- Master entities (top row) -->
        <mxCell id="mv"  value="MasterVersion&#xa;─────────────&#xa;id, entity_type&#xa;version, status&#xa;created_by, created_at" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;align=left;" vertex="1" parent="1"><mxGeometry x="30"  y="55" width="200" height="95" as="geometry" /></mxCell>
        <mxCell id="proc" value="Process (L1)&#xa;─────────────&#xa;id, code, name&#xa;version_id, status" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;align=left;" vertex="1" parent="1"><mxGeometry x="280" y="55" width="200" height="80" as="geometry" /></mxCell>
        <mxCell id="op"  value="Operation (L2)&#xa;─────────────&#xa;id, code, name&#xa;process_id, seq_no" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;align=left;" vertex="1" parent="1"><mxGeometry x="540" y="55" width="200" height="80" as="geometry" /></mxCell>
        <mxCell id="step" value="Step (L3)&#xa;─────────────&#xa;id, code, title&#xa;operation_id, seq_no&#xa;instruction, media_url" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;align=left;" vertex="1" parent="1"><mxGeometry x="800" y="40" width="200" height="110" as="geometry" /></mxCell>

        <!-- User -->
        <mxCell id="user" value="User&#xa;─────────────&#xa;id, login_id&#xa;display_name, role&#xa;site_id, is_active" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;align=left;" vertex="1" parent="1"><mxGeometry x="1110" y="55" width="200" height="95" as="geometry" /></mxCell>

        <!-- WorkExecution (center) -->
        <mxCell id="we"  value="WorkExecution&#xa;─────────────&#xa;id, process_id&#xa;operator_id, status&#xa;started_at, ended_at" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;" vertex="1" parent="1"><mxGeometry x="540" y="290" width="200" height="95" as="geometry" /></mxCell>

        <!-- StepRecord -->
        <mxCell id="sr"  value="StepRecord&#xa;─────────────&#xa;id, execution_id&#xa;step_id, operator_id&#xa;started_at, completed_at&#xa;result" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;" vertex="1" parent="1"><mxGeometry x="800" y="270" width="200" height="110" as="geometry" /></mxCell>

        <!-- Evidence -->
        <mxCell id="ev"  value="Evidence&#xa;─────────────&#xa;id, step_record_id&#xa;type, file_path&#xa;captured_at, operator_id" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;" vertex="1" parent="1"><mxGeometry x="1060" y="200" width="200" height="95" as="geometry" /></mxCell>

        <!-- ElectronicSign -->
        <mxCell id="es"  value="ElectronicSign&#xa;─────────────&#xa;id, step_record_id&#xa;signer_id, sign_type&#xa;signed_at, hash" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;" vertex="1" parent="1"><mxGeometry x="1060" y="400" width="200" height="95" as="geometry" /></mxCell>

        <!-- Defect -->
        <mxCell id="def" value="Defect&#xa;─────────────&#xa;id, execution_id&#xa;defect_code, description&#xa;detected_at, status" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;align=left;" vertex="1" parent="1"><mxGeometry x="280" y="490" width="200" height="95" as="geometry" /></mxCell>

        <!-- Outbox -->
        <mxCell id="ob"  value="Outbox&#xa;─────────────&#xa;id, idempotency_key&#xa;event_type, payload&#xa;status, retry_count" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;align=left;" vertex="1" parent="1"><mxGeometry x="540" y="520" width="200" height="95" as="geometry" /></mxCell>

        <!-- ===== RELATIONSHIPS ===== -->
        <!-- MasterVersion 1 to * Process -->
        <mxCell id="r_mv_proc" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="mv" target="proc" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="230" y="95" /><mxPoint x="280" y="95" /></Array></mxGeometry></mxCell>

        <!-- Process 1 to * Operation -->
        <mxCell id="r_proc_op" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="proc" target="op" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="480" y="95" /><mxPoint x="540" y="95" /></Array></mxGeometry></mxCell>

        <!-- Operation 1 to * Step -->
        <mxCell id="r_op_step" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="op" target="step" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="740" y="95" /><mxPoint x="800" y="95" /></Array></mxGeometry></mxCell>

        <!-- Process (via id) 1 to * WorkExecution -->
        <mxCell id="r_proc_we" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="proc" target="we" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="380" y="155" /><mxPoint x="380" y="337" /><mxPoint x="540" y="337" /></Array></mxGeometry></mxCell>

        <!-- WorkExecution 1 to * StepRecord -->
        <mxCell id="r_we_sr" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="we" target="sr" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="740" y="337" /><mxPoint x="800" y="337" /></Array></mxGeometry></mxCell>

        <!-- StepRecord 1 to * Evidence -->
        <mxCell id="r_sr_ev" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="sr" target="ev" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1000" y="310" /><mxPoint x="1060" y="247" /></Array></mxGeometry></mxCell>

        <!-- StepRecord 1 to * ElectronicSign -->
        <mxCell id="r_sr_es" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="sr" target="es" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1000" y="360" /><mxPoint x="1060" y="447" /></Array></mxGeometry></mxCell>

        <!-- WorkExecution 1 to 0..1 Defect -->
        <mxCell id="r_we_def" value="0..1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="we" target="def" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="640" y="385" /><mxPoint x="640" y="460" /><mxPoint x="380" y="460" /><mxPoint x="380" y="490" /></Array></mxGeometry></mxCell>

        <!-- WorkExecution 1 to * Outbox (via event) -->
        <mxCell id="r_we_ob" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="we" target="ob" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="640" y="385" /><mxPoint x="640" y="520" /></Array></mxGeometry></mxCell>

        <!-- User referenced by WorkExecution: route above all entities at y=8, drop at x=535 (left gap of op/we) -->
        <mxCell id="r_user_we" value="1..*" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=10;fontColor=#333333;edgeStyle=none;" edge="1" source="user" target="we" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1210" y="8" /><mxPoint x="535" y="8" /><mxPoint x="535" y="290" /><mxPoint x="540" y="337" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

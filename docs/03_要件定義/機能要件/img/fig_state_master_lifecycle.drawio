<mxfile>
  <diagram name="マスタライフサイクル状態遷移" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="マスタ ライフサイクル 状態遷移図" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="32" as="geometry" />
        </mxCell>

        <!-- Start point -->
        <mxCell id="start" value="" style="ellipse;aspect=fixed;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="170" y="195" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- States -->
        <mxCell id="draft" value="DRAFT"          style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="230" y="175" width="200" height="70" as="geometry" /></mxCell>
        <mxCell id="rev"   value="UNDER_REVIEW"   style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1"><mxGeometry x="530" y="175" width="200" height="70" as="geometry" /></mxCell>
        <mxCell id="pub"   value="PUBLISHED"       style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1"><mxGeometry x="530" y="415" width="200" height="70" as="geometry" /></mxCell>
        <mxCell id="arch"  value="ARCHIVED"        style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1"><mxGeometry x="830" y="415" width="200" height="70" as="geometry" /></mxCell>
        <mxCell id="rej"   value="REJECTED"        style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1"><mxGeometry x="830" y="175" width="200" height="70" as="geometry" /></mxCell>

        <!-- Start → DRAFT -->
        <mxCell id="e_start" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="200" y="210" as="sourcePoint" /><mxPoint x="230" y="210" as="targetPoint" /></mxGeometry></mxCell>

        <!-- DRAFT → UNDER_REVIEW: レビュー申請 -->
        <mxCell id="e_d_r" value="レビュー申請" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="draft" target="rev" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="430" y="200" /><mxPoint x="530" y="200" /></Array></mxGeometry></mxCell>

        <!-- UNDER_REVIEW → PUBLISHED: 承認 -->
        <mxCell id="e_r_pub" value="承認" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="rev" target="pub" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="630" y="245" /><mxPoint x="630" y="415" /></Array></mxGeometry></mxCell>

        <!-- UNDER_REVIEW → REJECTED: 差し戻し -->
        <mxCell id="e_r_rej" value="差し戻し" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="rev" target="rej" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="730" y="210" /><mxPoint x="830" y="210" /></Array></mxGeometry></mxCell>

        <!-- REJECTED → DRAFT: 修正再起動 -->
        <mxCell id="e_rej_d" value="修正再起動" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="rej" target="draft" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="930" y="245" /><mxPoint x="930" y="340" /><mxPoint x="330" y="340" /><mxPoint x="330" y="245" /></Array></mxGeometry></mxCell>

        <!-- PUBLISHED → ARCHIVED: 廃止 -->
        <mxCell id="e_pub_arch" value="廃止" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="pub" target="arch" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="730" y="450" /><mxPoint x="830" y="450" /></Array></mxGeometry></mxCell>

        <!-- PUBLISHED → DRAFT: 改訂（複製） -->
        <mxCell id="e_pub_d" value="改訂（複製）" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="pub" target="draft" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="530" y="480" /><mxPoint x="160" y="480" /><mxPoint x="160" y="245" /><mxPoint x="230" y="245" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile>
  <diagram name="作業実行ステータス状態遷移" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="作業実行ステータス 状態遷移図" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="32" as="geometry" />
        </mxCell>

        <!-- Start point -->
        <mxCell id="start" value="" style="ellipse;aspect=fixed;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="570" y="55" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- States -->
        <mxCell id="ns"   value="NOT_STARTED" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1"><mxGeometry x="490" y="110" width="200" height="65" as="geometry" /></mxCell>
        <mxCell id="ip"   value="IN_PROGRESS"  style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1"><mxGeometry x="490" y="290" width="200" height="65" as="geometry" /></mxCell>
        <mxCell id="su"   value="SUSPENDED"    style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="180" y="290" width="200" height="65" as="geometry" /></mxCell>
        <mxCell id="comp" value="COMPLETED"    style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1"><mxGeometry x="800" y="290" width="200" height="65" as="geometry" /></mxCell>
        <mxCell id="canc" value="CANCELLED"    style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1"><mxGeometry x="490" y="530" width="200" height="65" as="geometry" /></mxCell>

        <!-- Start → NOT_STARTED -->
        <mxCell id="e_start" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="585" y="85" as="sourcePoint" /><mxPoint x="585" y="110" as="targetPoint" /></mxGeometry></mxCell>

        <!-- NOT_STARTED → IN_PROGRESS: 作業開始 -->
        <mxCell id="e_ns_ip" value="作業開始" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="ns" target="ip" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="590" y="200" /><mxPoint x="590" y="290" /></Array></mxGeometry></mxCell>

        <!-- IN_PROGRESS → SUSPENDED: 中断 -->
        <mxCell id="e_ip_su" value="中断" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="ip" target="su" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="490" y="322" /><mxPoint x="380" y="322" /></Array></mxGeometry></mxCell>

        <!-- SUSPENDED → IN_PROGRESS: 再開 -->
        <mxCell id="e_su_ip" value="再開" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="su" target="ip" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="380" y="342" /><mxPoint x="490" y="342" /></Array></mxGeometry></mxCell>

        <!-- IN_PROGRESS → COMPLETED: 最終Step完了 -->
        <mxCell id="e_ip_comp" value="最終Step完了" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="ip" target="comp" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="690" y="322" /><mxPoint x="800" y="322" /></Array></mxGeometry></mxCell>

        <!-- IN_PROGRESS → CANCELLED: キャンセル -->
        <mxCell id="e_ip_canc" value="キャンセル" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="ip" target="canc" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="590" y="355" /><mxPoint x="590" y="530" /></Array></mxGeometry></mxCell>

        <!-- NOT_STARTED → CANCELLED: キャンセル -->
        <mxCell id="e_ns_canc" value="キャンセル" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" source="ns" target="canc" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="530" y="175" /><mxPoint x="460" y="175" /><mxPoint x="460" y="562" /><mxPoint x="490" y="562" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile>
  <diagram name="Outbox同期シーケンス" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1400" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Outbox 同期シーケンス" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="450" y="10" width="500" height="32" as="geometry" />
        </mxCell>

        <!-- Actor headers: spacing 320px apart -->
        <mxCell id="h_app" value="ハンディ APP"  style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="30"  y="55" width="160" height="50" as="geometry" /></mxCell>
        <mxCell id="h_ob"  value="SQLite-Outbox" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1"><mxGeometry x="360" y="55" width="160" height="50" as="geometry" /></mxCell>
        <mxCell id="h_be"  value="バックエンド"  style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1"><mxGeometry x="700" y="55" width="160" height="50" as="geometry" /></mxCell>
        <mxCell id="h_erp" value="親機 / ERP"    style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1"><mxGeometry x="1060" y="55" width="160" height="50" as="geometry" /></mxCell>

        <!-- Lifelines: centers at 110, 440, 780, 1140 -->
        <mxCell id="ll_app" value="" style="dashed=1;endArrow=none;html=1;strokeColor=#333333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="110"  y="105" as="sourcePoint" /><mxPoint x="110"  y="660" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_ob"  value="" style="dashed=1;endArrow=none;html=1;strokeColor=#333333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="440"  y="105" as="sourcePoint" /><mxPoint x="440"  y="660" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_be"  value="" style="dashed=1;endArrow=none;html=1;strokeColor=#333333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780"  y="105" as="sourcePoint" /><mxPoint x="780"  y="660" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_erp" value="" style="dashed=1;endArrow=none;html=1;strokeColor=#333333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="105" as="sourcePoint" /><mxPoint x="1140" y="660" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Messages: all labels in #333333 for WCAG compliance, spacing dist=330px -->
        <!-- msg1: APP→Outbox dist=330px, label≈140px (9 chars × 12 + 12 half × 0.55) ≈ fine -->
        <mxCell id="msg1" value="1. INSERT PENDING" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="110" y="148" as="sourcePoint" /><mxPoint x="440" y="148" as="targetPoint" /></mxGeometry></mxCell>
        <!-- msg2: Outbox→Backend dist=340px -->
        <mxCell id="msg2" value="2. 非同期送信（SENDING）" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="440" y="218" as="sourcePoint" /><mxPoint x="780" y="218" as="targetPoint" /></mxGeometry></mxCell>
        <!-- msg3: self-loop at Backend — use offset points, no zero-length -->
        <mxCell id="msg3" value="3. 冪等性チェック" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="280" as="sourcePoint" /><mxPoint x="780" y="440" as="targetPoint" /><Array as="points"><mxPoint x="870" y="280" /><mxPoint x="870" y="440" /></Array></mxGeometry></mxCell>
        <!-- msg4: Backend→Outbox dist=340px -->
        <mxCell id="msg4" value="4. ACK（SENT）" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="470" as="sourcePoint" /><mxPoint x="440" y="470" as="targetPoint" /></mxGeometry></mxCell>
        <!-- msg5: Backend→ERP dist=360px -->
        <mxCell id="msg5" value="5. ERP 実績転送" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="530" as="sourcePoint" /><mxPoint x="1140" y="530" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Failure separator -->
        <mxCell id="sep_fail" value="" style="endArrow=none;html=1;strokeColor=#666666;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="10" y="540" as="sourcePoint" /><mxPoint x="1380" y="540" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lbl_fail" value="【失敗時】" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="10" y="545" width="80" height="20" as="geometry" /></mxCell>
        <!-- msg6: Backend→Outbox dist=340px; shorten label -->
        <mxCell id="msg6" value="6. FAILED（タイムアウト）" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="580" as="sourcePoint" /><mxPoint x="440" y="580" as="targetPoint" /></mxGeometry></mxCell>
        <!-- msg7: Outbox→Backend dist=340px -->
        <mxCell id="msg7" value="7. RETRY（&lt;3回）" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;fontFamily=Helvetica;fontSize=11;fontColor=#333333;edgeStyle=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="440" y="640" as="sourcePoint" /><mxPoint x="780" y="640" as="targetPoint" /></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile>
  <diagram name="リワーク業務フロー" id="page-1">
    <mxGraphModel pageWidth="1200" pageHeight="820" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="820" as="geometry" />
        </mxCell>
        <mxCell id="title" value="リワーク・修正作業業務フロー（BF-08）" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="640" height="32" as="geometry" />
        </mxCell>
        <!-- ===== MAIN FLOW NODES ===== -->
        <mxCell id="n1" value="不適合起票（BF-03経由）&#xa;PENDING_DISPOSITION 状態へ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="ディスポジション判定（MRB）&#xa;品質担当＋現場監督の二者電子サイン" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="240" height="60" as="geometry" />
        </mxCell>
        <!-- Decision: disposition type -->
        <mxCell id="d1" value="判定種別" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="120" y="320" width="160" height="80" as="geometry" />
        </mxCell>
        <!-- REWORK branch -->
        <mxCell id="n3" value="リワーク作業実施&#xa;（新case_id・前後写真必須）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="再検査（別worker_id必須）&#xa;修正品QRスキャン起動" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="80" y="580" width="240" height="60" as="geometry" />
        </mxCell>
        <!-- Re-inspection decision -->
        <mxCell id="d2" value="再検査結果" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="120" y="700" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- TERMINAL NODES (right side) -->
        <!-- SCRAP/RETURN from disposition -->
        <mxCell id="t1" value="廃却処理&#xa;廃棄物処理票・立会者サイン" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="420" y="300" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="仕入先返却処理&#xa;返却伝票・追跡番号記録" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="420" y="380" width="200" height="60" as="geometry" />
        </mxCell>
        <!-- CLOSED states from re-inspection -->
        <mxCell id="t3" value="CLOSED_OK_RELEASE&#xa;再検査合格・出荷可" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="420" y="660" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="再ディスポジション&#xa;（RE_REWORK_NEEDED）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="420" y="740" width="200" height="60" as="geometry" />
        </mxCell>
        <!-- Annotations -->
        <mxCell id="a1" value="Just Culture 原則:&#xa;作業員は上申権限のみ（決定は品質担当・監督）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="660" y="200" width="320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="Two-Person Integrity:&#xa;同一 worker_id 不可（ERR-BIZ-021）&#xa;二者の signer_id が異なることを DB トリガーで検証" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="660" y="250" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="ALCOA+ Original 原則:&#xa;元 WorkExecution（parent_case_id）は不可侵&#xa;リワークは新 case_id で独立 Append-only 記録" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="660" y="460" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="Two-Person Integrity（再検査）:&#xa;再検査者 ≠ リワーク実施者（ERR-BIZ-023）&#xa;修正品 QR ラベル（GS1 AI 8003 + AI 91）を発行" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">

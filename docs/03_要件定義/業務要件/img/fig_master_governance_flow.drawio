<mxfile>
  <diagram name="マスタDraft-Publishフロー" id="page-1">
    <mxGraphModel pageWidth="1200" pageHeight="700" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="マスタ Draft → Publish ガバナンスフロー" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="32" as="geometry" />
        </mxCell>
        <!-- ステップ矩形 -->
        <mxCell id="s1" value="改訂提案" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="Draft編集" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="220" y="280" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="レビュー" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="120" height="60" as="geometry" />
        </mxCell>
        <!-- 承認判定ゲート -->
        <mxCell id="gate" value="承認？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="580" y="260" width="100" height="100" as="geometry" />
        </mxCell>
        <!-- Publish, Active, Archive -->
        <mxCell id="s5" value="Publish" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="750" y="280" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="Active&#xa;（運用中）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="940" y="280" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="Archive" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="1060" y="460" width="100" height="60" as="geometry" />
        </mxCell>
        <!-- Draft差し戻しフィードバック -->
        <mxCell id="s_reject" value="差し戻し&#xa;（要修正）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="580" y="460" width="120" height="60" as="geometry" />
        </mxCell>
        <!-- 矢印 s1→s2 -->
        <mxCell id="e12" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="160" y="310" />
              <mxPoint x="220" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- s2→s3 -->
        <mxCell id="e23" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="310" />
              <mxPoint x="400" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- s3→gate -->
        <mxCell id="e3g" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="s3" target="gate" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="310" />
              <mxPoint x="580" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- gate→s5 Yes -->
        <mxCell id="eg5" value="Yes" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="gate" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="310" />
              <mxPoint x="750" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- gate→s_reject No -->
        <mxCell id="eg_rej" value="No" style="endArrow=classic;endFill=1;html=1;strokeColor=#b85450;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="gate" target="s_reject" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="630" y="360" />
              <mxPoint x="630" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- s_reject→s2 フィードバック -->
        <mxCell id="erej2" value="修正" style="endArrow=classic;endFill=1;html=1;strokeColor=#b85450;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_reject" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="490" />
              <mxPoint x="280" y="490" />
              <mxPoint x="280" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- s5→s6 -->
        <mxCell id="e56" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="s5" target="s6" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="870" y="310" />
              <mxPoint x="940" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- s6→s7 Archive -->
        <mxCell id="e67" value="廃版時" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s6" target="s7" parent="1">
          <mxGeometry relative="1" as="geometry">

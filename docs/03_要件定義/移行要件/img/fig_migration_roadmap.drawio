<mxfile>
  <diagram name="移行ロードマップ" id="page-1">
    <mxGraphModel dx="1100" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="600" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1400" height="600" as="geometry" />
        </mxCell>
        <mxCell id="title" value="移行ロードマップ" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- Phase 1: 移行準備 (app色 #fff2cc / #d79b00) -->
        <mxCell id="ph1" value="&lt;b&gt;フェーズ1&lt;/b&gt;&lt;br&gt;移行準備&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;・マスタデータ整理&lt;br&gt;・Excel変換&lt;br&gt;・テンプレ確定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="250" height="150" as="geometry" />
        </mxCell>

        <!-- Phase 2: リハーサル (net色 #dae8fc / #6c8ebf) -->
        <mxCell id="ph2" value="&lt;b&gt;フェーズ2&lt;/b&gt;&lt;br&gt;リハーサル&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;・第1回リハーサル&lt;br&gt;・第2回リハーサル&lt;br&gt;・品質確認&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="370" y="120" width="250" height="150" as="geometry" />
        </mxCell>

        <!-- Phase 3: 本番移行 (危険色 #f8cecc / #b85450) -->
        <mxCell id="ph3" value="&lt;b&gt;フェーズ3&lt;/b&gt;&lt;br&gt;本番移行&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;・カットオーバー段階1&lt;br&gt;・カットオーバー段階2&lt;br&gt;・カットオーバー段階3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="660" y="120" width="250" height="150" as="geometry" />
        </mxCell>

        <!-- Phase 4: 検証完了 (data色 #e1d5e7 / #9673a6) -->
        <mxCell id="ph4" value="&lt;b&gt;フェーズ4&lt;/b&gt;&lt;br&gt;検証完了&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;・並行運用&lt;br&gt;・受入確認&lt;br&gt;・移行完了宣言&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="950" y="120" width="250" height="150" as="geometry" />
        </mxCell>

        <!-- Arrows between phases -->
        <mxCell id="e1" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="ph1" target="ph2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="ph2" target="ph3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="ph3" target="ph4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Milestones (diamonds) below each phase (phases end y=270, milestones at y=320) -->
        <mxCell id="ms1" value="MS1&lt;br&gt;準備完了" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="155" y="320" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ms2" value="MS2&lt;br&gt;リハ完了" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="445" y="320" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ms3" value="MS3&lt;br&gt;移行完了" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="735" y="320" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ms4" value="MS4&lt;br&gt;受入完了" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="1025" y="320" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- Connecting phases to milestones (direct vertical, phases now end at y=270) -->
        <mxCell id="e5" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="ph1" target="ms1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="ph2" target="ms2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="ph3" target="ms3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="ph4" target="ms4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Timeline bar -->
        <mxCell id="timeline" value="移行タイムライン →" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=left;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="tl-start" value="" style="point;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="458" width="4" height="4" as="geometry" />
        </mxCell>
        <mxCell id="tl-end" value="" style="point;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1276" y="458" width="4" height="4" as="geometry" />
        </mxCell>
        <mxCell id="timeline-bar" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#333333;strokeWidth=2;edgeStyle=none;" edge="1" source="tl-start" target="tl-end" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

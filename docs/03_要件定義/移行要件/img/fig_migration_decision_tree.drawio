<mxfile>
  <diagram name="過去記録引継ぎ判断ツリー" id="page-1">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="過去記録引継ぎ 3択判断ツリー" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- Root node -->
        <mxCell id="root" value="過去記録の引継ぎ判断" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="470" y="80" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 1 (diamond) -->
        <mxCell id="g1" value="直近1年以内か？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="490" y="200" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Yes branch: 移行対象 (data色) -->
        <mxCell id="res-yes" value="移行対象&lt;br&gt;（external_lot_id 紐付け）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="160" y="200" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 2 (diamond) - No branch -->
        <mxCell id="g2" value="重要な製品・品番か？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="490" y="390" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Yes branch from g2: 個別判断 (net色) -->
        <mxCell id="res-g2-yes" value="個別判断・IT担当に相談" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="250" y="530" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- No branch from g2: 移行非対象 (infra色) -->
        <mxCell id="res-g2-no" value="移行非対象&lt;br&gt;（外部システムに保持）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="750" y="530" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <!-- Root → Gate1 -->
        <mxCell id="e-root-g1" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="root" target="g1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Gate1 → res-yes (Yes, left) -->
        <mxCell id="e-g1-yes" value="Yes" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="g1" target="res-yes" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="490" y="240" />
              <mxPoint x="270" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Gate1 → Gate2 (No, down) -->
        <mxCell id="e-g1-no" value="No" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="g1" target="g2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="310" />
              <mxPoint x="600" y="390" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Gate2 → res-g2-yes (Yes, left) -->
        <mxCell id="e-g2-yes" value="Yes" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="g2" target="res-g2-yes" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="490" y="430" />
              <mxPoint x="350" y="430" />
              <mxPoint x="350" y="530" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Gate2 → res-g2-no (No, right) -->
        <mxCell id="e-g2-no" value="No" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="g2" target="res-g2-no" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="430" />
              <mxPoint x="860" y="430" />
              <mxPoint x="860" y="530" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

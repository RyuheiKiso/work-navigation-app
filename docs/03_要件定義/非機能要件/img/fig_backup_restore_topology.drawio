<mxfile>
  <diagram name="バックアップ/リストア構成" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="バックアップ / リストア構成" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- Layer labels on left -->
        <mxCell id="lbl_primary" value="【上段】原本" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=right;" vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="90" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl_local" value="【中段】&#xa;ローカルバックアップ" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=right;" vertex="1" parent="1">
          <mxGeometry x="10" y="380" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lbl_offsite" value="【下段】&#xa;オフサイト" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=right;" vertex="1" parent="1">
          <mxGeometry x="20" y="610" width="90" height="40" as="geometry" />
        </mxCell>

        <!-- Upper tier: PostgreSQL server (app color) -->
        <mxCell id="pg_server" value="PostgreSQL サーバ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="200" y="110" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pg_detail" value="Primary DB&#xa;WAL ストリーミング有効" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="195" width="220" height="35" as="geometry" />
        </mxCell>

        <!-- Middle tier: WAL PITR (net color) -->
        <mxCell id="wal_pitr" value="WAL PITR" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="160" y="360" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Middle tier: pg_dump daily (net color) -->
        <mxCell id="pg_dump" value="日次 pg_dump" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="380" y="360" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Middle tier: NAS (net color) -->
        <mxCell id="nas" value="NAS&#xa;（ネットワークストレージ）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="600" y="355" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Lower tier: Offsite removable media (infra color) -->
        <mxCell id="offsite" value="別棟可搬媒体&#xa;（オフサイトバックアップ）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="580" y="600" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow: PG -> WAL PITR (continuous) -->
        <mxCell id="e_wal" value="WAL&#xa;(継続)" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="280" y="190" as="sourcePoint" />
            <mxPoint x="240" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: PG -> pg_dump (daily) -->
        <mxCell id="e_dump" value="日次" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="190" as="sourcePoint" />
            <mxPoint x="460" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: WAL PITR -> NAS (route below boxes via y=450) -->
        <mxCell id="e_wal_nas" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="420" as="sourcePoint" />
            <mxPoint x="700" y="420" as="targetPoint" />
            <Array as="points">
              <mxPoint x="240" y="450" />
              <mxPoint x="700" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Arrow: pg_dump -> NAS -->
        <mxCell id="e_dump_nas" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="540" y="420" as="sourcePoint" />
            <mxPoint x="600" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: NAS -> Offsite (weekly) -->
        <mxCell id="e_offsite" value="週次" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="425" as="sourcePoint" />
            <mxPoint x="700" y="600" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Restore path: dashed arrow from NAS/Offsite back to PG -->
        <mxCell id="e_restore" value="障害時リストアパス" style="endArrow=classic;endFill=1;html=1;strokeColor=#b85450;edgeStyle=none;dashed=1;strokeWidth=2;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="900" y="635" as="sourcePoint" />
            <mxPoint x="950" y="150" as="targetPoint" />
            <Array as="points">
              <mxPoint x="950" y="635" />
              <mxPoint x="950" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_restore2" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#b85450;edgeStyle=none;dashed=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="950" y="150" as="sourcePoint" />
            <mxPoint x="420" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg_title" value="凡例" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg_app" value="原本 (app)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="120" y="677" width="100" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg_net" value="ローカルBK (net)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="230" y="677" width="130" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg_infra" value="オフサイト (infra)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="370" y="677" width="130" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg_restore" value="リストアパス（点線）" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=left;" vertex="1" parent="1">
          <mxGeometry x="510" y="680" width="140" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

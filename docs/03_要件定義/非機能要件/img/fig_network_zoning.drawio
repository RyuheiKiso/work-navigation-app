<mxfile>
  <diagram name="ネットワークゾーニング" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="ネットワークゾーニング" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- Outermost zone: 工場物理境界 (infra, dashed) -->
        <mxCell id="zone_factory" value="工場物理境界" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;verticalAlign=top;dashed=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="920" height="660" as="geometry" />
        </mxCell>

        <!-- Middle zone: 社内LAN (net) -->
        <mxCell id="zone_lan" value="社内 LAN（192.168.x.x）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="130" width="840" height="560" as="geometry" />
        </mxCell>

        <!-- Inner zone: サーバセグメント (app) -->
        <mxCell id="zone_server" value="サーバセグメント（DMZ 的）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="540" y="200" width="360" height="440" as="geometry" />
        </mxCell>

        <!-- LAN components: タブレット group -->
        <mxCell id="tablet1" value="タブレット #1&#xa;Android / iOS" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="140" y="280" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tablet2" value="タブレット #2&#xa;Android / iOS" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="140" y="380" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tablet_more" value="…（N 台）" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="165" y="455" width="90" height="20" as="geometry" />
        </mxCell>
        <mxCell id="mgmt_pc" value="管理 PC&#xa;（マスタメンテ）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="340" y="320" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- Server segment components -->
        <mxCell id="web_server" value="Web サーバ&#xa;（Axum / Rust）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="570" y="260" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="db_server" value="DB サーバ&#xa;（PostgreSQL）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="570" y="380" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nas_server" value="NAS&#xa;（バックアップ）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="570" y="490" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- Connection arrows inside zones -->
        <mxCell id="e_t1_web" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="280" y="310" as="sourcePoint" />
            <mxPoint x="570" y="290" as="targetPoint" />
            <Array as="points">
              <mxPoint x="490" y="310" />
              <mxPoint x="490" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_t2_web" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="280" y="410" as="sourcePoint" />
            <mxPoint x="570" y="310" as="targetPoint" />
            <Array as="points">
              <mxPoint x="490" y="410" />
              <mxPoint x="490" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_mgmt_web" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="490" y="350" as="sourcePoint" />
            <mxPoint x="570" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e_web_db" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="645" y="320" as="sourcePoint" />
            <mxPoint x="645" y="380" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e_db_nas" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="645" y="440" as="sourcePoint" />
            <mxPoint x="645" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Internet / External (danger color) -->
        <mxCell id="internet_box" value="インターネット（外部）&#xa;接続禁止" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="1020" y="320" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="internet_note" value="境界外・接続禁止" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#b85450;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="1020" y="415" width="150" height="20" as="geometry" />
        </mxCell>

        <!-- Blocked arrow from factory to internet -->
        <mxCell id="e_blocked" value="遮断" style="endArrow=block;endFill=0;html=1;strokeColor=#b85450;strokeWidth=2;edgeStyle=none;fontColor=#333333;fontSize=11;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="980" y="360" as="sourcePoint" />
            <mxPoint x="1020" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

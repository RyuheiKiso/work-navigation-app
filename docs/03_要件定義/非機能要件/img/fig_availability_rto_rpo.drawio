<mxfile>
  <diagram name="RTO/RPO定義図" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="RTO / RPO 定義図" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- Zone 1: 正常運用（data色） -->
        <mxCell id="zone_normal" value="正常運用" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="300" height="220" as="geometry" />
        </mxCell>

        <!-- Zone 2: 障害・復旧作業中（危険色） -->
        <mxCell id="zone_failure" value="障害・復旧作業中" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="420" y="120" width="360" height="220" as="geometry" />
        </mxCell>

        <!-- Zone 3: 業務再開後（app色） -->
        <mxCell id="zone_restored" value="業務再開後" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="840" y="120" width="300" height="220" as="geometry" />
        </mxCell>

        <!-- Timeline horizontal line -->
        <mxCell id="timeline" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry x="60" y="430" width="100" height="100" relative="1" as="geometry">
            <mxPoint x="60" y="430" as="sourcePoint" />
            <mxPoint x="1140" y="430" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="timeline_label" value="時刻 →" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=left;" vertex="1" parent="1">
          <mxGeometry x="1100" y="435" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- Failure point marker -->
        <mxCell id="failure_point" value="障害発生" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#b85450;fillColor=none;strokeColor=none;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="390" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="failure_arrow" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#b85450;strokeWidth=2;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="410" as="sourcePoint" />
            <mxPoint x="410" y="432" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- RPO bracket (15min before failure) -->
        <mxCell id="rpo_bar" value="" style="endArrow=classic;startArrow=classic;startFill=1;endFill=1;html=1;strokeColor=#9673a6;strokeWidth=2;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="270" y="465" as="sourcePoint" />
            <mxPoint x="410" y="465" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rpo_label" value="RPO = 15 min&#xa;（データ復旧点）" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="475" width="120" height="35" as="geometry" />
        </mxCell>

        <!-- RTO bracket (failure to recovery) -->
        <mxCell id="rto_bar" value="" style="endArrow=classic;startArrow=classic;startFill=1;endFill=1;html=1;strokeColor=#b85450;strokeWidth=2;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="510" as="sourcePoint" />
            <mxPoint x="840" y="510" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="rto_label" value="RTO = 1 h（業務再開）" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#b85450;fillColor=none;strokeColor=none;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="515" width="180" height="20" as="geometry" />
        </mxCell>

        <!-- Timeline tick marks -->
        <mxCell id="tick_rpo" value="" style="endArrow=none;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="270" y="422" as="sourcePoint" />
            <mxPoint x="270" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tick_failure" value="" style="endArrow=none;html=1;strokeColor=#b85450;strokeWidth=2;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="415" as="sourcePoint" />
            <mxPoint x="410" y="445" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tick_recovery" value="" style="endArrow=none;html=1;strokeColor=#333333;strokeWidth=2;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="415" as="sourcePoint" />
            <mxPoint x="840" y="445" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tick_recovery_label" value="業務再開" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="800" y="448" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- Normal zone description -->
        <mxCell id="normal_desc" value="通常業務稼働中&#xa;データ継続記録" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="260" height="100" as="geometry" />
        </mxCell>

        <!-- Failure zone description -->
        <mxCell id="failure_desc" value="サービス停止&#xa;復旧作業・リストア実施" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="440" y="200" width="320" height="100" as="geometry" />
        </mxCell>

        <!-- Restored zone description -->
        <mxCell id="restored_desc" value="業務再開&#xa;通常サービス復帰" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="860" y="200" width="260" height="100" as="geometry" />
        </mxCell>

        <!-- Uptime target -->
        <mxCell id="uptime_label" value="稼働率目標: 99.5%（営業時間ベース）" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=#f5f5f5;strokeColor=#666666;align=center;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="600" width="400" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

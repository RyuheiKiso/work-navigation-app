<mxfile>
  <diagram name="IPA共通フレームでの位置" id="page-1">
    <mxGraphModel pageWidth="1200" pageHeight="600" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="600" as="geometry" />
        </mxCell>
        <mxCell id="title" value="IPA 共通フレームでの位置づけ" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="32" as="geometry" />
        </mxCell>
        <!-- 企画プロセス -->
        <mxCell id="plan" value="企画プロセス&#xa;（構想・計画）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="250" height="80" as="geometry" />
        </mxCell>
        <!-- 要件定義プロセス（強調） -->
        <mxCell id="req" value="&lt;b&gt;要件定義プロセス&lt;/b&gt;&#xa;（本書）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="480" y="220" width="240" height="160" as="geometry" />
        </mxCell>
        <!-- システム設計プロセス -->
        <mxCell id="design" value="システム設計プロセス&#xa;（概要設計〜）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="870" y="260" width="250" height="80" as="geometry" />
        </mxCell>
        <!-- 左→中 矢印 -->
        <mxCell id="e1" value="入力（継承）" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=12;fontColor=#333333;" edge="1" source="plan" target="req" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="300" />
              <mxPoint x="480" y="300" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 中→右 矢印 -->
        <mxCell id="e2" value="出力（引き渡し）" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=12;fontColor=#333333;" edge="1" source="req" target="design" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="720" y="300" />
              <mxPoint x="870" y="300" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 下部テキスト -->
        <mxCell id="note" value="本書が担う問い: Why（確定済）/ What の確定 / How の大枠" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="440" width="600" height="30" as="geometry" />
        </mxCell>
        <!-- 上部フェーズラベル -->
        <mxCell id="lbl1" value="上流" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl2" value="★ 本書スコープ" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="390" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl3" value="下流" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="870" y="360" width="250" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

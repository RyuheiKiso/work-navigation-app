        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="700" as="geometry" />
        </mxCell>
        <mxCell id="title" value="MoSCoW 優先度マトリクス" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="32" as="geometry" />
        </mxCell>
        <!-- Must (左上, app色) -->
        <mxCell id="must" value="&lt;b&gt;Must Have&lt;/b&gt;&#xa;ver1.0.0 でリリースしなければならない要件&#xa;&#xa;• SOP 実行ナビ機能&#xa;• 作業ログ記録（ALCOA+）&#xa;• アンドン発報機能" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="480" height="260" as="geometry" />
        </mxCell>
        <!-- Should (右上, net色) -->
        <mxCell id="should" value="&lt;b&gt;Should Have&lt;/b&gt;&#xa;重要だが代替手段がある要件&#xa;&#xa;• Kaizen 起票フロー&#xa;• 夜勤引継ぎ電子記録&#xa;• 教育コンテンツ管理" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="640" y="80" width="480" height="260" as="geometry" />
        </mxCell>
        <!-- Could (左下, infra色) -->
        <mxCell id="could" value="&lt;b&gt;Could Have&lt;/b&gt;&#xa;あると良い要件&#xa;&#xa;• ダッシュボード可視化&#xa;• AI 異常検知アシスト&#xa;• 多言語対応（英語）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="480" height="260" as="geometry" />
        </mxCell>
        <!-- Won't (右下, 危険色) -->
        <mxCell id="wont" value="&lt;b&gt;Won&apos;t Have（今回）&lt;/b&gt;&#xa;今回スコープ外と明示的に除外する要件&#xa;&#xa;• ERP 完全統合（SAP連携）&#xa;• 予知保全 AI エンジン&#xa;• 外部取引先ポータル" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="640" y="380" width="480" height="260" as="geometry" />
        </mxCell>
        <!-- 軸ラベル -->
        <mxCell id="ax_h" value="← 今回含む　　　　　　　　　　今回外 →" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="660" width="750" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ax_v" value="高 ↑ 優先度 ↓ 低" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="20" y="300" width="140" height="20" as="geometry" />

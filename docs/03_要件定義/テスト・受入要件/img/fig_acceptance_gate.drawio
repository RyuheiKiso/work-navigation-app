        <!-- Any Fail → NO-GO from each gate (representative) -->
        <mxCell id="e-g1-ng" value="Fail" style="endArrow=classic;endFill=1;html=1;strokeColor=#b85450;edgeStyle=none;fontFamily=Helvetica;fontSize=10;fontColor=#333333;" edge="1" source="g1" target="nogo" parent="1">

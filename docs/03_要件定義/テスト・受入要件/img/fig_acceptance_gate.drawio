        <mxCell id="g4" value="TST-004&lt;br&gt;セキュリティ？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="330" width="120" height="70" as="geometry" />

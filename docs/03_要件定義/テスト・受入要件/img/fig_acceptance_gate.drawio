        <mxCell id="g5" value="TST-005&lt;br&gt;ALCOA+？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="420" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g6" value="TST-006&lt;br&gt;移行テスト？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="510" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g7" value="TST-007&lt;br&gt;Outbox動作？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="600" width="120" height="70" as="geometry" />

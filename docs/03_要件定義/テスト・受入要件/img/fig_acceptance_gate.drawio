        <!-- All pass → GO (data色) -->
        <mxCell id="go" value="GO&lt;br&gt;（リリース可）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="960" y="300" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Any fail → NO-GO (危険色) -->
        <mxCell id="nogo" value="NO-GO&lt;br&gt;（修正・再テスト）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">

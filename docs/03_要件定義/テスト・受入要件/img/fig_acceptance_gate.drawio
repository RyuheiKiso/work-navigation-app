        <!-- All Pass → GO -->
        <mxCell id="e-g7-go" value="All Pass" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="g7" target="go" parent="1">
          <mxGeometry relative="1" as="geometry">

          <mxGeometry x="40" y="300" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- 7 gates (diamonds) stacked vertically - using horizontal layout -->
        <mxCell id="g1" value="TST-001&lt;br&gt;FR実装完了？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="60" width="120" height="70" as="geometry" />

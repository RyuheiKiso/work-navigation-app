        <mxCell id="lb6" value="受入判定" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="1295" y="290" width="80" height="20" as="geometry" />

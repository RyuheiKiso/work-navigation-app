        <!-- gate-sys → ph4 (合格) -->
        <mxCell id="e-gs-4" value="合格" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="gate-sys" target="ph4" parent="1">

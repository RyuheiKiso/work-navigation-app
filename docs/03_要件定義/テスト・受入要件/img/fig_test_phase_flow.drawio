          <mxGeometry x="440" y="200" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Gate after システムテスト -->
        <mxCell id="gate-sys" value="合否？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="640" y="210" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- Phase 4: 性能テスト (data色 #e1d5e7 / #9673a6) -->
        <mxCell id="ph4" value="性能テスト" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="790" y="200" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Phase 5: セキュリティテスト (data色 #e1d5e7 / #9673a6) -->
        <mxCell id="ph5" value="セキュリティテスト" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="960" y="200" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Gate after セキュリティテスト -->
        <mxCell id="gate-sec" value="合否？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="1150" y="210" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- Phase 6: 受入テスト (危険色 #f8cecc / #b85450) -->
        <mxCell id="ph6" value="受入テスト" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="1300" y="200" width="70" height="80" as="geometry" />

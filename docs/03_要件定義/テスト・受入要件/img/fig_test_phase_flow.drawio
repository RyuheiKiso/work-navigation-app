          <mxGeometry x="500" y="16" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- Phase 1: 単体テスト (infra色 #f5f5f5 / #666666) -->
        <mxCell id="ph1" value="単体テスト" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Phase 2: 結合テスト (net色 #dae8fc / #6c8ebf) -->
        <mxCell id="ph2" value="結合テスト" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Phase 3: システムテスト (app色 #fff2cc / #d79b00) -->

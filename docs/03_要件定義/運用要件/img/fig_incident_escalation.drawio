<mxfile>
  <diagram name="障害エスカレーションフロー" id="page-1">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="障害エスカレーションフロー" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="16" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- 障害検知 (危険色) -->
        <mxCell id="detect" value="障害検知&lt;br&gt;（IT担当 / システム監視）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="460" y="60" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- P分類 (菱形) -->
        <mxCell id="pclass" value="優先度分類&lt;br&gt;P1 / P2 / P3 / P4" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="480" y="170" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- P1 box (危険色) -->
        <mxCell id="p1-esc" value="即時エスカレーション&lt;br&gt;（&lt; 15分）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p1-act" value="緊急対応&lt;br&gt;（RTO 1h）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="60" y="440" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- P2 box (app色) -->
        <mxCell id="p2-esc" value="30分以内&lt;br&gt;エスカレーション" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="290" y="320" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2-act" value="対応（2h以内）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="290" y="440" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- P3 box (net色) -->
        <mxCell id="p3-act" value="翌営業日対応" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="720" y="320" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- P4 box (infra色) -->
        <mxCell id="p4-act" value="週次レポートに記録" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="950" y="320" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Postmortem (data色) -->
        <mxCell id="postmortem" value="事後分析（ポストモーテム）&lt;br&gt;P1 / P2 のみ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="185" y="590" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- Edges: detect → pclass -->
        <mxCell id="e-det-pc" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="detect" target="pclass" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- pclass → P1 -->
        <mxCell id="e-pc-p1" value="P1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="pclass" target="p1-esc" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="480" y="210" />
              <mxPoint x="150" y="210" />
              <mxPoint x="150" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- pclass → P2 -->
        <mxCell id="e-pc-p2" value="P2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="pclass" target="p2-esc" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="530" y="250" />
              <mxPoint x="380" y="250" />
              <mxPoint x="380" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- pclass → P3 -->
        <mxCell id="e-pc-p3" value="P3" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="pclass" target="p3-act" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="250" />
              <mxPoint x="810" y="250" />
              <mxPoint x="810" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- pclass → P4 -->
        <mxCell id="e-pc-p4" value="P4" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="pclass" target="p4-act" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="720" y="210" />
              <mxPoint x="1040" y="210" />
              <mxPoint x="1040" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- P1 esc → P1 act -->
        <mxCell id="e-p1-e-a" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="p1-esc" target="p1-act" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- P2 esc → P2 act -->
        <mxCell id="e-p2-e-a" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="p2-esc" target="p2-act" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- P1 act → postmortem -->
        <mxCell id="e-p1-pm" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="p1-act" target="postmortem" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="150" y="540" />
              <mxPoint x="150" y="620" />
              <mxPoint x="185" y="620" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- P2 act → postmortem -->
        <mxCell id="e-p2-pm" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="p2-act" target="postmortem" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="540" />
              <mxPoint x="380" y="620" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- P1/P2 label -->
        <mxCell id="pm-label" value="P1/P2のみ" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="420" y="560" width="80" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

        </mxCell>

        <!-- Gate condition 1 -->
        <mxCell id="gate_cond1" value="通過条件:&#xa;コア機能動作&#xa;lint/test 全 ok" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="260" y="295" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- Gate condition 2 -->
        <mxCell id="gate_cond2" value="通過条件:&#xa;採用率 &gt; 80%&#xa;記録完全性 &gt; 95%" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="560" y="295" width="170" height="60" as="geometry" />

        </mxCell>

        <!-- Title -->
        <mxCell id="title" value="開発ステージゲート: PoC → パイロット → 本番 → 横展開" style="text;html=1;fontFamily=Helvetica;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="14" width="900" height="36" as="geometry" />
        </mxCell>

        <!-- Phase 1: PoC -->
        <mxCell id="phase1" value="PoC&#xa;（2〜4 週間）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- Gate arrow 1 -->
        <mxCell id="gate_arrow1" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;strokeWidth=3;edgeStyle=none;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="175" as="sourcePoint" />
            <mxPoint x="370" y="175" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Phase 2: パイロット -->
        <mxCell id="phase2" value="パイロット（M6）&#xa;30 日間" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="370" y="120" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- Gate arrow 2 -->
        <mxCell id="gate_arrow2" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;strokeWidth=3;edgeStyle=none;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="175" as="sourcePoint" />
            <mxPoint x="670" y="175" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Phase 3: 本番 -->
        <mxCell id="phase3" value="本番&#xa;ver1.0.0" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#d5e8d4;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="670" y="120" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- Gate arrow 3 -->
        <mxCell id="gate_arrow3" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;strokeWidth=3;edgeStyle=none;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="900" y="175" as="sourcePoint" />
            <mxPoint x="970" y="175" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Phase 4: 横展開 -->
        <mxCell id="phase4" value="横展開&#xa;ver1.x（将来）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="970" y="120" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- Purpose text: PoC -->
        <mxCell id="purpose1" value="技術的実現可能性の確認&#xa;（コア機能動作）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="70" y="240" width="230" height="50" as="geometry" />
        </mxCell>

        <!-- Purpose text: パイロット -->
        <mxCell id="purpose2" value="現場での実用性確認&#xa;（採用率 &gt; 80%）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="370" y="240" width="230" height="50" as="geometry" />
        </mxCell>

        <!-- Purpose text: 本番 -->

          <mxGeometry x="860" y="295" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- Child device mode note (bottom) -->
        <mxCell id="child_mode" value="子機モードの展開: 単独動作モードで安定稼働（90 日）を確認後、子機モードを順次有効化する。フェーズ 3 リリース判定要件に子機モードの READ-ONLY 同期検証を含む。" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="70" y="400" width="1160" height="50" as="geometry" />
        </mxCell>

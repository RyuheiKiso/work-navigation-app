        <!-- Legend / decision policy (right bottom) -->
        <mxCell id="legend_policy" value="SLO 目標値の決定方針:&#xa;1. 導入先工場の現状計測（ベースライン）&#xa;2. ベースラインの 120〜150% を達成目標に設定&#xa;3. 30 日パイロット後に妥当性を検証&#xa;4. ADR に記録して確定" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">

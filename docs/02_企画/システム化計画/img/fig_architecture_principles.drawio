<mxfile>
  <diagram name="アーキテクチャ原則" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="820" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1300" height="820" as="geometry" />
        </mxCell>
        <mxCell id="title" value="アーキテクチャ原則：Offline-First × Append-only × Idempotent × OT-IT 境界" style="text;html=1;fontFamily=Helvetica;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="150" y="16" width="1000" height="36" as="geometry" />
        </mxCell>

        <!-- OT area (left background) -->
        <mxCell id="ot_area" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="64" width="220" height="640" as="geometry" />
        </mxCell>
        <mxCell id="ot_lbl" value="OT 領域&#xa;（制御ネットワーク）&#xa;本アプリ対象外" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="36" y="76" width="188" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ot_plc" value="PLC / SCADA" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#b85450;strokeColor=#b85450;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ot_sensor" value="設備センサ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#b85450;strokeColor=#b85450;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="50" y="280" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- OT-IT boundary line -->
        <mxCell id="boundary" value="" style="endArrow=none;html=1;strokeColor=#b85450;strokeWidth=3;dashed=1;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="248" y="64" as="sourcePoint" />
            <mxPoint x="248" y="704" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="boundary_lbl" value="OT-IT 境界&#xa;（片方向流入のみ）" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="218" y="70" width="60" height="40" as="geometry" />
        </mxCell>

        <!-- IT area label -->
        <mxCell id="it_lbl" value="IT 領域（本アプリのスコープ）" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="270" y="70" width="300" height="24" as="geometry" />
        </mxCell>

        <!-- Tablet layer -->
        <mxCell id="tablet_box" value="タブレット APP&#xa;（React Native）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#DAE8FC;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="270" y="120" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- SQLite offline store -->
        <mxCell id="sqlite" value="SQLite&#xa;（ローカル永続化）" style="shape=cylinder3;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#DAE8FC;" vertex="1" parent="1">
          <mxGeometry x="290" y="240" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Outbox queue -->
        <mxCell id="outbox" value="Outbox Queue&#xa;（UUID Idempotency Key）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="270" y="360" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Offline mode indicator -->
        <mxCell id="offline_ind" value="【Offline-First 原則】&#xa;サーバー不到達でも全操作継続可" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="270" y="466" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- LAN network -->
        <mxCell id="lan" value="社内 LAN" style="shape=mxgraph.cisco.sites.generic_building;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="550" y="340" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lan_lbl" value="社内 LAN&#xa;（TLS 1.3）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="532" y="406" width="96" height="32" as="geometry" />
        </mxCell>

        <!-- Backend server -->
        <mxCell id="backend" value="バックエンド&#xa;（Rust + axum）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="700" y="120" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- PostgreSQL DB -->
        <mxCell id="db" value="PostgreSQL&#xa;（Append-only ログ）" style="shape=cylinder3;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="730" y="240" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- Hash chain -->
        <mxCell id="hash_chain" value="SHA-256 ハッシュチェーン&#xa;（改竄検知）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="700" y="360" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- Timestamps -->
        <mxCell id="ts_box" value="タイムスタンプ二重記録&#xa;・端末時刻（申告）&#xa;・サーバー受信時刻（証拠）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="700" y="466" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Backup -->
        <mxCell id="backup" value="NAS バックアップ&#xa;（WAL + PITR）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="980" y="240" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Management Web -->
        <mxCell id="web" value="管理 Web&#xa;（React）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="980" y="120" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Arrows (carefully routed to avoid overlaps) -->

        <!-- Tablet APP → SQLite (vertical down) -->
        <mxCell id="e_tab_sql" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="380" y="200" as="sourcePoint" />
            <mxPoint x="380" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- SQLite → Outbox (vertical down) -->
        <mxCell id="e_sql_out" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="380" y="310" as="sourcePoint" />
            <mxPoint x="380" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Outbox → LAN (right, then to backend) -->
        <mxCell id="e_out_lan" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#D79B00;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="490" y="390" as="sourcePoint" />
            <mxPoint x="550" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- LAN → Backend -->
        <mxCell id="e_lan_back" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="610" y="370" as="sourcePoint" />
            <mxPoint x="700" y="160" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Backend → DB (vertical down) -->
        <mxCell id="e_back_db" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="810" y="200" as="sourcePoint" />
            <mxPoint x="810" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- DB → Backup (right) -->
        <mxCell id="e_db_bak" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="890" y="275" as="sourcePoint" />
            <mxPoint x="980" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Backend → Web (right, horizontal) -->
        <mxCell id="e_back_web" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="920" y="160" as="sourcePoint" />
            <mxPoint x="980" y="160" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Principle callout boxes at bottom -->
        <mxCell id="p1" value="① Offline-First&#xa;LAN 断でも全操作継続" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#DAE8FC;" vertex="1" parent="1">
          <mxGeometry x="270" y="560" width="220" height="48" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="② Append-only&#xa;UPDATE/DELETE 禁止権限" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="510" y="560" width="220" height="48" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="③ Idempotent API&#xa;UUID v4 で重複排除" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="750" y="560" width="220" height="48" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="④ 改竄不可性&#xa;SHA-256 ハッシュチェーン" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#E1D5E7;" vertex="1" parent="1">
          <mxGeometry x="990" y="560" width="220" height="48" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

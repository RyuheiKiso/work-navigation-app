<mxfile>
  <diagram name="ALCOA+マッピング" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="940" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1300" height="940" as="geometry" />
        </mxCell>
        <mxCell id="title" value="ALCOA+ 9 原則 × 3 実装層（データモデル / UI / 運用）展開マトリクス" style="text;html=1;fontFamily=Helvetica;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="150" y="12" width="1000" height="36" as="geometry" />
        </mxCell>

        <!-- Header row -->
        <mxCell id="h0" value="ALCOA+ 原則" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="58" width="190" height="44" as="geometry" />
        </mxCell>
        <mxCell id="h1" value="データモデル層" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#DAE8FC;" vertex="1" parent="1">
          <mxGeometry x="210" y="58" width="350" height="44" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="UI 層" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="560" y="58" width="350" height="44" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="運用層" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="910" y="58" width="360" height="44" as="geometry" />
        </mxCell>

        <!-- Row height = 80px each, starting y=102 -->
        <!-- R1: Attributable -->
        <mxCell id="r1_p" value="Attributable&#xa;（帰属可能）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="102" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r1_d" value="worker_id + terminal_id を全イベントの必須フィールドに。事後入力は is_retroactive:true + 承認者署名必須" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="102" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r1_u" value="バーコード / PIN / NFC による作業者識別。匿名操作を許容しない" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="102" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r1_o" value="RBAC で役割ごとのアクセス権限を設定。共有アカウント禁止ポリシー" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="102" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- R2: Legible -->
        <mxCell id="r2_p" value="Legible&#xa;（読取可能）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="176" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r2_d" value="JSONB 多言語テキスト、UTF-8 保存必須。バイナリは UUID パスで参照" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="176" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r2_u" value="最小フォント 14pt、コントラスト比 4.5:1 以上。印刷時も可読なレイアウト" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="176" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r2_o" value="長期保存は文字化けしない UTF-8。PDF 出力は ISO 32000 準拠" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="176" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- R3: Contemporaneous -->
        <mxCell id="r3_p" value="Contemporaneous&#xa;（同時記録）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="250" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r3_d" value="timestamp_device（端末時刻）と timestamp_server（受信時刻）の二重保存。is_offline フラグで未同期を区別" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="250" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r3_u" value="ロックステップで「後でまとめて入力」を許容しない。「記録済（未同期）」バッジ表示" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="250" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r3_o" value="未同期レコードを監査者向けに sync_lag_ms で開示。監査記録での遅延明示" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="250" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- R4: Original -->
        <mxCell id="r4_p" value="Original&#xa;（元データ）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="324" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r4_d" value="Append-only: UPDATE/DELETE 禁止。修正は「訂正イベント」を追記。写真は SHA-256 ハッシュで改竄検知" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="324" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r4_u" value="完了済みステップの「編集」ボタンは存在しない。修正は「訂正申請」フローのみ" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="324" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r4_o" value="正本は DB のイベントレコード。印刷・PDF は「参照用複製」として位置づけ" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="324" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- R5: Accurate -->
        <mxCell id="r5_p" value="Accurate&#xa;（正確）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="398" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r5_d" value="数値は NUMERIC(18,6)。USL/LSL を SOP に保持し即時判定。単位は UCUM コードで型安全" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="398" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r5_u" value="ML Kit による自動スキャン値取得。手入力には単位・桁数バリデーション。False Precision 防止" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="398" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r5_o" value="JCSS 校正証明書の有効期限チェック（プレフライト）。計測前に期限切れをブロック" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="398" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- R6: Complete -->
        <mxCell id="r6_p" value="Complete&#xa;（完全）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="472" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r6_d" value="Step 完了をすべてイベントとして記録。スキップ・中断・差し戻しも別イベントで記録（除外なし）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="472" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r6_u" value="全 Step 完了まで「作業完了」ボタンを無効化。スキップには理由入力を強制" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="472" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r6_o" value="SOP の step_count と記録イベント数の一致チェックを自動実行。不一致は管理者通知" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="472" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- R7: Consistent -->
        <mxCell id="r7_p" value="Consistent&#xa;（一貫）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="546" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r7_d" value="sop_version_id を作業ログに時点参照。マスタ変更が実績データを遡及しない" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="546" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r7_u" value="同一工程を複数端末で実行する場合、同一 SOP 版を参照することをサーバー側で保証" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="546" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r7_o" value="版切替前の進行中作業はそのまま旧版で完了。新版は次作業指示から適用" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="546" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- R8: Enduring -->
        <mxCell id="r8_p" value="Enduring&#xa;（耐久）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="620" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r8_d" value="PostgreSQL + WAL アーカイブ + NAS バックアップ（三層）。保管期間を業種設定から参照" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="620" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r8_u" value="長期保存データには「保存期間 ○年」をメタデータに付与して可視化" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="620" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r8_o" value="定期バックアップの完了確認・リストアテストの年次実施を運用規程に明記" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="620" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- R9: Available -->
        <mxCell id="r9_p" value="Available&#xa;（利用可能）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="694" width="190" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r9_d" value="管理 Web から順方向・逆方向クエリを提供。CSV / XES / PDF エクスポート機能" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EAF4FB;" vertex="1" parent="1">
          <mxGeometry x="210" y="694" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r9_u" value="検索・フィルタは全項目対応。ロード時間は Glanceable 1 秒以内を目標とする" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#EDF7ED;" vertex="1" parent="1">
          <mxGeometry x="560" y="694" width="350" height="74" as="geometry" />
        </mxCell>
        <mxCell id="r9_o" value="Active-Standby 二重化（07 章）で RTO 1 時間・RPO 15 分を目標とする" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#333333;fillColor=#FFF4E5;" vertex="1" parent="1">
          <mxGeometry x="910" y="694" width="360" height="74" as="geometry" />
        </mxCell>

        <!-- Footer note -->
        <mxCell id="foot" value="本マトリクスは 06 章「データモデル中核設計」の権威章。他章は本図を参照。規制根拠: ISO 9001:2015 §7.5 / ALCOA+ (FDA, ICH, GMP) / 22_規制別トレーサビリティ要件詳論" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="790" width="1250" height="32" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile>
  <diagram name="連携モード比較" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1300" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="連携モード 3 形態の比較" style="text;html=1;fontFamily=Helvetica;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="16" width="900" height="36" as="geometry" />
        </mxCell>

        <!-- 列1: 単独動作モード (infra #f5f5f5) -->
        <mxCell id="col1_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="370" height="660" as="geometry" />
        </mxCell>
        <mxCell id="col1_hdr" value="単独動作モード" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="72" width="370" height="36" as="geometry" />
        </mxCell>
        <mxCell id="col1_app" value="本アプリ（子機）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;strokeWidth=2;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="col1_note" value="基幹システム（親機）なし&#xa;— 接続不要" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="310" height="50" as="geometry" />
        </mxCell>
        <mxCell id="col1_feat" value="✔ 全機能動作（SOP ナビ / ALCOA+ 記録 / Just Culture）&#xa;✔ Offline-First / Local-First 設計&#xa;✔ ERP/MES 非保有の小規模工場に最適&#xa;✔ 子機モードへの移行は設定変更のみ" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="45" y="550" width="340" height="80" as="geometry" />
        </mxCell>

        <!-- 列2: 子機モード READ-ONLY (net #dae8fc) -->
        <mxCell id="col2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="440" y="60" width="370" height="660" as="geometry" />
        </mxCell>
        <mxCell id="col2_hdr" value="子機モード（READ-ONLY 同期）" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="440" y="72" width="370" height="36" as="geometry" />
        </mxCell>
        <mxCell id="col2_app" value="本アプリ（子機）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;strokeWidth=2;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="490" y="150" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="col2_master" value="親機（ERP/MES/生産管理）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;strokeWidth=2;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="490" y="440" width="270" height="70" as="geometry" />
        </mxCell>
        <!-- 列2: マスタ同期矢印（親機→子機, y=440→220） -->
        <mxCell id="col2_sync_lbl" value="マスタ同期（READ-ONLY）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="640" y="290" width="160" height="24" as="geometry" />
        </mxCell>
        <mxCell id="col2_sync" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;edgeStyle=none;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="625" y="440" as="sourcePoint" />
            <mxPoint x="625" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="col2_feat" value="✔ 親機マスタを自動受信（手入力削減）&#xa;✔ 外部一意キー（型式/機番/品目コード）連携&#xa;✔ マスタ同期失敗時は縮退稼働（offline）&#xa;対象: 基幹システム保有・実績連携は不要の工場" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="455" y="548" width="340" height="80" as="geometry" />
        </mxCell>

        <!-- 列3: 子機モード 双方向 (app #fff2cc) -->
        <mxCell id="col3_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="850" y="60" width="370" height="660" as="geometry" />
        </mxCell>
        <mxCell id="col3_hdr" value="子機モード（双方向同期）" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="850" y="72" width="370" height="36" as="geometry" />
        </mxCell>
        <mxCell id="col3_app" value="本アプリ（子機）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;strokeWidth=2;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="900" y="150" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="col3_master" value="親機（ERP/MES/生産管理）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;strokeWidth=2;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="900" y="440" width="270" height="70" as="geometry" />
        </mxCell>
        <!-- 列3: マスタ同期矢印（親機→子機）x=1010 -->
        <mxCell id="col3_sync" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;edgeStyle=none;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1010" y="440" as="sourcePoint" />
            <mxPoint x="1010" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- 列3: 実績送信矢印（子機→親機, 破線）x=1060 -->
        <mxCell id="col3_result" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#d79b00;strokeWidth=2;dashed=1;edgeStyle=none;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1060" y="220" as="sourcePoint" />
            <mxPoint x="1060" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- 列3: ラベル（矢印の右側に配置） -->
        <mxCell id="col3_lbl_sync" value="マスタ同期（READ-ONLY）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1072" y="280" width="140" height="28" as="geometry" />
        </mxCell>
        <mxCell id="col3_lbl_result" value="実績送信（Outbox）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1072" y="370" width="140" height="28" as="geometry" />
        </mxCell>
        <mxCell id="col3_feat" value="✔ マスタ受信 + 実績自動連携&#xa;✔ トレサビの横断活用（ロット追跡）&#xa;✔ 親機 API 仕様が整っている場合に提供&#xa;対象: 基幹システム保有・実績連携が必要な工場" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;verticalAlign=top;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="865" y="548" width="340" height="80" as="geometry" />
        </mxCell>

        <!-- 凡例 -->
        <mxCell id="legend_sync" edge="1" parent="1"

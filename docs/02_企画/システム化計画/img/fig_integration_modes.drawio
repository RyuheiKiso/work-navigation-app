        <mxCell id="legend_result_lbl" value="実績送信（破線）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="850" y="750" width="160" height="24" as="geometry" />

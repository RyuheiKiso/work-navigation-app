<mxfile>
  <diagram name="データモデル中核" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1300" height="900" as="geometry" />
        </mxCell>
        <mxCell id="title" value="データモデル中核：3 階層手順 × 4M+1E × 横串参照" style="text;html=1;fontFamily=Helvetica;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="14" width="700" height="36" as="geometry" />
        </mxCell>

        <!-- === Section A: 3-tier SOP hierarchy (top-left) === -->
        <mxCell id="sec_a" value="A. 3 階層手順モデル（SOP マスタ）" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="380" height="24" as="geometry" />
        </mxCell>
        <mxCell id="L1" value="L1 工程 (Process)&#xa;例: 溶接工程・検査工程" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#DAE8FC;" vertex="1" parent="1">
          <mxGeometry x="40" y="92" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="L2" value="L2 作業 (Operation)&#xa;例: 溶接準備・本溶接・後処理" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#DAE8FC;" vertex="1" parent="1">
          <mxGeometry x="80" y="196" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="L3" value="L3 Step&#xa;例: 治具セット → トルク確認 → サイン" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#DAE8FC;" vertex="1" parent="1">
          <mxGeometry x="120" y="300" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- Hierarchy arrows (vertical, no overlap) -->
        <mxCell id="h_L1L2" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="152" as="sourcePoint" />
            <mxPoint x="220" y="196" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="h_L2L3" edge="1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="220" y="256" as="sourcePoint" />
            <mxPoint x="260" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step attributes (small text) -->
        <mxCell id="step_attr" value="Step 属性: input_type / judgment_condition /&#xa;evidence_required / fmea_rpn_flag /&#xa;skill_level_required / expected_unit" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="380" height="56" as="geometry" />
        </mxCell>

        <!-- === Section B: 4M+1E reference axes (top-right) === -->
        <mxCell id="sec_b" value="B. 4M+1E 参照軸（トレサビ軸）" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="460" y="60" width="380" height="24" as="geometry" />
        </mxCell>
        <mxCell id="m1_m" value="Man（人）&#xa;worker_id / approver_id" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="460" y="92" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m2_m" value="Machine（設備）&#xa;equipment_id" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="700" y="92" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m3_m" value="Material（材料）&#xa;lot_id / sub_lot_ids" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="460" y="158" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m4_m" value="Method（方法）&#xa;sop_version_id / work_order_id" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="700" y="158" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m5_m" value="Measurement（計測）&#xa;instrument_id / calibration_ref" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="460" y="224" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m6_m" value="Environment（環境）&#xa;env_snapshot（JSONB）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="700" y="224" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- 4M note -->
        <mxCell id="m4note" value="※ Man 軸への責任過収束を防ぐ設計：&#xa;不適合原因で「人」を直接選択させる UI は設けない" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="460" y="286" width="460" height="36" as="geometry" />
        </mxCell>

        <!-- === Section C: Cross-reference model === -->
        <mxCell id="sec_c" value="C. 横串参照モデル（時点参照・不変）" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="448" width="400" height="24" as="geometry" />
        </mxCell>

        <!-- Cross-reference boxes (2 columns) -->
        <mxCell id="cr1" value="SOP 版&#xa;sop_version_id（時点固定）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cr2" value="ロット（材料）&#xa;lot_id / sub_lot_ids" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="290" y="480" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cr3" value="校正情報&#xa;instrument_id + calibration_ref" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="40" y="546" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cr4" value="スキルスナップショット&#xa;skill_level（記録時点）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="290" y="546" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cr5" value="シフト情報&#xa;shift_type / consecutive_nights" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="40" y="612" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cr6" value="4M 変更&#xa;change_id（承認レコード参照）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="290" y="612" width="230" height="50" as="geometry" />
        </mxCell>

        <!-- === Section D: Event store (right side) === -->
        <mxCell id="sec_d" value="D. イベントストア（Append-only・XES 互換）" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="580" y="448" width="480" height="24" as="geometry" />
        </mxCell>

        <!-- Event store box -->
        <mxCell id="evt_box" value="イベントレコード&#xa;case_id / activity / timestamp_device / timestamp_server&#xa;worker_id / terminal_id / sop_version_id / payload&#xa;is_offline / sync_lag_ms" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#E1D5E7;" vertex="1" parent="1">
          <mxGeometry x="580" y="480" width="420" height="90" as="geometry" />
        </mxCell>

        <!-- Event types -->
        <mxCell id="evt_types" value="イベント種別: step_started / step_completed /&#xa;step_skipped / step_rejected / work_interrupted /&#xa;work_resumed / andon_triggered / nonconformance_filed /&#xa;kaizen_filed" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="580" y="580" width="420" height="64" as="geometry" />
        </mxCell>

        <!-- Immutability note -->
        <mxCell id="immut" value="UPDATE / DELETE 禁止（DB ロール制御）&#xa;修正は「訂正イベント」として追記" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="580" y="658" width="420" height="44" as="geometry" />
        </mxCell>

        <!-- Bottom note: master vs transaction -->
        <mxCell id="mv_sep" value="マスタ（権威: サーバー）とトランザクション（権威: 最初の記録デバイス→サーバー同期後はサーバー）を厳格に分離。マスタ変更がトランザクションを遡及しない。" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="778" width="1060" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

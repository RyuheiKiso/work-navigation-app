        <mxCell id="alcoa_note" value="ALCOA+ 整合: created_by（Attributable）/ created_at（Contemporaneous）/ Append-only 更新（valid_to を設定して新レコードを追加）" style="rounded=1;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=8;" vertex="1" parent="1">

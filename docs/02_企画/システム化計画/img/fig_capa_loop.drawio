<mxfile>
  <diagram name="CAPAフィードバックループ" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="不適合 → CAPA → SOP 改訂 → 現場展開 フィードバックループ" style="text;html=1;fontFamily=Helvetica;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="18" width="800" height="36" as="geometry" />
        </mxCell>

        <!-- Input source: 不適合 / ヒヤリハット / Kaizen Teian -->
        <mxCell id="input_src" value="不適合 / ヒヤリハット&#xa;/ Kaizen Teian" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#E1D5E7;" vertex="1" parent="1">
          <mxGeometry x="320" y="68" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- 4 main CAPA stages -->
        <!-- Stage 1: 検知 -->
        <mxCell id="s1" value="① 検知&#xa;起票・受付" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#DAE8FC;" vertex="1" parent="1">
          <mxGeometry x="330" y="210" width="220" height="80" as="geometry" />
        </mxCell>
        <!-- Stage 2: 分析 -->
        <mxCell id="s2" value="② 分析&#xa;根本原因特定" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#D79B00;fillColor=#FFE6CC;" vertex="1" parent="1">
          <mxGeometry x="720" y="210" width="220" height="80" as="geometry" />
        </mxCell>
        <!-- Stage 3: 対策 -->
        <mxCell id="s3" value="③ 対策&#xa;SOP 改訂・保全・教育" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="720" y="480" width="220" height="80" as="geometry" />
        </mxCell>
        <!-- Stage 4: 確認 -->
        <mxCell id="s4" value="④ 確認&#xa;効果検証・クローズ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#E1D5E7;" vertex="1" parent="1">
          <mxGeometry x="330" y="480" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Sub-descriptions (positioned to avoid arrow paths) -->
        <mxCell id="d1" value="Why-Why / Ishikawa 4M / CAPA 昇格" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="680" y="298" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="SOP 版管理・設備マスタ・教育完了確認" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="680" y="568" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="CAPA 採用通知→提案者フィードバック" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="220" y="568" width="300" height="20" as="geometry" />
        </mxCell>

        <!-- Center label -->
        <mxCell id="center_lbl" value="継続的改善ループ&#xa;（ISO 9001 §10.2 CAPA）" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="440" y="348" width="320" height="40" as="geometry" />
        </mxCell>

        <!-- Arrow: input_src → s1 (vertical down) -->
        <mxCell id="e_in" edge="1" source="input_src" target="s1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: s1 → s2 (horizontal right at y=250) -->
        <mxCell id="e12" edge="1" source="s1" target="s2" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: s2 → s3 (vertical down at x=830) -->
        <mxCell id="e23" edge="1" source="s2" target="s3" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: s3 → s4 (horizontal left at y=520) -->
        <mxCell id="e34" edge="1" source="s3" target="s4" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: s4 → s1 (left route, avoiding crossing) -->
        <mxCell id="e41" edge="1" source="s4" target="s1" parent="1"
                 style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=elbowEdgeStyle;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="440" y="430" />
              <mxPoint x="440" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- KPI box -->
        <mxCell id="kpi" value="健全性指標: 採用率 / 平均クローズ日数 / 未読件数" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="380" y="640" width="440" height="36" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

          <mxGeometry x="30" y="100" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="sqlite" value="SQLite Outbox&#xa;（未送信イベント保持）" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontStyle=1;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="180" height="80" as="geometry"/>

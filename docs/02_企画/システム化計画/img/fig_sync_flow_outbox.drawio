        <mxCell id="postgres" value="PostgreSQL&#xa;（Append-only イベントストア）" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontStyle=1;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;" vertex="1" parent="1">
          <mxGeometry x="710" y="100" width="180" height="80" as="geometry"/>

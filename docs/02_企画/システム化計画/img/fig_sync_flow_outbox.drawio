        </mxCell>
        <mxCell id="title" value="Outbox Pattern と Idempotency による実績送信フロー" style="text;fontFamily=Helvetica;fontColor=#333333;fontStyle=1;fontSize=16;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="14" width="900" height="34" as="geometry"/>

        <mxCell id="sub_tablet" value="Idempotency-Key (UUID v4)&#xa;をヘッダに付与" style="text;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">

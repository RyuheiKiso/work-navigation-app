        </mxCell>
        <mxCell id="sub_sqlite" value="送信完了まで&#xa;イベントを保持" style="text;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">

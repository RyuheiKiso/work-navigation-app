        <mxCell id="arrow_master_save" value="" style="endArrow=classic;startArrow=none;fontFamily=Helvetica;strokeColor=#9673a6;strokeWidth=1.5;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="670" y="490" as="sourcePoint"/>

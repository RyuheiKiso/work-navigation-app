<mxfile>
  <diagram name="参照整合性ガード" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="650" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="650" as="geometry" />
        </mxCell>
        <mxCell id="title" value="参照整合性ガード — 削除前 dry-run から安全な削除実行までのフロー" style="text;html=1;fontFamily=Helvetica;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="14" width="1000" height="34" as="geometry" />
        </mxCell>

        <!-- Row labels -->
        <mxCell id="lbl_happy" value="影響件数 = 0（即時削除）" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;align=right;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="730" y="112" width="200" height="18" as="geometry" />
        </mxCell>
        <mxCell id="lbl_impact" value="影響件数 &gt; 0（参照解除フロー）" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;align=right;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="730" y="305" width="230" height="18" as="geometry" />
        </mxCell>

        <!-- Main flow boxes (top row, y=130) -->
        <mxCell id="b_req" value="削除リクエスト&#xa;（編集者の操作）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="130" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b_dryrun" value="dry-run 実行&#xa;（API シミュレーション）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="240" y="130" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b_judge" value="影響件数判定&#xa;参照レコード集計" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="470" y="120" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b_instant" value="即時削除（件数 = 0）&#xa;API ブロック解除" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="820" y="130" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Impact path boxes (bottom row, y=330) -->
        <mxCell id="b_impact" value="影響範囲ビュー表示&#xa;（SOP/作業パターン/Step/ルール の件数一覧）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="470" y="330" width="210" height="65" as="geometry" />
        </mxCell>
        <mxCell id="b_resolve" value="参照解除 / 移行&#xa;（編集者が各参照を手動解消）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="730" y="330" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="b_delete" value="削除実行&#xa;（参照件数 = 0 確認後）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="990" y="330" width="180" height="65" as="geometry" />
        </mxCell>

        <!-- Main flow arrows (no labels) -->
        <mxCell id="a1" edge="1" source="b_req" target="b_dryrun" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" edge="1" source="b_dryrun" target="b_judge" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Labeled arrows from judgment -->
        <mxCell id="a3" value="影響件数 = 0" edge="1" source="b_judge" target="b_instant" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="影響件数 &gt; 0" edge="1" source="b_judge" target="b_impact" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Impact path arrows (no labels) -->
        <mxCell id="a5" edge="1" source="b_impact" target="b_resolve" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a6" edge="1" source="b_resolve" target="b_delete" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Bottom notes -->
        <mxCell id="note_cascade" value="cascade 削除禁止: 参照件数がゼロでない状態での削除は API レベルでブロックする。クライアント側チェックのみへの依存は禁止（計画 19 章 §6-3 参照）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="20" y="440" width="560" height="70" as="geometry" />
        </mxCell>
        <mxCell id="note_alcoa" value="ALCOA+ Complete: 削除されたマスタはソフトデリート（deleted_at フィールド）で保持し、物理削除は禁止する。削除イベントは master_edit_event テーブルに Append-only 記録する（計画 19 章 §9 参照）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="600" y="440" width="580" height="70" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

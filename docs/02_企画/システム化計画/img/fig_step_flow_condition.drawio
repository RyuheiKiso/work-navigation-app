        <mxCell id="note_json" value='JSON DSL 例（step_flow_rule）:&#xa;{ "condition": { "source_step": "step_002", "operator": "lt", "value": 5.5 },&#xa;  "action": "insert", "target": "step_007_repair", "priority": 1 }' style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">

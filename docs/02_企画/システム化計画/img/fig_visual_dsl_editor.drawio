<mxfile>
  <diagram name="ビジュアル DSL エディタ" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="ビジュアル DSL エディタ — JSON Logic と条件分岐フローを GUI で編集" style="text;html=1;fontFamily=Helvetica;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="14" width="1000" height="34" as="geometry" />
        </mxCell>

        <!-- Panel headers -->
        <mxCell id="hdr_palette" value="演算子パレット" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="20" y="58" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="hdr_tree" value="条件ツリー表示（サンプル: value &gt;= 5.5 の評価式）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="260" y="58" width="580" height="35" as="geometry" />
        </mxCell>
        <mxCell id="hdr_preview" value="プレビュー実行" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="860" y="58" width="320" height="35" as="geometry" />
        </mxCell>

        <!-- Operator palette buttons -->
        <mxCell id="op_eq" value="== （等値）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="105" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="op_ne" value="!= （不等値）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="op_gte" value="&lt;b&gt;&gt;= （以上）&lt;/b&gt;  ← 選択中" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="40" y="195" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="op_lte" value="&lt;= （以下）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="op_and" value="and （論理積）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="285" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="op_or" value="or （論理和）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="op_not" value="! （否定）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="375" width="180" height="35" as="geometry" />
        </mxCell>

        <!-- Condition tree: outer operator box -->
        <mxCell id="tree_op" value="演算子: &gt;=&#xa;（ドラッグ＆ドロップで配置）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="280" y="105" width="540" height="130" as="geometry" />
        </mxCell>
        <!-- Inner nodes (visually inside outer box) -->
        <mxCell id="tree_var" value='左辺: {"var": "value"}&#xa;（変数ピッカーで選択）' style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="295" y="160" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tree_val" value="右辺: 5.5&#xa;（値入力フィールド）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="545" y="160" width="255" height="60" as="geometry" />
        </mxCell>

        <!-- Raw JSON display -->
        <mxCell id="raw_json" value='RAW JSON （ビジュアルモード ⇔ RAW JSON モード 随時切替）:&#xa;{ "&gt;=": [ {"var": "value"}, 5.5 ] }' style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="280" y="255" width="540" height="65" as="geometry" />
        </mxCell>
        <!-- Syntax error display -->
        <mxCell id="syntax_err" value="構文エラー表示例: 行 2 列 5 — 演算子が不正 → インライン赤強調" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;align=left;spacingLeft=8;spacingTop=6;verticalAlign=middle;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="280" y="335" width="540" height="40" as="geometry" />
        </mxCell>

        <!-- Preview pane -->
        <mxCell id="prev_label" value="入力値 (value) を入力:" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="875" y="108" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="prev_input" value="4.8" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="875" y="135" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="prev_btn" value="▶ 評価実行" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="875" y="185" width="280" height="35" as="geometry" />
        </mxCell>
        <mxCell id="prev_result" value="評価結果: TRUE&#xa;（value = 4.8 &gt;= 5.5 → FALSE の場合は赤）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="875" y="235" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prev_samples" value="サンプル評価:&#xa;value = 4.8 → TRUE&#xa;value = 5.5 → TRUE&#xa;value = 6.2 → FALSE" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="875" y="310" width="280" height="70" as="geometry" />
        </mxCell>

        <!-- DAG section header -->
        <mxCell id="hdr_dag" value="DAG ビジュアライザ — 条件分岐フローをノード＆エッジで可視化（循環参照は赤強調）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="20" y="405" width="1160" height="35" as="geometry" />
        </mxCell>

        <!-- DAG nodes -->
        <mxCell id="dag_s1" value="Step 001&#xa;初期点検" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dag_s2" value="Step 002&#xa;計測（value 入力）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="290" y="490" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dag_cond" value="条件評価&#xa;value &gt;= 5.5 ?" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="520" y="480" width="180" height="75" as="geometry" />
        </mxCell>
        <mxCell id="dag_true" value="Step 007 補修作業&#xa;（TRUE: insert）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="790" y="455" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dag_false" value="Step 003 本締め&#xa;（FALSE: 通常進行）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="790" y="540" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dag_circ_note" value="循環参照検出時:&#xa;エッジを赤で強調&#xa;登録をブロック" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="1020" y="490" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- DAG arrows (no labels to avoid gap constraints) -->
        <mxCell id="dag_a1" edge="1" source="dag_s1" target="dag_s2" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dag_a2" edge="1" source="dag_s2" target="dag_cond" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dag_a3" edge="1" source="dag_cond" target="dag_true" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dag_a4" edge="1" source="dag_cond" target="dag_false" parent="1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />

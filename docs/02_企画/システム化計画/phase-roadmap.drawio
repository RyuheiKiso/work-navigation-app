          <mxGeometry x="510" y="64" width="380" height="590" as="geometry" />
        </mxCell>
        <mxCell id="phase3-bg" value="Phase 3: 知的支援" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#333333;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="960" y="64" width="380" height="590" as="geometry" />
        </mxCell>
        <mxCell id="p1-items" value="・ JWT 認証 / 5 ロール RBAC&lt;br&gt;・ 作業手順マスタ CRUD&lt;br&gt;・ 作業ナビ表示（タブレット）&lt;br&gt;・ QR / GS1-128 / Data Matrix スキャン&lt;br&gt;・ 実績記録（測定値 + UCUM 単位）&lt;br&gt;・ ローカル SQLite + Outbox 同期&lt;br&gt;・ オフライン自動切替 / 復帰同期&lt;br&gt;・ 監査ログ（Append-only）&lt;br&gt;・ トレサビ照会 + CSV エクスポート&lt;br&gt;・ WAL PITR + Docker volume BCP&lt;br&gt;・ i18n 基盤 + やさしい日本語 UI" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="340" height="280" as="geometry" />
        </mxCell>
        <mxCell id="p2-items" value="・ 写真記録（SHA-256 ハッシュ + EXIF）&lt;br&gt;・ 不適合起票 / 不適合リスト照会&lt;br&gt;・ CAPA 連携基盤（8D テンプレート）&lt;br&gt;・ 手順承認ワークフロー&lt;br&gt;・ スキルマトリクス管理&lt;br&gt;・ ベトナム語 / 英語 翻訳追加&lt;br&gt;・ 測定器直結（USB/Bluetooth）&lt;br&gt;・ JCSS 校正期限アラート&lt;br&gt;・ pgvector 拡張の有効化準備&lt;br&gt;・ 引継ぎ承認フロー" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="530" y="140" width="340" height="260" as="geometry" />
        </mxCell>
        <mxCell id="p3-items" value="・ RAG 手順 Q&amp;A（pgvector + Ollama）&lt;br&gt;・ 異常検知（SPC / Isolation Forest）&lt;br&gt;・ Edge ML 外観検査補助（TFLite）&lt;br&gt;・ プロセスマイニング（ボトルネック分析）&lt;br&gt;・ 中国語 / ポルトガル語 翻訳追加&lt;br&gt;・ ピクトグラム優先モード&lt;br&gt;※ EU AI Act リスク分類確認後に着手" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="980" y="140" width="340" height="220" as="geometry" />
        </mxCell>

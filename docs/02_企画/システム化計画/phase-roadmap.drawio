        <mxCell id="phase1-bg" value="Phase 1: コア" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="64" width="380" height="590" as="geometry" />

<mxfile>
  <diagram name="time_context" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="時代認識マップ — 中小製造業が直面する構造的圧力" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="800" height="32" as="geometry" />
        </mxCell>
        <!-- Pressure 1: top (above center) -->
        <mxCell id="p1" value="❶ 熟練退職・技能継承危機&lt;br&gt;2007年問題 / 高齢化の加速" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="240" height="70" as="geometry" />
        </mxCell>
        <!-- Pressure 2: left (left of center) -->
        <mxCell id="p2" value="❷ 規制強化・顧客監査厳格化&lt;br&gt;ISO 9001 / IATF 16949 / ALCOA+" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="80" y="345" width="260" height="70" as="geometry" />
        </mxCell>
        <!-- Center: manufacturing site -->
        <mxCell id="center" value="中小製造業の現場&lt;br&gt;（単一工場）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="480" y="345" width="240" height="70" as="geometry" />
        </mxCell>
        <!-- Pressure 3: bottom (below center) -->
        <mxCell id="p3" value="❸ スマートファクトリー言説&lt;br&gt;と現場実態のギャップ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="480" y="610" width="240" height="70" as="geometry" />
        </mxCell>
        <!-- System response: right -->
        <mxCell id="system" value="本プロジェクト&lt;br&gt;作業ナビ＋トレサビ記録&lt;br&gt;SaaS否定 × 中小製造業&lt;br&gt;× 高カスタマイズ要求" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="840" y="320" width="280" height="110" as="geometry" />
        </mxCell>
        <!-- Statistics note (no arrows) -->
        <mxCell id="stats" value="業界統計（参考値）&lt;br&gt;DXツール 68% 期待効果未達&lt;br&gt;MES/ERP 54% 予算超過 / 68% 期間超過&lt;br&gt;日本製造業 IT投資率 平均 1.2%（米国 2〜2.5%）" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=left;verticalAlign=top;fontColor=#666666;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="380" height="80" as="geometry" />
        </mxCell>
        <!-- Arrows: pressures → center (using explicit exit/entry ports) -->
        <!-- P1 bottom-center → Center top-center: vertical -->
        <mxCell id="e1" style="endArrow=classic;endFill=1;html=1;strokeColor=#d79b00;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="p1" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- P2 right-center → Center left-center: horizontal -->
        <mxCell id="e2" style="endArrow=classic;endFill=1;html=1;strokeColor=#d79b00;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p2" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- P3 top-center → Center bottom-center: vertical -->
        <mxCell id="e3" style="endArrow=classic;endFill=1;html=1;strokeColor=#d79b00;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="p3" target="center" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Center right-center → System left-center: horizontal -->
        <mxCell id="e4" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="center" target="system" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="900" as="geometry" />
        </mxCell>
        <mxCell id="title" value="プロダクトビジョン：三位一体構造" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="36" as="geometry" />
        </mxCell>
        <!-- Intrinsic EPSS: left -->
        <mxCell id="epss" value="&lt;b&gt;Intrinsic EPSS&lt;/b&gt;&lt;br&gt;手順提示・記録・検査・&lt;br&gt;トレサビを一体統合" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#1e4d78;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="280" height="90" as="geometry" />
        </mxCell>
        <!-- ALCOA+: top center -->
        <mxCell id="alcoa" value="&lt;b&gt;ALCOA+&lt;/b&gt;&lt;br&gt;電子証拠品質の9原則&lt;br&gt;帰属性・同時性・原本性 等" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#2e6b3e;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="460" y="80" width="280" height="90" as="geometry" />
        </mxCell>
        <!-- Just Culture: right -->
        <mxCell id="jc" value="&lt;b&gt;Just Culture&lt;/b&gt;&lt;br&gt;記録は学習のために存在する&lt;br&gt;スリップ・ラプスは問責しない" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#7b4f00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="880" y="320" width="280" height="90" as="geometry" />
        </mxCell>
        <!-- Center label (diamond shape) -->
        <mxCell id="center" value="&lt;b&gt;作業ナビゲーション&amp;amp;&lt;br&gt;トレサビシステム&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="470" y="380" width="260" height="90" as="geometry" />
        </mxCell>
        <!-- Edge: EPSS → ALCOA+ (left side of triangle, going up-right) -->
        <!-- Source top-right of EPSS (320, 365), Target bottom-left of ALCOA+ (460, 170) -->
        <!-- Line goes left of center diamond: at y=380, x≈380 which is left of center x=470 -->
        <mxCell id="e1" value="Contemporaneous原則を&lt;br&gt;構造的に充足" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=10;fontColor=#333333;labelPosition=center;verticalLabelPosition=middle;align=center;" edge="1" parent="1" source="epss" target="alcoa">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="365" as="sourcePoint" />
            <mxPoint x="460" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Edge: ALCOA+ → Just Culture (right side of triangle, going right-down) -->
        <!-- Source right of ALCOA+ (740, 125), Target top of JC (1020, 320) -->
        <!-- Passes right of center diamond (x>740) -->
        <mxCell id="e2" value="客観的証拠が&lt;br&gt;公正な判断を支援" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="alcoa" target="jc">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="740" y="125" as="sourcePoint" />
            <mxPoint x="1020" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Edge: Just Culture → EPSS (bottom of triangle, going left below center) -->
        <!-- Route below all elements via y=660 -->
        <mxCell id="e3" value="報告文化がEPSSを&lt;br&gt;学習ツールに変える" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="jc" target="epss">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1020" y="660" />
              <mxPoint x="180" y="660" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Subtitle explanation at bottom -->
        <mxCell id="note" value="三者が不可分に連環するとき、システムは証拠品質と支援品質を同時に実現する" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="760" width="800" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile>
  <diagram name="fig_regulation_matrix">
    <mxGraphModel pageWidth="1200" pageHeight="820" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bg" value="" style="fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="title" value="国内規制への立ち位置マトリクス" style="text;fontFamily=Helvetica;fontColor=#333333;fontStyle=1;fontSize=16;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="150" y="16" width="900" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="hdr_regulation" value="規制・基準" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontStyle=1;fontSize=12;fillColor=#f5f5f5;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="70" width="370" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="hdr_stance" value="立場" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontStyle=1;fontSize=12;fillColor=#f5f5f5;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="70" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="hdr_note" value="備考" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontStyle=1;fontSize=12;fillColor=#f5f5f5;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="590" y="70" width="590" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="row1_reg" value="改正電子帳簿保存法&#xa;（2024年完全義務化）" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#FFFFFF;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="120" width="370" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row1_stance" value="設計余地あり" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#fff2cc;strokeColor=#d79b00;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="120" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row1_note" value="業務記録への直接適用なし。ALCOA+ 設計が電帳法の&#xa;真実性確保・視認性確保と方向性が整合する。" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#FFFFFF;strokeColor=#666666;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="120" width="590" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="row2_reg" value="ISO 9001:2015&#xa;/ IATF 16949 / AS 9100" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#FFFFFF;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="210" width="370" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row2_stance" value="設計思想が整合" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#d5e8d4;strokeColor=#6c8ebf;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="210" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row2_note" value="ISO 9001 の 8.1〜8.7（運用管理・不適合管理）と整合。&#xa;第三者認証・適合保証は担わない。" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#FFFFFF;strokeColor=#666666;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="210" width="590" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="row3_reg" value="ISO 13485&#xa;（医療機器）" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#FFFFFF;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="300" width="370" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row3_stance" value="永続非提供" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="300" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row3_note" value="医療機器固有の設計管理（DHF）・検証プロセス（IEC 62304）が&#xa;必要。個人開発スコープを根本的に超える。" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#FFFFFF;strokeColor=#666666;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="300" width="590" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="row4_reg" value="労働安全衛生規則&#xa;/ 労働基準法" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#FFFFFF;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="390" width="370" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row4_stance" value="設計思想が整合" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#d5e8d4;strokeColor=#6c8ebf;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="390" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row4_note" value="夜勤・疲労・高齢者設計（Glanceable UI / EWI）が規則の精神と&#xa;整合する。法的管理の代替はしない。" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#FFFFFF;strokeColor=#666666;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="390" width="590" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="row5_reg" value="HACCP&#xa;（食品安全・2021年義務化）" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#FFFFFF;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="480" width="370" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row5_stance" value="永続非提供&#xa;（流用は自己責任）" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="480" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row5_note" value="CCP・Critical Limit 設計に食品安全専門知識が必要。&#xa;自己責任での流用は対象外として関与しない。" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#FFFFFF;strokeColor=#666666;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="480" width="590" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="row6_reg" value="GMP / FDA 21 CFR Part 11" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#FFFFFF;strokeColor=#666666;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="570" width="370" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row6_stance" value="永続非提供" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="570" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="row6_note" value="電子署名技術規格・Validation（CSV）・GAMP 5 対応が&#xa;必要。個人開発スコープを根本的に超える。" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#FFFFFF;strokeColor=#666666;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="590" y="570" width="590" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="legend_green" value="設計思想が整合" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#d5e8d4;strokeColor=#6c8ebf;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="680" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="legend_yellow" value="設計余地あり（ver1.0.0では非保証）" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#fff2cc;strokeColor=#d79b00;align=center;" vertex="1" parent="1">
          <mxGeometry x="210" y="680" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="legend_red" value="永続非提供" style="rounded=0;fontFamily=Helvetica;fontColor=#333333;fontSize=10;fillColor=#f8cecc;strokeColor=#b85450;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="680" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="legend_label" value="凡例: 緑 = 設計思想として整合・推奨 / 黄 = 設計余地あり（ver1.0.0 では保証せず） / 赤 = 将来にわたって永続非提供" style="text;fontFamily=Helvetica;fontColor=#333333;fontSize=10;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="752" width="1160" height="24" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

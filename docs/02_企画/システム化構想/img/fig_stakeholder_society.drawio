        <mxCell id="rh" value="主要設計原則" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="820" y="80" width="340" height="28" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="Just Culture&lt;br&gt;スリップ・ラプスは問責しない。&lt;br&gt;WADの乖離は適応の証拠として扱う" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#7b4f00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="820" y="130" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="行動データ用途三限定&lt;br&gt;品質保証・工程改善・教育設計のみ。&lt;br&gt;人事評価転用は永続禁止" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#b85450;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="820" y="230" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="ISO 9001準拠・ALCOA+対応&lt;br&gt;電子証拠の品質基準を設計の核心に置く。&lt;br&gt;GMP・IATF等は対象外と判断する" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#2e6b3e;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="820" y="330" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="多言語・多識字対応&lt;br&gt;外国人技能実習・特定技能・高齢者を&lt;br&gt;正規ユーザーとして設計に包含する" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#1e4d78;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="820" y="430" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="労働者代表の構想的優位性&lt;br&gt;最も声が小さく最も影響を受ける主体に&lt;br&gt;Foucaultのパノプティコンに抗する設計を" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;strokeColor=#7b4f00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="820" y="530" width="340" height="70" as="geometry" />

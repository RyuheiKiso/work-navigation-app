        <mxCell id="eb_c" value="WAI/WAD乖離の拡大" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="b" target="c">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- c → d: from bottom-left of c to top of d -->
        <mxCell id="ec_d" value="ALCOA+違反の構造化" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="c" target="d">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- c → e2: from bottom-right of c to top of e2 -->
        <mxCell id="ec_e" value="デジタル化の副作用" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="c" target="e2">

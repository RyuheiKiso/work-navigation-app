        <!-- Note -->
        <mxCell id="note" value="本アプリはこの因果連鎖を技術と倫理の両面から断ち切る" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">

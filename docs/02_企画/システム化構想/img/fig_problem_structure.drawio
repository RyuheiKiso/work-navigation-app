        <mxCell id="ea_c" value="記録の事後性" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=10;fontColor=#333333;" edge="1" parent="1" source="a" target="c">

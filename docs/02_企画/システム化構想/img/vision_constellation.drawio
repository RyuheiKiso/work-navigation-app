        <mxCell id="pr1" value="① Safety-I/II 相補&lt;br&gt;バリア×適応能力" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">

<mxfile>
  <diagram name="problem_chain" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="課題連鎖図" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="32" as="geometry" />
        </mxCell>
        <!-- Root cause box -->
        <mxCell id="root" value="WAI / WAD の制度的乖離&lt;br&gt;（手順書と現場作業のギャップが放置）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="240" height="80" as="geometry" />
        </mxCell>
        <!-- Effect 1 -->
        <mxCell id="eff1" value="後記・まとめ記入の常態化&lt;br&gt;（ALCOA+ 同時性原則の違反）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="360" y="240" width="240" height="80" as="geometry" />
        </mxCell>
        <!-- Effect 2 -->
        <mxCell id="eff2" value="作業ミス・手順抜け漏れ&lt;br&gt;（記憶頼り・中断後の再開ミス）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="360" y="400" width="240" height="80" as="geometry" />
        </mxCell>
        <!-- Effect 3 -->
        <mxCell id="eff3" value="暗黙知の消失&lt;br&gt;（熟練者退職でノウハウが失われる）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="660" y="200" width="240" height="80" as="geometry" />
        </mxCell>
        <!-- Effect 4 -->
        <mxCell id="eff4" value="トレーサビリティの断絶&lt;br&gt;（不適合追跡に数日を要する）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="660" y="360" width="240" height="80" as="geometry" />
        </mxCell>
        <!-- Final risk -->
        <mxCell id="risk" value="監査リスク・顧客信頼の喪失&lt;br&gt;（リコール範囲特定困難・規制対応遅延）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="880" y="300" width="260" height="80" as="geometry" />
        </mxCell>
        <!-- System response label -->
        <mxCell id="response_label" value="本システムの応答" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="440" y="590" width="320" height="24" as="geometry" />
        </mxCell>
        <mxCell id="resp1" value="電子記録で同時性を担保（Append-only）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="625" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="resp2" value="ステップ別ナビ + 完了ロック（多層防御）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="380" y="625" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="resp3" value="手順書のバージョン管理 + CAPA 閉ループ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="700" y="625" width="300" height="50" as="geometry" />
        </mxCell>
        <!-- Arrows: root → effects -->
        <mxCell id="e1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="root" target="eff1" parent="1">

        </mxCell>
        <mxCell id="e2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="root" target="eff2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- eff1 → eff3, eff2 → eff4 -->
        <mxCell id="e3" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="eff1" target="eff3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="eff2" target="eff4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- eff3, eff4 → risk -->
        <mxCell id="e5" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" source="eff3" target="risk" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" edge="1" source="eff4" target="risk" parent="1">
          <mxGeometry relative="1" as="geometry" />

<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="OutboxWorker 処理フロー" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="18" width="400" height="32" as="geometry" />
        </mxCell>
        <!-- START -->
        <mxCell id="start" value="Timer Trigger" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="160" height="44" as="geometry" />
        </mxCell>
        <!-- CHECK network -->
        <mxCell id="check_net" value="CHECK network state" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="460" y="130" width="200" height="44" as="geometry" />
        </mxCell>
        <!-- Decision: EMERGENCY? -->
        <mxCell id="d_emerg" value="EMERGENCY MODE?" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="440" y="210" width="240" height="70" as="geometry" />
        </mxCell>
        <!-- skip box (right of decision) -->
        <mxCell id="skip_box" value="Skip sync&#xa;Schedule next run" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="800" y="225" width="180" height="44" as="geometry" />
        </mxCell>
        <!-- SELECT PENDING events -->
        <mxCell id="sel_events" value="SELECT PENDING events LIMIT 10" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="440" y="320" width="240" height="44" as="geometry" />
        </mxCell>
        <!-- POST to backend -->
        <mxCell id="post_be" value="POST event to backend" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="460" y="400" width="200" height="44" as="geometry" />
        </mxCell>
        <!-- Decision: 2xx? -->
        <mxCell id="d_2xx" value="2xx response?" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="450" y="480" width="220" height="70" as="geometry" />
        </mxCell>
        <!-- status=SENT (left) -->
        <mxCell id="sent_box" value="status = SENT" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="160" y="495" width="160" height="40" as="geometry" />
        </mxCell>
        <!-- retry logic (right) -->
        <mxCell id="retry_box" value="retry_count++&#xa;retry &gt;= 5: DEAD_LETTERED" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="760" y="495" width="220" height="44" as="geometry" />
        </mxCell>
        <!-- Schedule next run (bottom) -->
        <mxCell id="next_run" value="Schedule next run" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="460" y="640" width="200" height="44" as="geometry" />
        </mxCell>
        <!-- Loop label -->
        <mxCell id="loop_lbl" value="[ for each event ]" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=#FFFFFF;strokeColor=#333333;align=center;" vertex="1" parent="1">
          <mxGeometry x="280" y="395" width="160" height="22" as="geometry" />
        </mxCell>
        <!-- Edges -->
        <mxCell id="e_s_cn" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="104" as="sourcePoint" />
            <mxPoint x="560" y="130" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e_cn_d" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="174" as="sourcePoint" />
            <mxPoint x="560" y="210" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e_emerg_yes" value="YES" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="680" y="245" as="sourcePoint" />
            <mxPoint x="800" y="245" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e_emerg_no" value="NO" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="280" as="sourcePoint" />
            <mxPoint x="560" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e_sel_post" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="364" as="sourcePoint" />
            <mxPoint x="560" y="400" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e_post_d2xx" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="444" as="sourcePoint" />
            <mxPoint x="560" y="480" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- YES goes left to sent_box -->
        <mxCell id="e_2xx_yes" value="YES" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="450" y="515" as="sourcePoint" />
            <mxPoint x="320" y="515" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- NO goes right to retry_box -->
        <mxCell id="e_2xx_no" value="NO" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="670" y="515" as="sourcePoint" />
            <mxPoint x="760" y="515" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Both converge to next_run via y=600 -->
        <mxCell id="e_sent_nr" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="535" as="sourcePoint" />
            <mxPoint x="560" y="640" as="targetPoint" />
            <Array as="points">
              <mxPoint x="240" y="600" />
              <mxPoint x="560" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_retry_nr" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="870" y="539" as="sourcePoint" />
            <mxPoint x="560" y="640" as="targetPoint" />
            <Array as="points">
              <mxPoint x="870" y="600" />
              <mxPoint x="560" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_skip_nr" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="890" y="269" as="sourcePoint" />
            <mxPoint x="660" y="640" as="targetPoint" />
            <Array as="points">
              <mxPoint x="1050" y="269" />
              <mxPoint x="1050" y="720" />
              <mxPoint x="660" y="720" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

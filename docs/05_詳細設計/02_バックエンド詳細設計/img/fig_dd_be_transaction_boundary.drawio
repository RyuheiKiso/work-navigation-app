<mxfile>
  <diagram name="トランザクション境界" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="トランザクション境界（WorkEvent + OutboxEvent）" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="700" height="32" as="geometry" />
        </mxCell>
        <!-- Transaction border rectangle -->
        <mxCell id="txn_border" value="BEGIN TRANSACTION" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=none;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="160" y="120" width="720" height="420" as="geometry" />
        </mxCell>
        <!-- Step 1: INSERT work_events -->
        <mxCell id="step_insert_we" value="INSERT work_events&#xa;(Append-only)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="240" y="220" width="240" height="70" as="geometry" />
        </mxCell>
        <!-- Step 2: INSERT outbox_events -->
        <mxCell id="step_insert_ob" value="INSERT outbox_events&#xa;(Append-only)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="560" y="220" width="240" height="70" as="geometry" />
        </mxCell>
        <!-- COMMIT -->
        <mxCell id="step_commit" value="COMMIT" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="460" y="390" width="120" height="60" as="geometry" />
        </mxCell>
        <!-- Outside txn: ROLLBACK -->
        <mxCell id="step_rollback" value="ROLLBACK" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="960" y="300" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- Note: append-only -->
        <mxCell id="note_ao" value="Append-only: INSERT only, no UPDATE/DELETE" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=2;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="600" width="500" height="30" as="geometry" />
        </mxCell>
        <!-- Edges inside transaction -->
        <!-- BEGIN → INSERT work_events -->
        <mxCell id="e_begin_we" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="txn_border" target="step_insert_we" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="360" y="160" />
              <mxPoint x="360" y="220" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- BEGIN → INSERT outbox_events -->
        <mxCell id="e_begin_ob" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="txn_border" target="step_insert_ob" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="160" />
              <mxPoint x="680" y="220" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- INSERT work_events → COMMIT -->
        <mxCell id="e_we_commit" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="step_insert_we" target="step_commit" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="360" y="340" />
              <mxPoint x="360" y="420" />
              <mxPoint x="460" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- INSERT outbox_events → COMMIT -->
        <mxCell id="e_ob_commit" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="step_insert_ob" target="step_commit" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="340" />
              <mxPoint x="680" y="420" />
              <mxPoint x="580" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- ROLLBACK edge: from error path outside txn border -->
        <mxCell id="e_rollback" value="エラー発生時" style="endArrow=classic;endFill=1;html=1;strokeColor=#9673a6;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="txn_border" target="step_rollback" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="880" y="330" />
              <mxPoint x="960" y="330" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

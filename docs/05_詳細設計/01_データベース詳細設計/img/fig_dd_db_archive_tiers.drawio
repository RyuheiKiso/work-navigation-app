        </mxCell>
        <mxCell id="y7" value="Year 7" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="920" y="208" width="60" height="18" as="geometry" />
        </mxCell>
        <!-- Year tick marks -->
        <mxCell id="tick0" value="" style="endArrow=none;html=1;strokeColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="80" y="194" as="sourcePoint" />
            <mxPoint x="80" y="206" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tick2" value="" style="endArrow=none;html=1;strokeColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="194" as="sourcePoint" />
            <mxPoint x="350" y="206" as="targetPoint" />
          </mxGeometry>

        <!-- Data creation event -->
        <mxCell id="create_ev" value="データ書込&#xa;(work_event INSERT)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="180" height="48" as="geometry" />

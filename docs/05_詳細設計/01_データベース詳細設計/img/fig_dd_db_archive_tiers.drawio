            <mxPoint x="60" y="200" as="sourcePoint" />
            <mxPoint x="1140" y="200" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tl_lbl" value="時間軸" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="1070" y="208" width="70" height="20" as="geometry" />
        </mxCell>
        <!-- Year markers -->

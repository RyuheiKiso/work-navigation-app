        <!-- Tier bands -->
        <!-- Hot: 0-2y = x 80 to 350 width 270 -->
        <mxCell id="hot" value="Hot Tier&#xa;SSD online&#xa;(0 - 2 年)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="270" height="100" as="geometry" />

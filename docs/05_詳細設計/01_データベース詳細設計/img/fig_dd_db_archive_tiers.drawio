        <!-- 7-year retention policy note -->
        <mxCell id="ret_note" value="法定保存年限: 7年 / 7年後に自動削除" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fffacd;strokeColor=#333333;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="500" width="440" height="34" as="geometry" />

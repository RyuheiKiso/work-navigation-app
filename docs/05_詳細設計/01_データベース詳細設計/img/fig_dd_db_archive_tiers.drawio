        <mxCell id="tick5" value="" style="endArrow=none;html=1;strokeColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="194" as="sourcePoint" />
            <mxPoint x="650" y="206" as="targetPoint" />

<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Append-only テーブルと PostgreSQL ロール設計" style="text;html=1;fontFamily=Helvetica;fontSize=17;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="800" height="32" as="geometry" />
        </mxCell>

        <!-- Role boxes (top row, y=52) -->
        <mxCell id="role1" value="app_event_writer" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="52" width="260" height="36" as="geometry" />
        </mxCell>
        <mxCell id="role1d" value="GRANT INSERT&#xa;REVOKE UPDATE, DELETE&#xa;対象: work_events, evidence_files, measurements 等" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="92" width="260" height="64" as="geometry" />
        </mxCell>

        <mxCell id="role2" value="app_master_writer" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="470" y="52" width="260" height="36" as="geometry" />
        </mxCell>
        <mxCell id="role2d" value="GRANT INSERT, UPDATE&#xa;REVOKE DELETE&#xa;対象: マスタ系テーブル全般" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;align=left;" vertex="1" parent="1">
          <mxGeometry x="470" y="92" width="260" height="64" as="geometry" />
        </mxCell>

        <mxCell id="role3" value="app_read_only" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="880" y="52" width="260" height="36" as="geometry" />
        </mxCell>
        <mxCell id="role3d" value="GRANT SELECT&#xa;対象: 全テーブル" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;align=left;" vertex="1" parent="1">
          <mxGeometry x="880" y="92" width="260" height="64" as="geometry" />
        </mxCell>

        <!-- Section header: Append-only tables -->
        <mxCell id="aoh" value="INSERT-only テーブル（Append-only）" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="192" width="800" height="26" as="geometry" />
        </mxCell>

        <!-- Append-only table boxes: Row 1 y=232 -->
        <mxCell id="tbl01" value="TBL-001&#xa;work_orders" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="232" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="tbl02" value="TBL-002&#xa;work_executions" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="300" y="232" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="tbl03" value="TBL-003&#xa;work_events" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="540" y="232" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="tbl09" value="TBL-009&#xa;evidence_files" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="780" y="232" width="210" height="48" as="geometry" />
        </mxCell>

        <!-- Row 2 y=308 -->
        <mxCell id="tbl10" value="TBL-010&#xa;measurements" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="308" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="tbl11" value="TBL-011&#xa;electronic_signs" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="300" y="308" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="tbl31" value="TBL-031&#xa;andon_alerts" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="540" y="308" width="210" height="48" as="geometry" />
        </mxCell>
        <mxCell id="tbl32" value="TBL-032&#xa;audit_logs" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="780" y="308" width="210" height="48" as="geometry" />
        </mxCell>

        <!-- Edges from role1 to tables:
             Use a bus at y=174 (between aoh label bottom and table top),
             route down-only at the RIGHT side of each table's column gap.
             Left side: x=30 clear bus for row-2 items.
             Strategy: role1 drops to y=174 bus, branches out to each column.
             We use x=40 (left of tbl01), x=280 (between tbl01 and tbl02),
             x=520 (between tbl02 and tbl03), x=760 (between tbl03 and tbl09),
             x=1000 (right of tbl09) as vertical channels.
        -->

        <!-- Bus line: role1 -> horizontal at y=174 -->
        <mxCell id="e_r1_bus" style="endArrow=none;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint as="sourcePoint" x="190" y="156" />
            <mxPoint as="targetPoint" x="190" y="220" />
          </mxGeometry>
        </mxCell>

        <!-- role1 bottom to bus start -->
        <mxCell id="e_r1_drop" style="endArrow=none;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="role1d" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint as="sourcePoint" x="190" y="156" />
            <mxPoint as="targetPoint" x="190" y="172" />
            <Array as="points">
              <mxPoint x="190" y="156" />
              <mxPoint x="190" y="172" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Direct edges from role1d to tables: use column-center x values,
             and ensure each vertical segment is in the gap between adjacent tables.
             tbl01 center x=165, tbl02 center x=405, tbl03 center x=645, tbl09 center x=885
             tbl10 center x=165, tbl11 center x=405, tbl31 center x=645, tbl32 center x=885
        -->

        <!-- role1 -> tbl01 (straight down, same column) -->
        <mxCell id="e_r1_t01" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="role1d" target="tbl01" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="165" y="156" />
              <mxPoint x="165" y="232" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- role1 -> tbl02: go right at y=172 then down -->
        <mxCell id="e_r1_t02" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="role1d" target="tbl02" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="156" />
              <mxPoint x="270" y="172" />
              <mxPoint x="405" y="172" />
              <mxPoint x="405" y="232" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- role1 -> tbl03 -->
        <mxCell id="e_r1_t03" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="role1d" target="tbl03" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="156" />
              <mxPoint x="270" y="172" />
              <mxPoint x="645" y="172" />
              <mxPoint x="645" y="232" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- role1 -> tbl09 -->
        <mxCell id="e_r1_t09" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="role1d" target="tbl09" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="156" />
              <mxPoint x="270" y="172" />
              <mxPoint x="885" y="172" />
              <mxPoint x="885" y="232" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- role1 -> tbl10 (row 2): go LEFT of tbl01 using x=40 -->
        <mxCell id="e_r1_t10" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="role1d" target="tbl10" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="60" y="124" />
              <mxPoint x="40" y="124" />
              <mxPoint x="40" y="332" />
              <mxPoint x="60" y="332" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- role1 -> tbl11 (row 2): go through gap between tbl01/tbl02 at x=280 -->
        <mxCell id="e_r1_t11" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="role1d" target="tbl11" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="156" />
              <mxPoint x="270" y="172" />
              <mxPoint x="280" y="172" />
              <mxPoint x="280" y="332" />
              <mxPoint x="300" y="332" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- role3 -> tbl32 (representative read arrow): go right to x=1160, down to tbl32 -->
        <mxCell id="e_r3_t32" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="role3d" target="tbl32" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1140" y="156" />
              <mxPoint x="1160" y="156" />
              <mxPoint x="1160" y="332" />
              <mxPoint x="990" y="332" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Note -->
        <mxCell id="note" value="INSERT-only 制約: BEFORE UPDATE/DELETE トリガにより変更・削除を禁止 | app_event_writer は Append-only テーブルにのみ書込み可" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="376" width="1000" height="22" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

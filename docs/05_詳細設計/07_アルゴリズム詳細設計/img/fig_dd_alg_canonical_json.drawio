<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="正規化 JSON 生成アルゴリズム（ALG-006）" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="250" y="12" width="700" height="34" as="geometry" />
        </mxCell>

        <!-- Pipeline steps: left to right -->
        <!-- Step 1: WorkEvent struct (Rust) -->
        <mxCell id="s1" value="WorkEvent struct&#xa;(Rust)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Op 1: BTreeMap -->
        <mxCell id="op1" value="BTreeMap&#xa;(キーソート)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="300" y="200" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Op 2: serde_json::to_string() -->
        <mxCell id="op2" value="serde_json::to_string()&#xa;(compact・決定的)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="540" y="200" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Op 3: UTF-8 bytes -->
        <mxCell id="op3" value="UTF-8 bytes" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="820" y="200" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Op 4: SHA-256 hash -->
        <mxCell id="op4" value="SHA-256&#xa;→ content_hash CHAR(64)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="1000" y="200" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Arrows between pipeline steps -->
        <!-- s1 -> op1 -->
        <mxCell id="e1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="s1" target="op1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="240" y="230" />
              <mxPoint x="300" y="230" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- op1 -> op2 -->
        <mxCell id="e2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="op1" target="op2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="480" y="230" />
              <mxPoint x="540" y="230" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- op2 -> op3 -->
        <mxCell id="e3" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="op2" target="op3" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="230" />
              <mxPoint x="820" y="230" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- op3 -> op4 -->
        <mxCell id="e4" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="op3" target="op4" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1000" y="230" />
              <mxPoint x="1000" y="230" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step labels below each box -->
        <mxCell id="l1" value="Step 1" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="268" width="180" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="Step 2" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="268" width="180" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="Step 3" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="540" y="268" width="220" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l4" value="Step 4" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="820" y="268" width="180" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l5" value="Step 5" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="1000" y="268" width="180" height="18" as="geometry" />
        </mxCell>

        <!-- Description annotations below labels -->
        <mxCell id="d1" value="イベント構造体" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="180" height="18" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="キー昇順ソート" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="290" width="180" height="18" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="JSON文字列化" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="540" y="290" width="220" height="18" as="geometry" />
        </mxCell>
        <mxCell id="d4" value="バイト列変換" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="820" y="290" width="180" height="18" as="geometry" />
        </mxCell>
        <mxCell id="d5" value="ハッシュ値(hex 64文字)" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="1000" y="290" width="180" height="18" as="geometry" />
        </mxCell>

        <!-- Guarantee note box -->
        <mxCell id="gnote" value="正規化保証: フィールド順序を BTreeMap で固定 → 同一データは常に同一バイト列 → 同一ハッシュ値" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="360" width="800" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

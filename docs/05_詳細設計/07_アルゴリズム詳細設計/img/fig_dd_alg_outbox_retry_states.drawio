<mxfile>
  <diagram name="Outbox イベント状態遷移" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Outbox イベント状態遷移" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="32" as="geometry" />
        </mxCell>
        <!-- States -->
        <mxCell id="s_pending" value="PENDING" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="120" y="350" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_sending" value="SENDING" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="520" y="350" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- SENT: final - double border via outer container -->
        <mxCell id="s_sent_outer" value="" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#333333;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="900" y="195" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s_sent" value="SENT" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="910" y="203" width="160" height="54" as="geometry" />
        </mxCell>
        <!-- DEAD_LETTERED: final -->
        <mxCell id="s_dead_outer" value="" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#333333;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="900" y="505" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s_dead" value="DEAD_LETTERED" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="910" y="513" width="160" height="54" as="geometry" />
        </mxCell>
        <!-- Backoff formula note -->
        <mxCell id="backoff_note" value="delay = min(1000 × 2^(retry-1), 32000) ms" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="340" y="640" width="360" height="30" as="geometry" />
        </mxCell>
        <!-- Edges -->
        <!-- PENDING → SENDING -->
        <mxCell id="e_pend_send" value="dispatch" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_pending" target="s_sending" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="370" />
              <mxPoint x="520" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- SENDING → SENT -->
        <mxCell id="e_send_sent" value="success" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_sending" target="s_sent" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="740" y="360" />
              <mxPoint x="860" y="280" />
              <mxPoint x="910" y="230" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- SENDING → PENDING (retry with backoff) -->
        <mxCell id="e_send_pend" value="retry (backoff)" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_sending" target="s_pending" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="410" />
              <mxPoint x="600" y="460" />
              <mxPoint x="200" y="460" />
              <mxPoint x="200" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- SENDING → DEAD_LETTERED (5 failures) -->
        <mxCell id="e_send_dead" value="5 failures" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_sending" target="s_dead" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="740" y="390" />
              <mxPoint x="860" y="480" />
              <mxPoint x="910" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

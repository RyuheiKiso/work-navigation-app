<mxfile>
  <diagram name="ネットワーク状態遷移" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="ネットワーク状態遷移（ALG-011）" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="32" as="geometry" />
        </mxCell>
        <!-- States arranged left to right -->
        <!-- CONNECTED (green) -->
        <mxCell id="s_connected" value="CONNECTED" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="180" height="60" as="geometry" />
        </mxCell>
        <!-- DEGRADED (yellow) -->
        <mxCell id="s_degraded" value="DEGRADED" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="380" y="360" width="180" height="60" as="geometry" />
        </mxCell>
        <!-- DISCONNECTED (orange) -->
        <mxCell id="s_disconnected" value="DISCONNECTED" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#666666;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="680" y="360" width="180" height="60" as="geometry" />
        </mxCell>
        <!-- EMERGENCY_MODE (red) -->
        <mxCell id="s_emergency" value="EMERGENCY_MODE" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#9673a6;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="980" y="360" width="180" height="60" as="geometry" />
        </mxCell>
        <!-- Legend -->
        <mxCell id="legend" value="凡例: CONNECTED=青, DEGRADED=黄, DISCONNECTED=灰, EMERGENCY_MODE=紫" style="text;html=1;fontFamily=Helvetica;fontSize=10;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="740" width="800" height="24" as="geometry" />
        </mxCell>
        <!-- Forward edges (top path) -->
        <!-- CONNECTED → DEGRADED: API P95 > threshold -->
        <mxCell id="e_con_deg" value="API P95 &gt; threshold" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_connected" target="s_degraded" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="340" />
              <mxPoint x="470" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- CONNECTED → DISCONNECTED: API timeout 30s -->
        <mxCell id="e_con_dis" value="API timeout 30s" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_connected" target="s_disconnected" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="170" y="290" />
              <mxPoint x="770" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- DEGRADED → DISCONNECTED: complete failure -->
        <mxCell id="e_deg_dis" value="complete failure" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_degraded" target="s_disconnected" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="350" />
              <mxPoint x="680" y="350" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- DISCONNECTED → EMERGENCY_MODE: disconnected > 5min (CFG) -->
        <mxCell id="e_dis_em" value="disconnected &gt; 5min (CFG)" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_disconnected" target="s_emergency" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="860" y="370" />
              <mxPoint x="980" y="370" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Return edges (bottom path): Any → CONNECTED: API call success -->
        <!-- DEGRADED → CONNECTED -->
        <mxCell id="e_deg_con" value="API call success" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_degraded" target="s_connected" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="470" y="450" />
              <mxPoint x="200" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- DISCONNECTED → CONNECTED -->
        <mxCell id="e_dis_con" value="API call success" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_disconnected" target="s_connected" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="480" />
              <mxPoint x="170" y="480" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- EMERGENCY_MODE → CONNECTED -->
        <mxCell id="e_em_con" value="API call success" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="s_emergency" target="s_connected" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1070" y="510" />
              <mxPoint x="170" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

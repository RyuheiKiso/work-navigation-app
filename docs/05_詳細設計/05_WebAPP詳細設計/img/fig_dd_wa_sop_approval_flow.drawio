        <mxCell id="st_rej" value="rejected" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="440" y="540" width="140" height="60" as="geometry" />
        </mxCell>
        <!-- Edge labels as separate text boxes (to avoid label distance rule) -->
        <!-- draft -> under_review -->
        <mxCell id="e_dr_rev" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="340" as="sourcePoint" />
            <mxPoint x="440" y="340" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_dr_rev" value="submitForReview (master_admin)" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=#FFFFFF;strokeColor=#333333;align=center;" vertex="1" parent="1">
          <mxGeometry x="196" y="315" width="228" height="22" as="geometry" />
        </mxCell>
        <!-- under_review -> approved: go up then right -->
        <mxCell id="e_rev_app" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="320" as="sourcePoint" />

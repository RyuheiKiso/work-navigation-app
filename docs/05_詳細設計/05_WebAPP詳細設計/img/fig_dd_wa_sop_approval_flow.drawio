        <mxCell id="lbl_rev_app" value="approve + e-sign (quality_admin)" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=#FFFFFF;strokeColor=#333333;align=center;" vertex="1" parent="1">
          <mxGeometry x="596" y="106" width="248" height="22" as="geometry" />
        </mxCell>
        <!-- under_review -> rejected: straight down -->

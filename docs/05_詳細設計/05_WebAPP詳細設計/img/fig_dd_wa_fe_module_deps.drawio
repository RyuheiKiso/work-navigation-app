<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="フロントエンドモジュール依存関係" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="12" width="600" height="34" as="geometry" />
        </mxCell>

        <!-- ===== LEFT APP: Master Maintenance APP ===== -->
        <mxCell id="lapp" value="Master Maintenance APP" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="56" width="460" height="24" as="geometry" />
        </mxCell>

        <!-- Left features: 2 boxes in one row, wide spacing -->
        <!-- lf1: x=80, lf2: x=320. Gap between right edge of lf1 (x=280) and left edge of lf2 (x=320) = 40px -->
        <mxCell id="lf1" value="features/sop-editor" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lf2" value="features/approval" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="320" y="90" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- Left shared: 2 boxes, aligned below features -->
        <!-- ls1: x=80, ls2: x=320 -->
        <mxCell id="ls1" value="shared/api-client" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="80" y="250" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ls2" value="shared/auth" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="320" y="250" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- Left edges: lf1->ls1 straight down center col1 x=170 -->
        <mxCell id="e_lf1_ls1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="lf1" target="ls1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="170" y="130" />
              <mxPoint x="170" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- lf2->ls2 straight down center col2 x=410 -->
        <mxCell id="e_lf2_ls2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="lf2" target="ls2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="410" y="130" />
              <mxPoint x="410" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- lf1->ls2: go right from lf1 bottom-right corner (x=260), down to y=230, right to x=410, down to ls2 -->
        <mxCell id="e_lf1_ls2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="lf1" target="ls2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="260" y="110" />
              <mxPoint x="300" y="110" />
              <mxPoint x="300" y="230" />
              <mxPoint x="410" y="230" />
              <mxPoint x="410" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- lf2->ls1: go left from lf2 (x=320), down x=300 is in gap, then to ls1 -->
        <mxCell id="e_lf2_ls1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="lf2" target="ls1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="320" y="110" />
              <mxPoint x="300" y="110" />
              <mxPoint x="300" y="230" />
              <mxPoint x="170" y="230" />
              <mxPoint x="170" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Divider -->
        <mxCell id="divider" style="endArrow=none;html=1;strokeColor=#333333;dashed=1;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint as="sourcePoint" x="580" y="56" />
            <mxPoint as="targetPoint" x="580" y="380" />
          </mxGeometry>
        </mxCell>

        <!-- ===== RIGHT APP: Management Console APP ===== -->
        <mxCell id="rapp" value="Management Console APP" style="text;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="620" y="56" width="560" height="24" as="geometry" />
        </mxCell>

        <!-- Right features: 5 modules in two rows -->
        <!-- Row 1: y=90. rf1,rf2,rf3. x=620,780,940 -->
        <mxCell id="rf1" value="features/dashboard" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="620" y="90" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf2" value="features/audit" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="780" y="90" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf3" value="features/hash-verify" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="940" y="90" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- Row 2: y=150. rf4,rf5. x=700,860 -->
        <mxCell id="rf4" value="features/outbox-mon" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf5" value="features/reports" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="860" y="150" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- Right shared: 2 boxes y=290. rs1: x=660, rs2: x=900 -->
        <mxCell id="rs1" value="shared/api-client" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="660" y="290" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rs2" value="shared/auth" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="920" y="290" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- Right edges: all features route down to shared via column gaps
             Available vertical channels (between boxes):
             ch_a: x=600 (left of rf1)
             ch_b: x=770 (gap rf1..rf2)
             ch_c: x=930 (gap rf2..rf3)
             ch_d: x=1100 (right of rf3)
             For rs1 center: x=750. For rs2 center: x=1010.
        -->

        <!-- rf1 -> rs1: down from rf1 bottom (x=695) through ch_b gap, to rs1 -->
        <mxCell id="e_rf1_rs1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="rf1" target="rs1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="695" y="130" />
              <mxPoint x="695" y="270" />
              <mxPoint x="750" y="270" />
              <mxPoint x="750" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- rf2 -> rs1: go up above all boxes (y=80), then right past rf3 (x=1100), down, then left to rs1 -->
        <mxCell id="e_rf2_rs1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="rf2" target="rs1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="855" y="90" />
              <mxPoint x="855" y="78" />
              <mxPoint x="1100" y="78" />
              <mxPoint x="1100" y="270" />
              <mxPoint x="750" y="270" />
              <mxPoint x="750" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- rf3 -> rs2: down at x=1010 -->
        <mxCell id="e_rf3_rs2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="rf3" target="rs2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1010" y="130" />
              <mxPoint x="1010" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- rf4 -> rs1: straight down x=750 -->
        <mxCell id="e_rf4_rs1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="rf4" target="rs1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="190" />
              <mxPoint x="750" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- rf5 -> rs2: straight down x=1010 -->
        <mxCell id="e_rf5_rs2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="rf5" target="rs2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1010" y="190" />
              <mxPoint x="1010" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Direction note -->
        <mxCell id="dnote" value="依存方向: features → shared（単方向・循環依存なし）" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="360" width="800" height="22" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

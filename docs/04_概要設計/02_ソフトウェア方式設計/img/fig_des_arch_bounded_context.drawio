        <mxCell id="rework" value="&lt;b&gt;Rework Context&lt;/b&gt;&lt;br&gt;作業実施[terminal-api]&lt;br&gt;ディスポジション[master-api]" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#e1d5e7;" vertex="1" parent="1">

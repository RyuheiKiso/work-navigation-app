        </mxCell>
        <mxCell id="auth_ctx" value="&lt;b&gt;認証（Auth）&lt;/b&gt;&lt;br&gt;JWT aud クレームで判別&lt;br&gt;&lt;font style=&apos;font-size:11px;&apos;&gt;[両バイナリ]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="840" y="340" width="280" height="120" as="geometry" />
        </mxCell>
        <!-- Edges 上段 -->
        <mxCell id="e1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="authoring" target="execution">

          </mxGeometry>
        </mxCell>
        <!-- Edges 中段 -->
        <!-- e3: execution(460-740,120-240) → rework(460-740,340-460): 直下に降りる (x=600) -->
        <mxCell id="e3" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="execution" target="rework">

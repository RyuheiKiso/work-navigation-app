        <mxCell id="legend_both" value="両バイナリ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="1180" y="220" width="160" height="36" as="geometry" />
        </mxCell>
        <!-- BCs 上段 -->
        <mxCell id="authoring" value="&lt;b&gt;Authoring Context&lt;/b&gt;&lt;br&gt;SOP作成・承認・公開&lt;br&gt;&lt;font style=&apos;font-size:11px;&apos;&gt;[master-api]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="execution" value="&lt;b&gt;Execution Context&lt;/b&gt;&lt;br&gt;作業実行・進捗・Offline-First&lt;br&gt;&lt;font style=&apos;font-size:11px;&apos;&gt;[terminal-api]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="460" y="120" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="evidence" value="&lt;b&gt;Evidence Context&lt;/b&gt;&lt;br&gt;証拠収集・SHA-256&lt;br&gt;&lt;font style=&apos;font-size:11px;&apos;&gt;[terminal-api]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="840" y="120" width="280" height="120" as="geometry" />
        </mxCell>
        <!-- BCs 下段 -->
        <mxCell id="quality" value="&lt;b&gt;Quality Context&lt;/b&gt;&lt;br&gt;Andon発報[terminal-api]&lt;br&gt;CAPA管理[master-api]" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="200" y="560" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="integration" value="&lt;b&gt;Integration Context&lt;/b&gt;&lt;br&gt;Outbox送信・Webhook配信&lt;br&gt;&lt;font style=&apos;font-size:11px;&apos;&gt;[terminal-api]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="700" y="560" width="300" height="120" as="geometry" />
        </mxCell>
        <!-- IQC / Rework BCs 右段 -->
        <mxCell id="iqc" value="&lt;b&gt;IQC Context&lt;/b&gt;&lt;br&gt;検査実施[terminal-api]&lt;br&gt;合否判定・特採[master-api]" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#e1d5e7;" vertex="1" parent="1">

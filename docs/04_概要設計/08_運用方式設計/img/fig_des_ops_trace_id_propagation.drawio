          <mxGeometry x="80" y="430" width="1040" height="24" as="geometry" />
        </mxCell>
        <mxCell id="log3" value="2026-05-17 14:30:01.178    abc-123           backend_api       INFO        DB INSERT INTO work_records — rows: 1" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="1040" height="24" as="geometry" />
        </mxCell>
        <mxCell id="log4" value="2026-05-17 14:30:01.190    abc-123           postgresql        INFO        transaction committed" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="490" width="1040" height="24" as="geometry" />
        </mxCell>
        <mxCell id="log5" value="2026-05-17 14:30:01.200    abc-123           backend_api       INFO        Response 200 OK — duration: 77ms" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="1040" height="24" as="geometry" />
        </mxCell>
        <!-- Trace ID highlight box -->
        <mxCell id="trace-highlight" value="trace_id = abc-123 で全ログを串刺し検索可能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#333333;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="630" width="600" height="36" as="geometry" />

<mxfile>
  <diagram name="fig16-trace-id" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <!-- Title -->
        <mxCell id="title" value="X-Trace-Id 伝播" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="800" height="36" as="geometry" />
        </mxCell>
        <!-- Client box -->
        <mxCell id="client" value="クライアント&#xa;(Handy APP / Web APP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#333333;fontFamily=Helvetica;fontSize=13;fontColor=#333333;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="220" height="100" as="geometry" />
        </mxCell>
        <!-- Backend API box -->
        <mxCell id="backend" value="Backend API&#xa;(Rust + Axum)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#333333;fontFamily=Helvetica;fontSize=13;fontColor=#333333;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="490" y="160" width="220" height="100" as="geometry" />
        </mxCell>
        <!-- PostgreSQL box -->
        <mxCell id="pg" value="PostgreSQL&#xa;ログテーブル" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#333333;fontFamily=Helvetica;fontSize=13;fontColor=#333333;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="920" y="160" width="220" height="100" as="geometry" />
        </mxCell>
        <!-- Arrow: client to backend -->
        <mxCell id="arr-cb" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="client" target="backend" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="210" />
              <mxPoint x="448" y="210" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Arrow label (separate text vertex) -->
        <mxCell id="lbl-cb" value="HTTP Request&#xa;X-Trace-Id: abc-123" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="310" y="180" width="200" height="40" as="geometry" />
        </mxCell>
        <!-- Arrow: backend to pg -->
        <mxCell id="arr-bp" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="backend" target="pg" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="756" y="210" />
              <mxPoint x="878" y="210" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl-bp" value="SQL + trace_id&#xa;INSERT INTO logs" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="756" y="180" width="200" height="40" as="geometry" />
        </mxCell>
        <!-- Log entries showing same trace_id -->
        <mxCell id="log-title" value="ログエントリ — 全エントリが同一 trace_id を共有" style="text;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="700" height="28" as="geometry" />
        </mxCell>
        <!-- Log entries table -->
        <mxCell id="log-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="358" width="1080" height="260" as="geometry" />
        </mxCell>
        <mxCell id="log-hdr" value="timestamp                   trace_id          service           log_level   message" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="368" width="1000" height="24" as="geometry" />
        </mxCell>
        <mxCell id="log1" value="2026-05-17 14:30:01.123    abc-123           handy_app         INFO        Request started: POST /api/work-records" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="1040" height="24" as="geometry" />
        </mxCell>

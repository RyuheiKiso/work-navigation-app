<mxfile>
  <diagram name="fig_des_deploy_degraded_mode" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="縮退運用モード (Emergency Mode)" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="36" as="geometry" />
        </mxCell>

        <!-- LEVEL-1 box -->
        <mxCell id="lv1-box" value="LEVEL-1: API 縮退" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#ffe6cc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="1080" height="140" as="geometry" />
        </mxCell>
        <mxCell id="lv1-desc" value="一部エンドポイント利用不可&#xa;・master-api 停止時も terminal-api は継続稼働（現場作業・記録に影響なし）&#xa;・停止側エンドポイントは HTTP 503 を返却" style="text;html=1;fontFamily=Helvetica;fontSize=12;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="780" height="70" as="geometry" />
        </mxCell>
        <mxCell id="lv1-badge" value="影響: 軽微" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="980" y="130" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- LEVEL-2 box -->
        <mxCell id="lv2-box" value="LEVEL-2: Emergency Mode (WiFi 断絶)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="1080" height="200" as="geometry" />
        </mxCell>
        <mxCell id="lv2-desc" value="オフライン運用 (WiFi 断絶時)&#xa;・ハンディ端末はローカル SQLite で作業記録を継続（terminal-api 不達でも動作）&#xa;・送信キュー (Outbox) にデータを蓄積&#xa;・WiFi 復旧時に terminal-api へ自動同期 (Retry with Exponential Backoff)" style="text;html=1;fontFamily=Helvetica;fontSize=12;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="315" width="740" height="120" as="geometry" />
        </mxCell>
        <mxCell id="lv2-outbox" value="Outbox&#xa;蓄積中" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="840" y="315" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lv2-sync" value="WiFi 復旧&#xa;→ 自動同期" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="980" y="315" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lv2-arr" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="940" y="345" as="sourcePoint" />
            <mxPoint x="980" y="345" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lv2-badge" value="影響: 中程度" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="840" y="400" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- LEVEL-3 box -->
        <mxCell id="lv3-box" value="LEVEL-3: サーバー全停止（terminal-api + master-api 両方停止）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#f8cecc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="1080" height="220" as="geometry" />
        </mxCell>
        <mxCell id="lv3-desc" value="サーバー全停止時の紙帳票バックアップ運用&#xa;・ハンディ端末を使用不可&#xa;・作業実績を紙帳票 (FR-001) に手書き記録&#xa;・サーバー復旧後にまとめて手動入力&#xa;（通常は terminal-api 単独稼働で LEVEL-1 相当に留まる）" style="text;html=1;fontFamily=Helvetica;fontSize=12;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="565" width="740" height="130" as="geometry" />
        </mxCell>
        <mxCell id="lv3-rto" value="RTO = 15 分&#xa;(目標復旧時間)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="840" y="560" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lv3-paper" value="紙帳票&#xa;バックアップ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="1000" y="560" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lv3-badge" value="影響: 重大" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="840" y="650" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- Severity down arrows between levels -->
        <mxCell id="arr-lv1-lv2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="220" as="sourcePoint" />
            <mxPoint x="600" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl-deg1" value="さらに縮退" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="615" y="228" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="arr-lv2-lv3" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="470" as="sourcePoint" />
            <mxPoint x="600" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl-deg2" value="さらに縮退" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="615" y="478" width="80" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

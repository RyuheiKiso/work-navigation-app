<mxfile>
  <diagram name="fig_des_deploy_degraded_mode" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="縮退運用モード (Emergency Mode)" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="36" as="geometry" />
        </mxCell>

        <!-- LEVEL-1 box -->
        <mxCell id="lv1-box" value="LEVEL-1: API 縮退" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#ffe6cc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="1080" height="160" as="geometry" />
        </mxCell>
        <mxCell id="lv1-desc" value="一部エンドポイント利用不可&#xa;・対象外エンドポイントは HTTP 503 を返却&#xa;・クリティカルパス (作業記録・製品照会) は継続稼働" style="text;html=1;fontFamily=Helvetica;fontSize=12;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="lv1-badge" value="影響: 軽微" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="980" y="155" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- LEVEL-2 box -->
        <mxCell id="lv2-box" value="LEVEL-2: Emergency Mode (WiFi 断絶)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="1080" height="200" as="geometry" />
        </mxCell>
        <mxCell id="lv2-desc" value="オフライン運用 (WiFi 断絶時)&#xa;・ハンディ端末はローカル SQLite で作業記録を継続&#xa;・送信キュー (Outbox) にデータを蓄積&#xa;・WiFi 復旧時に自動同期 (Retry with Exponential Backoff)" style="text;html=1;fontFamily=Helvetica;fontSize=12;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="348" width="700" height="110" as="geometry" />
        </mxCell>
        <mxCell id="lv2-outbox" value="Outbox&#xa;蓄積中" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="840" y="340" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lv2-sync" value="WiFi 復旧&#xa;→ 自動同期" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="980" y="340" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lv2-arr" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="940" y="370" as="sourcePoint" />
            <mxPoint x="980" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lv2-badge" value="影響: 中程度" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="840" y="430" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- LEVEL-3 box -->
        <mxCell id="lv3-box" value="LEVEL-3: サーバー停止" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#f8cecc;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="540" width="1080" height="200" as="geometry" />
        </mxCell>
        <mxCell id="lv3-desc" value="サーバー停止時の紙帳票バックアップ運用&#xa;・ハンディ端末を使用不可&#xa;・作業実績を紙帳票 (FR-001) に手書き記録&#xa;・サーバー復旧後にまとめて手動入力" style="text;html=1;fontFamily=Helvetica;fontSize=12;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="588" width="700" height="110" as="geometry" />
        </mxCell>
        <mxCell id="lv3-rto" value="RTO = 15 分&#xa;(目標復旧時間)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="840" y="580" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lv3-paper" value="紙帳票&#xa;バックアップ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="1000" y="580" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lv3-badge" value="影響: 重大" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="840" y="670" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- Severity down arrows between levels -->
        <mxCell id="arr-lv1-lv2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="260" as="sourcePoint" />
            <mxPoint x="600" y="300" as="targetPoint" />

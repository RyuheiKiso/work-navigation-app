<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="システム全体構成" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="36" as="geometry" />
        </mxCell>

        <!-- フィールド層 (left, blue) -->
        <mxCell id="field_box" value="フィールド層" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="300" height="560" as="geometry" />
        </mxCell>
        <mxCell id="handy_app" value="ハンディ APP&#xa;(React Native)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="90" y="170" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sqlite_cyl" value="SQLite+SQLCipher" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="90" y="280" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ble_label" value="BLE" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="90" y="410" width="220" height="36" as="geometry" />
        </mxCell>

        <!-- サーバー層 (middle, orange) -->
        <mxCell id="server_box" value="サーバー層" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="440" y="100" width="320" height="560" as="geometry" />
        </mxCell>
        <mxCell id="rust_axum" value="Rust axum API" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="480" y="170" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pg_cyl" value="PostgreSQL 16" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="480" y="280" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="docker_label" value="Docker Compose" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="480" y="410" width="240" height="36" as="geometry" />
        </mxCell>

        <!-- クライアント層 (right, green) -->
        <mxCell id="client_box" value="クライアント層" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="850" y="100" width="300" height="560" as="geometry" />
        </mxCell>
        <mxCell id="master_app" value="マスタメンテ APP&#xa;(React)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="885" y="200" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="admin_app" value="管理コンソール&#xa;(React)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="885" y="340" width="230" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow: Field -> Server (WiFi/TLS 1.3) -->
        <!-- Route goes between boxes at y=460, avoiding internal elements -->
        <mxCell id="edge_field_server" value="WiFi / TLS 1.3" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1" source="field_box" target="server_box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="350" y="680" />
              <mxPoint x="440" y="680" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Arrow: Server -> Client (LAN/HTTPS) -->
        <mxCell id="edge_server_client" value="LAN / HTTPS" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" parent="1" source="server_box" target="client_box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="680" />
              <mxPoint x="850" y="680" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

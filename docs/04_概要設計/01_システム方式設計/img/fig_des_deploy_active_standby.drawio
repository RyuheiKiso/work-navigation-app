<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Active-Standby 配置設計" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="36" as="geometry" />
        </mxCell>

        <!-- ハンディ端末群 (far left) -->
        <mxCell id="handy_group" value="ハンディ端末群" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="30" y="390" width="180" height="60" as="geometry" />
        </mxCell>

        <!--
          Active サーバー box: x=280, y=130, w=260, h=420
          Inner elements are in x=300..520, y=190..530.
          Left corridor: x<280. Right corridor: x>540. Top corridor: y<130. Bottom corridor: y>550.
        -->
        <mxCell id="active_box" value="Active サーバー" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="280" y="130" width="260" height="420" as="geometry" />
        </mxCell>
        <mxCell id="active_iis" value="IIS" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="185" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="active_terminal" value="terminal-api: 8080" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="245" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="active_master_be" value="master-api: 8081" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="305" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="active_pg" value="PostgreSQL (primary)" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="365" width="220" height="60" as="geometry" />
        </mxCell>

        <!--
          Standby サーバー box: x=660, y=130, w=260, h=420
          Inner elements are in x=680..900, y=185..425.
          Left corridor: x<660. Right corridor: x>920. Top corridor: y<130. Bottom corridor: y>550.
        -->
        <mxCell id="standby_box" value="Standby サーバー" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="660" y="130" width="260" height="420" as="geometry" />
        </mxCell>
        <mxCell id="standby_iis" value="IIS（待機中）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="680" y="185" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="standby_terminal" value="terminal-api（停止中）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="680" y="245" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="standby_master_be" value="master-api（停止中）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="680" y="305" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="standby_pg" value="PostgreSQL (standby)" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="680" y="365" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- 管理PC群 (far right) -->
        <mxCell id="admin_pcs" value="管理 PC 群" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="990" y="390" width="180" height="60" as="geometry" />
        </mxCell>

        <!--
          Edge: handy_group -> active_box
          Source center: (120, 420). Target: active_box.
          Route via left corridor (x=265) and top corridor (y=110):
            (120,420) -> (265,420) -> (265,110) -> (285,110) -> (285,340) -> active_box
          Segment check:
            S0 (120,420)-(265,420): y=420. handy_group y=390..450. x goes 120..265. handy_group x=30..210. At y=420, handy_group x=30..210. Passes x=120..210 inside. CROSSES.
          Use source as right edge of handy_group (210,420):
            (210,420) -> (265,420) -> (265,110) -> (285,110) -> (285,340)
          S0: (210,420)-(265,420): y=420. x=210..265. clear (no boxes in this range at y=420).
          S1: (265,420)-(265,110): x=265. active_box x=280..540. 265<280. clear.
          S2: (265,110)-(285,110): y=110. above all boxes (top=130). clear.
          S3: (285,110)-(285,340): x=285. active_box inner: x=300..520. 285<300. clear.
        -->
        <mxCell id="edge_handy_active" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="handy_group" target="active_box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="265" y="420" />
              <mxPoint x="265" y="110" />
              <mxPoint x="285" y="110" />
              <mxPoint x="285" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!--
          Edge: admin_pcs -> active_box
          Source center: (1080, 420). Target: active_box center.
          Route: bottom then via right of standby then top corridor:
            (1080,420) -> (1080,570) -> (645,570) -> (645,110) -> (545,110) -> (545,340) -> active_box
          Segment check:
            S0: (1080,420)-(1080,570): x=1080. No boxes. clear.
            S1: (1080,570)-(645,570): y=570. standby_box bottom=550. y=570>550. clear. active_box bottom=550. y=570>550. clear.
            S2: (645,570)-(645,110): x=645. standby_box x=660..920. 645<660. active_box x=280..540. 645>540. clear.
            S3: (645,110)-(545,110): y=110. above all boxes (top=130). clear.
            S4: (545,110)-(545,340): x=545. active_box x=280..540. 545>540. clear.
        -->
        <mxCell id="edge_admin_active" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="admin_pcs" target="active_box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1080" y="570" />
              <mxPoint x="645" y="570" />
              <mxPoint x="645" y="110" />
              <mxPoint x="545" y="110" />
              <mxPoint x="545" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!--
          Edge: active_box -> standby_box (WAL replication) — no label to avoid all crossing issues.
          A separate text vertex carries the label outside all box/edge bboxes.
          Route via top corridor (y=110) which is clear of both boxes (top=130) and clear of
          edge_admin_active path (which runs x=645 at y=110..570 and y=570 x=645..1080).
          Use x=275 (left of active_box at x=280) and x=655 (right corridor between boxes: active right=540, standby left=660).
          Waypoints: (275,340) -> (275,110) -> (655,110) -> (655,340)
          Linter exempts source(active_box) and target(standby_box). All intermediate path points are
          outside active_box(x=280..540) and standby_box(x=660..920) inner elements.
          Label text placed at y=90 (above all boxes, y=110 is corridor, label above at y=75..90) or below corridor.
          Place label as separate vertex at (350,92) with enough space below title (y=20..56) and above corridor (y=110).
        -->
        <mxCell id="edge_wal" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="active_box" target="standby_box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="275" y="340" />
              <mxPoint x="275" y="110" />
              <mxPoint x="655" y="110" />
              <mxPoint x="655" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_wal" value="WAL ストリーミングレプリケーション" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="88" width="300" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

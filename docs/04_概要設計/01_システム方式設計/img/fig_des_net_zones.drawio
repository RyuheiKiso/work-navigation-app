<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="ネットワーク構成とゾーニング" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="36" as="geometry" />
        </mxCell>

        <!-- 工場 LAN (Wi-Fi) zone - left, yellow -->
        <mxCell id="factory_lan" value="工場 LAN (Wi-Fi)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="190" width="230" height="220" as="geometry" />
        </mxCell>
        <mxCell id="handy_icon" value="ハンディ端末群" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="85" y="275" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- サーバーゾーン - center, green — updated with 2 API entries -->
        <mxCell id="server_zone" value="サーバーゾーン" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="470" y="190" width="260" height="220" as="geometry" />
        </mxCell>
        <mxCell id="terminal_api_zone" value="terminal-api: 8080" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="495" y="255" width="210" height="35" as="geometry" />
        </mxCell>
        <mxCell id="master_api_zone" value="master-api: 8081" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="495" y="305" width="210" height="35" as="geometry" />
        </mxCell>

        <!-- 管理 LAN (有線) zone - right, blue -->
        <mxCell id="admin_lan" value="管理 LAN (有線)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="920" y="190" width="230" height="220" as="geometry" />
        </mxCell>
        <mxCell id="pc_icon" value="管理 PC 群" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="955" y="275" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- 外部接続 zone - top-center, dotted border -->
        <mxCell id="external_zone" value="外部接続" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="470" y="55" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="firewall_label" value="ファイアウォール" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="510" y="100" width="180" height="30" as="geometry" />
        </mxCell>

        <!-- OT ゾーン (永続禁止) - bottom, red fill -->
        <mxCell id="ot_zone" value="OT ゾーン (永続禁止)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;fillColor=#f8cecc;strokeColor=#333333;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="340" y="570" width="520" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ot_x_label" value="接続禁止" style="text;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="340" y="660" width="520" height="30" as="geometry" />
        </mxCell>

        <!--
          Arrow: factory_lan -> server_zone with label "→ terminal-api:8080"
          sourcePoint at factory_lan right boundary = (280, 300)
          targetPoint at server_zone left boundary = (470, 300)
          Route: direct horizontal, no inner elements in x=280..470 at y=300.
          Label width: "terminal-api:8080" ~17 chars → ~204px approx. dist=190px.
          Label is short enough to place separately below the arrow.
          Use no label on edge; add a text label vertex instead.
        -->
        <mxCell id="edge_factory_server" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="280" y="300" as="sourcePoint" />
            <mxPoint x="470" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_factory_server" value="→ terminal-api:8080" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="280" y="308" width="190" height="20" as="geometry" />
        </mxCell>

        <!--
          Arrow: server_zone -> admin_lan with label "← master-api:8081"
          sourcePoint at server_zone right boundary = (730, 300)
          targetPoint at admin_lan left boundary = (920, 300)
          Route: direct horizontal, clear in x=730..920 at y=300.
        -->
        <mxCell id="edge_server_admin" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="300" as="sourcePoint" />
            <mxPoint x="920" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_server_admin" value="→ master-api:8081" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="730" y="308" width="190" height="20" as="geometry" />
        </mxCell>

        <!--
          Arrow: external_zone -> server_zone (top)
          external_zone bottom: (600, 155). server_zone top: (600, 190).
          Direct vertical, short path.
        -->
        <mxCell id="edge_external_server" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="600" y="155" as="sourcePoint" />
            <mxPoint x="600" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Thick wall / barrier between OT zone and others (visual only) -->
        <mxCell id="ot_wall_label" value="━━━━ 接続禁止境界 ━━━━" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="340" y="535" width="520" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile>
  <diagram name="データフロー図（概要）" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="920" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- 白背景必須 -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1400" height="920" as="geometry" />
        </mxCell>
        <mxCell id="title" value="データフロー図（概要）— バックエンド 2 バイナリ構成" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="340" y="16" width="720" height="32" as="geometry" />
        </mxCell>

        <!--
          レイアウト方針（左→右・上→下）:
          col A (x=40-180):   外部エンティティ（ハンディ APP / マスタメンテ UI）
          col B (x=240-380):  入力プロセス（P1 Step実行 / P2 写真撮影 / P3 マスタ同期）
          col C (x=480-700):  バックエンドバイナリ枠（terminal-api 上段 / master-api 下段）
          col D (x=760-920):  出力プロセス（P4 Outbox / P5 バックアップ / P6 監査照会）
          col E (x=980-1180): データストア（work_events / Outbox / evidence_files / SOPs / audit_logs）
          col F (x=1220-1380):外部エンティティ（外部システム / バックアップストレージ）
        -->

        <!-- ===== 外部エンティティ ===== -->
        <mxCell id="handy" value="ハンディ APP" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="master_ui" value="マスタメンテ UI" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ext_sys" value="外部システム&#xa;（親機）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="1220" y="100" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="backup_store" value="バックアップ&#xa;ストレージ（NAS）" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="1220" y="760" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- ===== 入力プロセス（col B）===== -->
        <!-- P1: Step実行 (y=80 + 30 = center 110) -->
        <mxCell id="p1" value="P1&#xa;Step 実行" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="60" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- P2: 写真撮影 (center y=260) -->
        <mxCell id="p2" value="P2&#xa;写真撮影" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- P3: マスタ同期 (center y=590) -->
        <mxCell id="p3" value="P3&#xa;マスタ同期" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="240" y="560" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- ===== バックエンドバイナリ枠（col C）===== -->
        <!-- terminal-api (y=80..340 center 210) -->
        <mxCell id="terminal_api" value="terminal-api&#xa;（Rust/axum, 8080）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#d79b00;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="480" y="120" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- master-api (y=540..680 center 600) -->
        <mxCell id="master_api" value="master-api&#xa;（Rust/axum, 8081）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#6c8ebf;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="480" y="560" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- ===== 出力プロセス（col D）===== -->
        <!-- P4: Outbox Consumer tokio task (center y=150) -->
        <mxCell id="p4" value="P4&#xa;Outbox 送信&#xa;(tokio task)" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="760" y="80" width="130" height="90" as="geometry" />
        </mxCell>

        <!-- P6: 監査照会 (center y=590) -->
        <mxCell id="p6" value="P6&#xa;監査照会&#xa;XES エクスポート" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="760" y="560" width="130" height="90" as="geometry" />
        </mxCell>

        <!-- P5: バックアップ (center y=790) -->
        <mxCell id="p5" value="P5&#xa;バックアップ" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="760" y="760" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- ===== データストア（col E）===== -->
        <!-- work_events y=80 -->
        <mxCell id="ds_wevents" value="work_events&#xa;(TBL-001)" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="980" y="80" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Outbox y=160 -->
        <mxCell id="ds_outbox" value="Outbox&#xa;(TBL-003)" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="980" y="168" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- evidence_files y=250 -->
        <mxCell id="ds_evfiles" value="evidence_files&#xa;(TBL-009)" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="980" y="256" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- SOPs y=560 -->
        <mxCell id="ds_sops" value="SOPs / steps" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="980" y="556" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- audit_logs y=640 -->
        <mxCell id="ds_audit" value="audit_logs&#xa;(TBL-032)" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="980" y="644" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- ===== フロー矢印 ===== -->

        <!-- 1. handy → p1（作業記録） -->
        <!-- handy: right=180, y_mid=110. p1: left=240, y_mid=100 -->
        <mxCell id="ef01" value="作業記録" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="handy" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="210" y="100" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 2. handy → p2（写真撮影） -->
        <!-- handy: right=180, y_mid=110. p2: left=240, y_mid=240 -->
        <mxCell id="ef02" value="写真" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="handy" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="210" y="130" />
              <mxPoint x="210" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 3. p1 → terminal_api -->
        <!-- p1: right=360, y_mid=100. terminal_api: left=480, y_mid=150 -->
        <mxCell id="ef03" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="p1" target="terminal_api" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="420" y="100" />
              <mxPoint x="420" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 4. p2 → terminal_api -->
        <!-- p2: right=360, y_mid=240. terminal_api: left=480, y_mid=150 -->
        <mxCell id="ef04" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="p2" target="terminal_api" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="440" y="240" />
              <mxPoint x="440" y="160" />
              <mxPoint x="480" y="155" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 5. terminal_api → ds_wevents（work_events INSERT） -->
        <!-- terminal_api: right=680, y_mid=150. ds_wevents: left=980, y_mid=105 -->
        <!-- Route: go right of p4 (p4 bbox: x=760..890, y=80..170) -->
        <!-- Pass above p4: y=70, then right to ds_wevents -->
        <mxCell id="ef05" value="INSERT" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="terminal_api" target="ds_wevents" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="130" />
              <mxPoint x="750" y="70" />
              <mxPoint x="940" y="70" />
              <mxPoint x="940" y="105" />
              <mxPoint x="980" y="105" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 6. terminal_api → ds_outbox（Outbox INSERT） -->
        <!-- Route: go right below p4 (p4 bottom=170), pass at y=200, then to ds_outbox y=193 -->
        <mxCell id="ef06" value="INSERT&#xa;(Outbox)" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="terminal_api" target="ds_outbox" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="155" />
              <mxPoint x="750" y="200" />
              <mxPoint x="940" y="200" />
              <mxPoint x="940" y="193" />
              <mxPoint x="980" y="193" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 7. terminal_api → ds_evfiles（evidence_files INSERT） -->
        <!-- ds_evfiles: left=980, y_mid=281. Route at y=280 below ds_outbox -->
        <mxCell id="ef07" value="INSERT" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="terminal_api" target="ds_evfiles" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="160" />
              <mxPoint x="750" y="280" />
              <mxPoint x="980" y="281" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 8. terminal_api → p4（Outbox Consumer tokio task） -->
        <!-- p4: left=760, y_mid=125. terminal_api: right=680, y_mid=150 -->
        <mxCell id="ef08" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="terminal_api" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="720" y="140" />
              <mxPoint x="730" y="125" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 9. p4 → ext_sys（IF-002 HMAC-SHA256） -->
        <!-- p4: right=890, y_mid=125. ext_sys: left=1220, y_mid=130 -->
        <!-- ds_wevents bbox: x=980..1140, y=80..130 -->
        <!-- Route: go above ds_wevents top (y=60), across to x=1200, then down to ext_sys y=130 -->
        <mxCell id="ef09" value="IF-002&#xa;HMAC-SHA256" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="p4" target="ext_sys" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="825" y="80" />
              <mxPoint x="825" y="50" />
              <mxPoint x="1200" y="50" />
              <mxPoint x="1200" y="130" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 10. terminal_api → ds_audit (audit_role INSERT) -->
        <!-- ds_audit: left=980, y_mid=669. terminal_api y_mid=150 -->
        <!-- ds_outbox bbox: x=980..1140, y=168..218 — must not cross -->
        <!-- Route: go right from terminal_api at y=180, but pass below ds_outbox (bottom=218) -->
        <!-- then travel along x=1190 (right of all data stores right=1140), down to y=669, left to ds_audit -->
        <mxCell id="ef10" value="INSERT (audit_role)" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="terminal_api" target="ds_audit" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="178" />
              <mxPoint x="750" y="240" />
              <mxPoint x="1190" y="240" />
              <mxPoint x="1190" y="669" />
              <mxPoint x="1140" y="669" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 11. master_ui → p3 -->
        <mxCell id="ef11" value="マスタ操作" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="master_ui" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="210" y="590" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 12. p3 → master_api -->
        <!-- p3: right=360, y_mid=600. master_api: left=480, y_mid=590 -->
        <mxCell id="ef12" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="p3" target="master_api" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="420" y="595" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 13. master_api → ds_sops（マスタ配信） -->
        <!-- master_api: right=680, y_mid=590. ds_sops: left=980, y_mid=581 -->
        <!-- Route: must avoid p6 (x=760..890, y=560..650) -->
        <!-- Go above p6: y=540 (above p6 top=560) -->
        <mxCell id="ef13" value="配信" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="master_api" target="ds_sops" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="570" />
              <mxPoint x="700" y="540" />
              <mxPoint x="960" y="540" />
              <mxPoint x="960" y="581" />
              <mxPoint x="980" y="581" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 14. master_api → p6（監査照会処理） -->
        <!-- master_api: right=680, y_mid=590. p6: left=760, y_mid=605 -->
        <mxCell id="ef14" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="master_api" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="720" y="595" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 15. p6 → ds_audit（SELECT app_read） -->
        <!-- p6: right=890, y_mid=605. ds_audit: left=980, y_mid=669 -->
        <!-- Route: avoid ds_sops (right=1140, y=556..606) — route below ds_sops -->
        <mxCell id="ef15" value="SELECT (app_read)" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="p6" target="ds_audit" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="920" y="640" />
              <mxPoint x="960" y="669" />
              <mxPoint x="980" y="669" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 16. master_api → handy（マスタ同期返却） -->
        <!-- master_api: left=480, y_mid=590. handy: right=180, y_mid=110 -->
        <!-- handy bbox: x=40..180, y=80..140. master_ui bbox: x=40..180, y=560..620. p3 bbox: x=240..360, y=560..640 -->
        <!-- Route: go up from master_api (between y layers), pass between p3-bottom (640) and handy (80) -->
        <!-- Use x=220 (between handy/master_ui right=180 and p3 left=240) for vertical segment -->
        <mxCell id="ef16" value="マスタ同期 返却" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="master_api" target="handy" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="480" y="560" />
              <mxPoint x="220" y="560" />
              <mxPoint x="220" y="380" />
              <mxPoint x="200" y="380" />
              <mxPoint x="200" y="110" />
              <mxPoint x="180" y="110" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 17. ds_wevents → p5（バックアップ対象） -->
        <!-- ds_wevents: y_mid=105. p5: left=760, y_mid=800 -->
        <!-- Route: right side x=1185, down to y=800, left to p5 -->
        <mxCell id="ef17" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="ds_wevents" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1185" y="105" />
              <mxPoint x="1185" y="800" />
              <mxPoint x="880" y="800" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 18. p5 → backup_store -->
        <!-- p5: right=880, y_mid=800. backup_store: left=1220, y_mid=790 -->
        <mxCell id="ef18" value="WAL / pg_dump" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;fontFamily=Helvetica;fontSize=11;fontColor=#333333;" edge="1" source="p5" target="backup_store" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1000" y="800" />
              <mxPoint x="1200" y="790" />
              <mxPoint x="1220" y="790" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile>
  <diagram name="fig_des_tst_rtm_flow" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="テスト結果の RTM / DTM 反映フロー" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="36" as="geometry" />
        </mxCell>

        <!-- Step 1: Test Case -->
        <mxCell id="tst-case" value="テストケース&#xa;TST-NNN" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- Step 2: PASSED decision -->
        <mxCell id="passed" value="PASSED?" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="330" y="325" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Step 3: RTM FR status=TESTED -->
        <mxCell id="rtm-fr" value="RTM 更新&#xa;FR ステータス&#xa;= TESTED" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="570" y="330" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Step 4: DTM M5 NFR verified -->
        <mxCell id="dtm-m5" value="DTM 更新&#xa;M5 NFR&#xa;verified ✓" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="870" y="330" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- FAILED path: reopen -->
        <mxCell id="failed-box" value="バグ登録&#xa;(FAILED → 再テスト)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="330" y="520" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow: tst-case -> passed -->
        <mxCell id="e1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="375" as="sourcePoint" />
            <mxPoint x="330" y="375" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: passed -> rtm-fr (YES) -->
        <mxCell id="e2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="470" y="375" as="sourcePoint" />
            <mxPoint x="570" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl-yes" value="YES" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="490" y="352" width="40" height="20" as="geometry" />
        </mxCell>

        <!-- Arrow: rtm-fr -> dtm-m5 -->
        <mxCell id="e3" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="750" y="370" as="sourcePoint" />
            <mxPoint x="870" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: passed -> failed-box (NO) -->
        <mxCell id="e4" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="400" y="425" as="sourcePoint" />
            <mxPoint x="400" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl-no" value="NO" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="408" y="456" width="30" height="20" as="geometry" />
        </mxCell>

        <!-- Arrow: failed-box -> tst-case (loop back) -->
        <mxCell id="e5" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="555" as="sourcePoint" />
            <mxPoint x="160" y="555" as="targetPoint" />
            <Array as="points">
              <mxPoint x="160" y="555" />
              <mxPoint x="160" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl-retry" value="修正・再実施" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="170" y="538" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- Supplementary notes -->
        <mxCell id="note-rtm" value="RTM: 要求トレーサビリティマトリクス&#xa;FR = 機能要件" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="570" y="450" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="note-dtm" value="DTM: 設計トレーサビリティマトリクス&#xa;M5 = マイルストーン5 NFR検証完了" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=left;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="870" y="450" width="280" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

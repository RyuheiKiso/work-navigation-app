<mxfile>
  <diagram name="fig_des_tst_quality_gate" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="品質ゲートと完成条件" style="text;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="36" as="geometry" />
        </mxCell>

        <!-- Code node -->
        <mxCell id="code" value="Code" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 1: unit coverage -->
        <mxCell id="g1" value="Unit Coverage&#xa;≥80%" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="250" y="200" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 2: integration coverage -->
        <mxCell id="g2" value="Integration&#xa;Coverage ≥60%" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="430" y="200" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 3: CVSS -->
        <mxCell id="g3" value="CVSS = 0&#xa;(High以上なし)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="610" y="200" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 4: Lint -->
        <mxCell id="g4" value="Lint = 0&#xa;(警告ゼロ)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="250" y="520" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 5: Schemathesis -->
        <mxCell id="g5" value="Schemathesis&#xa;= 100%" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="430" y="520" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Gate 6: P95 -->
        <mxCell id="g6" value="P95 ≤ 2000ms&#xa;(性能基準)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="610" y="520" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- Gate funnel box (visual frame) -->
        <mxCell id="gate-frame" value="品質ゲート チェック" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=none;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="220" y="160" width="560" height="450" as="geometry" />
        </mxCell>

        <!-- Merge OK node -->
        <mxCell id="merge" value="Merge OK" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="1020" y="360" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow: Code -> gate-frame (entry) -->
        <mxCell id="e-code-gate" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="390" as="sourcePoint" />
            <mxPoint x="220" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: gate-frame -> Merge OK (exit) -->
        <mxCell id="e-gate-merge" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="780" y="390" as="sourcePoint" />
            <mxPoint x="1020" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Label on gate exit arrow -->
        <mxCell id="lbl-all-pass" value="全チェック PASS" style="text;html=1;fontFamily=Helvetica;fontSize=11;align=center;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="810" y="365" width="120" height="24" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

        <!-- Note about scope -->
        <mxCell id="note1" value="対象: マスタメンテナンス (React + Vite)" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=2;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">

        <mxCell id="lbl5" value="Step 5" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="820" y="340" width="140" height="20" as="geometry" />

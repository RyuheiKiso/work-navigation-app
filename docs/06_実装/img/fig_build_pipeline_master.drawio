<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Vite ビルドパイプライン (Master)" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="14" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="s1" value="openapi-generator-cli generate&#xa;(APIクライアント自動生成)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="160" height="56" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="s2" value="pnpm type-check&#xa;(tsc)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="250" y="360" width="140" height="56" as="geometry" />
        </mxCell>

        <!-- Step 3 -->

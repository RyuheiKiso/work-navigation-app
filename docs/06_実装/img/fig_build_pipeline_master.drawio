          <mxGeometry x="630" y="360" width="140" height="56" as="geometry" />
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="s5" value="pnpm build&#xa;(Vite)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="820" y="360" width="140" height="56" as="geometry" />
        </mxCell>

        <!-- Step 6: dist artifact -->
        <mxCell id="s6" value="dist/&#xa;静的成果物" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;fixedSize=1;" vertex="1" parent="1">
          <mxGeometry x="1010" y="360" width="130" height="56" as="geometry" />
        </mxCell>

        <!-- Step 7: IIS -->
        <mxCell id="s7" value="IIS 配信" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="1010" y="500" width="130" height="44" as="geometry" />
        </mxCell>

        <!-- Arrow labels row -->
        <!-- s1 -> s2 -->
        <mxCell id="e1" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- s2 -> s3 -->
        <mxCell id="e2" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="s2" target="s3" parent="1">

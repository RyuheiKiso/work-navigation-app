        <mxCell id="lbl3" value="Step 3" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="440" y="340" width="140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl4" value="Step 4" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="630" y="340" width="140" height="20" as="geometry" />

          <mxGeometry x="40" y="340" width="160" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl2" value="Step 2" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">

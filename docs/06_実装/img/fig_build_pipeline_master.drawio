          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- s6 -> s7 (down) -->
        <mxCell id="e6" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="s6" target="s7" parent="1">

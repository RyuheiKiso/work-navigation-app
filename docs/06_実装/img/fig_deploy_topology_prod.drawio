<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="本番デプロイトポロジ" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="14" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- Client Layer label -->
        <mxCell id="layer_client_lbl" value="クライアント層" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="180" height="24" as="geometry" />
        </mxCell>

        <!-- Client: Handy tablet -->
        <mxCell id="handy" value="ハンディタブレット&#xa;(Android / iOS / Windows)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="92" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- Client: Web browser -->
        <mxCell id="browser" value="マスタメンテ&#xa;Web ブラウザ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- Windows Server 2022 box -->
        <mxCell id="win_server" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="820" height="480" as="geometry" />
        </mxCell>
        <mxCell id="win_server_lbl" value="Windows Server 2022 (Primary)" style="text;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=left;" vertex="1" parent="1">
          <mxGeometry x="312" y="68" width="340" height="24" as="geometry" />
        </mxCell>

        <!-- IIS box -->
        <mxCell id="iis" value="IIS&#xa;マスタメンテ SPA 配信" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="340" y="100" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- WSL2 box -->
        <mxCell id="wsl2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="180" width="740" height="320" as="geometry" />
        </mxCell>
        <mxCell id="wsl2_lbl" value="WSL2 (Docker)" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;fillColor=none;strokeColor=none;align=left;" vertex="1" parent="1">
          <mxGeometry x="352" y="188" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- nginx -->
        <mxCell id="nginx" value="nginx&#xa;(TLS 終端)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="380" y="220" width="160" height="56" as="geometry" />
        </mxCell>

        <!-- Backend API -->
        <mxCell id="api" value="バックエンド API&#xa;(Docker: Rust + axum)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="620" y="220" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- PostgreSQL -->
        <mxCell id="pg" value="PostgreSQL&#xa;(Docker volume)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="900" y="220" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- Standby server box -->
        <mxCell id="standby" value="Windows Server 2022 (Standby)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="580" width="820" height="56" as="geometry" />
        </mxCell>

        <!-- Offline note -->
        <mxCell id="offline_note" value="縮退モード: ハンディは Offline-First で継続稼働可能（SQLite ローカル）" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontStyle=2;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="660" width="800" height="24" as="geometry" />
        </mxCell>

        <!-- Edges: client -> IIS (browser) -->
        <mxCell id="e_br_iis" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="browser" target="iis" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="198" />
              <mxPoint x="320" y="198" />
              <mxPoint x="320" y="128" />
              <mxPoint x="340" y="128" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_br_iis" value="HTTPS" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="180" y="148" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- Edges: client -> nginx (handy) -->
        <mxCell id="e_hnd_ng" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="handy" target="nginx" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="120" />
              <mxPoint x="320" y="120" />
              <mxPoint x="320" y="248" />
              <mxPoint x="380" y="248" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_hnd_ng" value="HTTPS/API" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="180" y="240" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- nginx -> api -->
        <mxCell id="e_ng_api" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="nginx" target="api" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="248" />
              <mxPoint x="600" y="248" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- api -> pg -->
        <mxCell id="e_api_pg" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="api" target="pg" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="870" y="248" />
              <mxPoint x="880" y="248" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Primary -> Standby -->
        <mxCell id="e_as" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;dashed=1;" edge="1" source="win_server" target="standby" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="560" />
              <mxPoint x="710" y="570" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_as" value="Active-Standby フェイルオーバー" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="500" y="640" width="240" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

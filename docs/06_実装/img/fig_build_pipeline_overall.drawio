        <!-- Subsystems → SBOM -->
        <mxCell id="e_rust_sbom" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="sub_rust" target="int_sbom">

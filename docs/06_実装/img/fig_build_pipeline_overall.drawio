        <!-- SBOM → cosign → push -->
        <mxCell id="e_sc" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="int_sbom" target="int_cosign">

        <!-- Source trigger -->
        <mxCell id="src" value="PR / main push" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="140" height="40" as="geometry" />
        </mxCell>

        <!-- 4 subsystems (parallel) -->
        <!-- backend (Rust) -->
        <mxCell id="sub_rust" value="backend (Rust)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="280" y="160" width="200" height="40" as="geometry" />

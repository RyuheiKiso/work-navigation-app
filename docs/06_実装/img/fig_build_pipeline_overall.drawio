        <!-- infra (Docker + IIS) -->
        <mxCell id="sub_infra" value="infra (Docker + IIS)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="280" y="580" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- Integration steps (right side) -->
        <mxCell id="int_sbom" value="SBOM 生成" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="680" y="300" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="int_cosign" value="cosign 署名" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="680" y="380" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="int_push" value="artifacts push&#xa;to ghcr.io" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="680" y="460" width="140" height="44" as="geometry" />
        </mxCell>

        <!-- Edges: source → subsystems -->
        <mxCell id="e_s_rust" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="src" target="sub_rust">
          <mxGeometry relative="1" as="geometry">

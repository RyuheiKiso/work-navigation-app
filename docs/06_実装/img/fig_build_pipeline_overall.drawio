        </mxCell>
        <mxCell id="title" value="ビルドパイプライン全体" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="14" width="400" height="32" as="geometry" />

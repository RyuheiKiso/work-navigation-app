        <mxCell id="e_master_sbom" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="sub_master" target="int_sbom">
          <mxGeometry relative="1" as="geometry">

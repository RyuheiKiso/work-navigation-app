          <mxGeometry x="280" y="300" width="200" height="40" as="geometry" />
        </mxCell>
        <!-- master (React + Vite) -->
        <mxCell id="sub_master" value="master (React + Vite)" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="280" y="440" width="200" height="40" as="geometry" />

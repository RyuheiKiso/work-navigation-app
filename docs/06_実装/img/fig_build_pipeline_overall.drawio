        <mxCell id="e_s_handy" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="src" target="sub_handy">
          <mxGeometry relative="1" as="geometry">

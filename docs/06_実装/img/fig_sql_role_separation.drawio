<mxfile>
  <diagram name="fig_sql_role_separation" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="DB ロール 3 分離図" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="14" width="400" height="32" as="geometry" />
        </mxCell>

        <!-- PostgreSQL DB (center) -->
        <mxCell id="pg_db" value="PostgreSQL" style="shape=cylinder3;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=13;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#e1d5e7;boundedLbl=1;backgroundOutline=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="280" width="160" height="100" as="geometry" />
        </mxCell>

        <!-- Role boxes (left / center-top / right) -->
        <mxCell id="role_write" value="app_write ロール" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="role_write_perm" value="SELECT / INSERT / UPDATE&#xa;（マスタテーブルのみ）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="200" height="40" as="geometry" />
        </mxCell>

        <mxCell id="role_event" value="app_event_insert ロール" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="480" y="140" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="role_event_perm" value="INSERT ONLY&#xa;（work_events テーブル）&#xa;UPDATE/DELETE は REVOKE" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="450" y="60" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="role_read" value="app_read ロール" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontStyle=1;fontColor=#333333;strokeColor=#333333;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="920" y="280" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="role_read_perm" value="SELECT ONLY&#xa;（全テーブル）" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="920" y="340" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- Connection pool description -->
        <mxCell id="pool_box" value="接続プール分離&#xa;各ロールは独立した接続プールで管理&#xa;アプリは用途に応じたロールを使用する" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="360" y="560" width="400" height="60" as="geometry" />
        </mxCell>

        <!-- Edges: roles → DB (with waypoints to avoid crossing boxes) -->
        <mxCell id="e_write_db" value="接続" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="role_write" target="pg_db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="300" y="300" />
              <mxPoint x="490" y="300" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_event_db" value="接続" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="role_event" target="pg_db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="570" y="180" />
              <mxPoint x="570" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_read_db" value="接続" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="role_read" target="pg_db">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="920" y="300" />
              <mxPoint x="650" y="300" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- role_write_perm annotation -->
        <mxCell id="e_wp" value="" style="endArrow=none;html=1;strokeColor=#333333;dashed=1;" edge="1" parent="1" source="role_write" target="role_write_perm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- role_event_perm annotation -->
        <mxCell id="e_ep" value="" style="endArrow=none;html=1;strokeColor=#333333;dashed=1;" edge="1" parent="1" source="role_event" target="role_event_perm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- role_read_perm annotation -->
        <mxCell id="e_rp" value="" style="endArrow=none;html=1;strokeColor=#333333;dashed=1;" edge="1" parent="1" source="role_read" target="role_read_perm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- DB → pool_box -->
        <mxCell id="e_db_pool" value="" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" parent="1" source="pg_db" target="pool_box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="570" y="460" />
              <mxPoint x="560" y="560" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

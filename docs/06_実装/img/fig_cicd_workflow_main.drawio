<mxfile>
  <diagram name="title" id="page-1">
    <mxGraphModel dx="900" dy="620" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1200" height="800" as="geometry" />
        </mxCell>
        <mxCell id="title" value="メイン CI/CD ワークフロー（PR トリガー）" style="text;html=1;fontFamily=Helvetica;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="14" width="500" height="32" as="geometry" />
        </mxCell>

        <!-- PR open -->
        <mxCell id="pr_open" value="PR オープン" style="ellipse;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="520" y="60" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Parallel: lint + unit-test -->
        <mxCell id="par_lbl" value="並列実行" style="text;html=1;fontFamily=Helvetica;fontSize=10;fontStyle=2;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="520" y="135" width="160" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lint_job" value="lint ジョブ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="340" y="160" width="160" height="44" as="geometry" />
        </mxCell>

        <mxCell id="unit_job" value="unit-test ジョブ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="700" y="160" width="160" height="44" as="geometry" />
        </mxCell>

        <!-- build job (after lint + unit) -->
        <mxCell id="build_job" value="build ジョブ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="520" y="280" width="160" height="44" as="geometry" />
        </mxCell>

        <!-- integration-test (after build) -->
        <mxCell id="int_job" value="integration-test ジョブ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="520" y="390" width="160" height="44" as="geometry" />
        </mxCell>

        <!-- security-scan -->
        <mxCell id="sec_job" value="security-scan ジョブ" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="520" y="500" width="160" height="44" as="geometry" />
        </mxCell>

        <!-- Decision: all green? -->
        <mxCell id="all_green" value="全 green？" style="rhombus;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="500" y="600" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- YES: PR ready -->
        <mxCell id="pr_ready" value="PR ready" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="340" y="720" width="140" height="44" as="geometry" />
        </mxCell>

        <!-- NO: comment + fix -->
        <mxCell id="fix" value="コメント通知 → 修正" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;strokeColor=#333333;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="760" y="720" width="180" height="44" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <!-- pr_open -> lint (left) -->
        <mxCell id="e_pr_lint" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="pr_open" target="lint_job" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="130" />
              <mxPoint x="420" y="130" />
              <mxPoint x="420" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- pr_open -> unit-test (right) -->
        <mxCell id="e_pr_unit" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="pr_open" target="unit_job" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="130" />
              <mxPoint x="780" y="130" />
              <mxPoint x="780" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- lint -> build -->
        <mxCell id="e_lint_build" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="lint_job" target="build_job" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="420" y="240" />
              <mxPoint x="420" y="262" />
              <mxPoint x="520" y="262" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- unit -> build -->
        <mxCell id="e_unit_build" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="unit_job" target="build_job" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="780" y="240" />
              <mxPoint x="780" y="262" />
              <mxPoint x="680" y="262" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- build -> integration -->
        <mxCell id="e_build_int" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="build_job" target="int_job" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="358" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- integration -> security -->
        <mxCell id="e_int_sec" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="int_job" target="sec_job" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="468" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- security -> all_green -->
        <mxCell id="e_sec_gate" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="sec_job" target="all_green" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="578" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- all_green -> pr_ready (YES) -->
        <mxCell id="e_yes" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="all_green" target="pr_ready" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="635" />
              <mxPoint x="410" y="635" />
              <mxPoint x="410" y="720" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_yes" value="YES" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="444" y="658" width="40" height="20" as="geometry" />
        </mxCell>

        <!-- all_green -> fix (NO) -->
        <mxCell id="e_no" style="endArrow=classic;endFill=1;html=1;strokeColor=#333333;edgeStyle=none;" edge="1" source="all_green" target="fix" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="635" />
              <mxPoint x="850" y="635" />
              <mxPoint x="850" y="720" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="lbl_no" value="NO" style="text;html=1;fontFamily=Helvetica;fontSize=11;fontColor=#333333;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="712" y="658" width="40" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:wnav:schema:step_flow_rule_definition:v1",
  "title": "StepFlowRuleDefinition",
  "description": "JSON Logic 形式の条件式。TBL-030 step_flow_rules.rule_definition に保存する。StepEngine が現在ステップの入力結果を評価し、次ステップを決定するための条件分岐ルール。JSON Logic（https://jsonlogic.com/）仕様に準拠する。",
  "type": "object",
  "properties": {
    "condition": {
      "description": "JSON Logic 演算子ツリー。評価結果が true の場合このルールが適用される。null は常に true（デフォルト遷移）を意味する。",
      "oneOf": [
        {
          "description": "比較演算子（==, !=, >, >=, <, <=）— JSON Logic 2 項比較",
          "type": "object",
          "properties": {
            "==":  { "type": "array", "minItems": 2, "maxItems": 2 },
            "!=":  { "type": "array", "minItems": 2, "maxItems": 2 },
            ">":   { "type": "array", "minItems": 2, "maxItems": 2 },
            ">=":  { "type": "array", "minItems": 2, "maxItems": 2 },
            "<":   { "type": "array", "minItems": 2, "maxItems": 2 },
            "<=":  { "type": "array", "minItems": 2, "maxItems": 2 }
          },
          "maxProperties": 1
        },
        {
          "description": "論理演算子（and, or, !）— 複数条件の組み合わせ",
          "type": "object",
          "properties": {
            "and": { "type": "array", "minItems": 2 },
            "or":  { "type": "array", "minItems": 2 },
            "!":   {}
          },
          "maxProperties": 1
        },
        {
          "description": "変数参照（var）— payload のフィールドを参照する",
          "type": "object",
          "properties": {
            "var": {
              "type": "string",
              "description": "ドット区切りのパス。例: 'payload.value', 'payload.judgment'"
            }
          },
          "required": ["var"],
          "maxProperties": 1
        },
        {
          "description": "定数値または null（null は常に true = デフォルト遷移）",
          "type": ["null", "boolean", "number", "string"]
        }
      ]
    },
    "label": {
      "description": "このルールの人間可読ラベル。マスタ管理 UI でのルール一覧表示に使用する。",
      "type": "object",
      "properties": {
        "ja": {
          "type": "string",
          "minLength": 1,
          "description": "日本語ラベル（必須）"
        },
        "en": {
          "type": "string",
          "description": "英語ラベル（任意）"
        }
      },
      "required": ["ja"],
      "additionalProperties": false
    }
  },
  "required": ["condition"],
  "additionalProperties": false,
  "examples": [
    {
      "condition": { ">": [{ "var": "payload.value" }, 10.5] },
      "label": { "ja": "測定値が上限超過", "en": "Value exceeds USL" }
    },
    {
      "condition": {
        "and": [
          { ">=": [{ "var": "payload.value" }, 9.5] },
          { "<=": [{ "var": "payload.value" }, 10.5] }
        ]
      },
      "label": { "ja": "測定値が規格内（OK ルート）", "en": "Value within spec" }
    },
    {
      "condition": { "==": [{ "var": "payload.judgment" }, "NG"] },
      "label": { "ja": "判定 NG — リワークへ分岐", "en": "NG judgment — branch to rework" }
    },
    {
      "condition": null,
      "label": { "ja": "常に適用（デフォルト遷移）", "en": "Always apply (default)" }
    }
  ]
}

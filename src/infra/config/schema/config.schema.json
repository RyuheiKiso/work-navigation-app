{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wnav.example.local/config.schema.json",
  "title": "WNAV Config Schema",
  "description": "WNAV バックエンド・インフラ設定の JSON Schema。config.base.yml および config.{profile}.yml の構造バリデーションに使用する。",
  "type": "object",
  "required": ["schema_version", "profile"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "YAML 構造の版。breaking change 時に 2 へ昇格し、旧版は起動時エラーとなる。"
    },
    "profile": {
      "type": "string",
      "enum": ["base", "local", "dev", "staging", "prod"],
      "description": "プロファイル名（WNAV_PROFILE 環境変数で選択）。"
    },
    "server": {
      "$ref": "#/$defs/ServerConfig"
    },
    "database": {
      "$ref": "#/$defs/DatabaseConfig"
    },
    "cors": {
      "$ref": "#/$defs/CorsConfig"
    },
    "jwt": {
      "$ref": "#/$defs/JwtConfig"
    },
    "idempotency": {
      "$ref": "#/$defs/IdempotencyConfig"
    },
    "outbox": {
      "$ref": "#/$defs/OutboxConfig"
    },
    "hash_chain_verify": {
      "$ref": "#/$defs/HashChainVerifyConfig"
    },
    "rate_limit": {
      "$ref": "#/$defs/RateLimitConfig"
    },
    "observability": {
      "$ref": "#/$defs/ObservabilityConfig"
    },
    "webhook": {
      "$ref": "#/$defs/WebhookConfig"
    },
    "external": {
      "$ref": "#/$defs/ExternalConfig"
    },
    "frontend": {
      "$ref": "#/$defs/FrontendConfig"
    },
    "infra": {
      "$ref": "#/$defs/InfraConfig"
    }
  },
  "$defs": {
    "SecretRef": {
      "type": "object",
      "description": "機密値の間接参照。secret_ref: '<scheme>:<id>' 形式で env / dpapi / docker_secret / file から取得する。",
      "required": ["secret_ref"],
      "additionalProperties": false,
      "properties": {
        "secret_ref": {
          "type": "string",
          "pattern": "^(env|dpapi|docker_secret|file):.+$",
          "description": "scheme:id 形式。env:VAR_NAME / dpapi:KEY / docker_secret:NAME / file:/path"
        }
      }
    },
    "ServerBinaryConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bind_addr": {
          "type": "string",
          "description": "バインドアドレス（0.0.0.0 または 127.0.0.1 等）"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "request_timeout_sec": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "ServerConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "terminal_api": { "$ref": "#/$defs/ServerBinaryConfig" },
        "master_api": { "$ref": "#/$defs/ServerBinaryConfig" }
      }
    },
    "DbRoleConfig": {
      "type": "object",
      "required": ["user", "password"],
      "additionalProperties": false,
      "properties": {
        "user": { "type": "string" },
        "password": { "$ref": "#/$defs/SecretRef" }
      }
    },
    "DatabaseConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "name": { "type": "string" },
        "ssl_mode": {
          "type": "string",
          "enum": ["require", "prefer", "disable"]
        },
        "max_connections": { "type": "integer", "minimum": 1 },
        "min_connections": { "type": "integer", "minimum": 0 },
        "acquire_timeout_sec": { "type": "integer", "minimum": 1 },
        "idle_timeout_sec": { "type": "integer", "minimum": 0 },
        "max_lifetime_sec": { "type": "integer", "minimum": 0 },
        "write": { "$ref": "#/$defs/DbRoleConfig" },
        "event_insert": { "$ref": "#/$defs/DbRoleConfig" },
        "read": { "$ref": "#/$defs/DbRoleConfig" }
      }
    },
    "CorsConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_origins": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "allow_credentials": { "type": "boolean" },
        "max_age_sec": { "type": "integer", "minimum": 0 }
      }
    },
    "JwtConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "RS256"
        },
        "ttl_sec": {
          "type": "integer",
          "minimum": 60,
          "description": "最小 60 秒。8h = 28800 秒を標準値とする。"
        },
        "public_key": { "$ref": "#/$defs/SecretRef" },
        "private_key": { "$ref": "#/$defs/SecretRef" }
      }
    },
    "IdempotencyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ttl_sec": { "type": "integer", "minimum": 3600 }
      }
    },
    "OutboxConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interval_ms": { "type": "integer", "minimum": 100 },
        "retry_max": { "type": "integer", "minimum": 1 },
        "backoff_max_sec": { "type": "integer", "minimum": 1 }
      }
    },
    "HashChainVerifyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cron": {
          "type": "string",
          "description": "cron 式（5 フィールド）。例: '0 2 * * *'"
        }
      }
    },
    "RateLimitConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rps": { "type": "integer", "minimum": 1 },
        "burst": { "type": "integer", "minimum": 1 }
      }
    },
    "ObservabilityConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "log_level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"]
        },
        "log_format": {
          "type": "string",
          "enum": ["json", "pretty"]
        },
        "request_id_header": { "type": "string" },
        "metrics_enabled": { "type": "boolean" },
        "metrics_path": { "type": "string" }
      }
    },
    "WebhookConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signature_header": { "type": "string" },
        "retry_max": { "type": "integer", "minimum": 1 },
        "retry_backoff_max_sec": { "type": "integer", "minimum": 1 },
        "hmac_key": { "$ref": "#/$defs/SecretRef" }
      }
    },
    "ExternalConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backup_notification_url": { "$ref": "#/$defs/SecretRef" }
      }
    },
    "FrontendHandyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_api_base_url": { "type": "string", "format": "uri" },
        "offline_timeout_min": { "type": "integer", "minimum": 1 },
        "sync_retry_max": { "type": "integer", "minimum": 1 }
      }
    },
    "FrontendMasterConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "api_base_url": { "type": "string", "format": "uri" },
        "openapi_url": { "type": "string", "format": "uri" },
        "session_timeout_min": { "type": "integer", "minimum": 1 },
        "polling_interval_ms": { "type": "integer", "minimum": 1000 }
      }
    },
    "FrontendConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "handy": { "$ref": "#/$defs/FrontendHandyConfig" },
        "master": { "$ref": "#/$defs/FrontendMasterConfig" }
      }
    },
    "InfraNginxConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "upstream_terminal": { "type": "string" },
        "upstream_master": { "type": "string" },
        "tls_cert_path": { "$ref": "#/$defs/SecretRef" },
        "tls_key_path": { "$ref": "#/$defs/SecretRef" }
      }
    },
    "InfraIisConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "site_name": { "type": "string" },
        "app_pool_name": { "type": "string" }
      }
    },
    "InfraBackupConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": { "type": "string" }
      }
    },
    "InfraNetworkConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_ips": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "InfraConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nginx": { "$ref": "#/$defs/InfraNginxConfig" },
        "iis": { "$ref": "#/$defs/InfraIisConfig" },
        "backup": { "$ref": "#/$defs/InfraBackupConfig" },
        "network": { "$ref": "#/$defs/InfraNetworkConfig" }
      }
    }
  }
}

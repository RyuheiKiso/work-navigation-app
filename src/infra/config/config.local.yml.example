# ============================================================
# WNAV 設定ファイル — local プロファイルのテンプレート
#
# このファイルを config.local.yml にコピーして開発環境を設定する:
#   cp config.local.yml.example config.local.yml
#
# config.local.yml は .gitignore で除外されている。
# 各開発者が自身の環境に合わせて値を変更してよい。
#
# 起動前に以下の環境変数を設定すること（.env ファイルに記載）:
#   WNAV_PROFILE=local
#   WNAV_DB_PASSWORD_WRITE=<dev_password>
#   WNAV_DB_PASSWORD_EVENT_INSERT=<dev_password>
#   WNAV_DB_PASSWORD_READ=<dev_password>
#   WNAV_BE_JWT_SECRET=<dev_private_key_pem>
#   WNAV_BE_JWT_PUBLIC_KEY=<dev_public_key_pem>
#   WNAV_BE_WEBHOOK_SECRET=<dev_hmac_secret>
# ============================================================

schema_version: 1
profile: local

server:
  terminal_api:
    bind_addr: "127.0.0.1"              # local では localhost のみ受付
    port: 8080
  master_api:
    bind_addr: "127.0.0.1"
    port: 8081

database:
  host: "localhost"
  port: 5432
  name: "wnav_local"
  ssl_mode: "disable"                   # local は TLS 不要

cors:
  allow_origins:
    - "http://localhost:5173"           # Vite dev server（マスタ SPA）
    - "http://localhost:3000"           # Expo dev server（ハンディ）
    - "http://localhost:19006"          # Expo web（ハンディ）

observability:
  log_level: "debug"

frontend:
  handy:
    default_api_base_url: "http://localhost:8080"
  master:
    api_base_url: "http://localhost:8081"
    openapi_url: "http://localhost:8081/api/openapi.json"

infra:
  backup:
    dir: "/tmp/wnav_backup"
  network:
    allowed_ips:
      - "127.0.0.1/32"
      - "192.168.0.0/16"

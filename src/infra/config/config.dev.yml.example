# ============================================================
# WNAV 設定ファイル — dev プロファイルのテンプレート
#
# このファイルを config.dev.yml にコピーして dev 環境を設定する:
#   cp config.dev.yml.example config.dev.yml
#
# config.dev.yml は .gitignore で除外されている。
# dev サーバーの実際のホスト名・ポートに合わせて変更する。
# ============================================================

schema_version: 1
profile: dev

server:
  master_api:
    bind_addr: "0.0.0.0"

database:
  host: "wnav-dev.example.local"        # dev DB サーバーの実ホスト名に変更
  name: "wnav_dev"
  ssl_mode: "prefer"

cors:
  allow_origins:
    - "https://wnav-dev.example.local"

observability:
  log_level: "debug"

frontend:
  handy:
    default_api_base_url: "https://wnav-dev.example.local"
  master:
    api_base_url: "https://wnav-dev.example.local"
    openapi_url: "https://wnav-dev.example.local/api/openapi.json"

infra:
  nginx:
    upstream_terminal: "127.0.0.1:8080"
    upstream_master: "127.0.0.1:8081"
  network:
    allowed_ips:
      - "192.168.10.0/24"

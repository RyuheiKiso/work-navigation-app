{
  "name": "@wnav/frontend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "master",
    "terminal"
  ],
  "scripts": {
    "gen:openapi": "npm run gen:openapi -w @wnav/shared",
    "build:master": "npm run build -w @wnav/master",
    "typecheck:all": "npm run typecheck -w @wnav/shared && npm run typecheck -w @wnav/master && npm run typecheck -w @wnav/terminal",
    "lint:all": "eslint --flag unstable_ts_config .",
    "test:all": "npm run test -w @wnav/shared && npm run test -w @wnav/master && npm run test -w @wnav/terminal",
    "mock:smoke": "node scripts/smoke-test-mocks.mjs",
    "schema:extract": "ts-node scripts/extract-entity-schema.ts > /tmp/sqlite_entities.json",
    "schema:check": "npm run schema:extract && ts-node scripts/compare-pg-sqlite-schema.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.8.0"
  }
}

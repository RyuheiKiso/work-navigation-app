# 対応 §: ロードマップ §9.4 §9.5
# エディタ設定の統一。インデントと改行が CI を通すレベルで揃うことを保証する。

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{rs,toml}]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

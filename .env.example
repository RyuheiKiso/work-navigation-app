# =================================================================
# WNAV 作業ナビゲーションシステム — シークレット & プロファイル選択テンプレート
#
# 使い方: cp .env.example .env && vi .env（CHANGE_ME を実際の値に変更する）
# 注意: .env は .gitignore に含まれており Git にコミットされない
#
# 非機密設定（接続先・ポート・タイムアウト等）は以下で管理する:
#   src/infra/config/config.local.yml
# テンプレートのコピー: cp src/infra/config/config.local.yml.example src/infra/config/config.local.yml
#
# 詳細: docs/06_実装/12_設定ファイル・環境変数・シークレット一覧.md
#       src/infra/config/README.md
# =================================================================

# ── プロファイル選択（必須） ────────────────────────────────────────
# 未設定の場合はバックエンドが exit code 78 で起動失敗する
WNAV_PROFILE=local

# ── YAML 配置ディレクトリ（任意） ──────────────────────────────────
# 未設定の場合はリポジトリ内 src/infra/config/ → /etc/wnav/config/ の順に探索する
# WNAV_CONFIG_DIR=/etc/wnav/config

# ── DB パスワード（3 ロール分・高機密） ─────────────────────────────
# ローカル DB の初期パスワードは docs/06_実装/06_開発環境構築手順.md §6 参照
WNAV_DB_PASSWORD_WRITE=CHANGE_ME
WNAV_DB_PASSWORD_EVENT_INSERT=CHANGE_ME
WNAV_DB_PASSWORD_READ=CHANGE_ME

# ── JWT 鍵（RS256・最高機密） ───────────────────────────────────────
# 生成コマンド:
#   openssl genrsa -out wnav_jwt.pem 4096
#   openssl rsa -in wnav_jwt.pem -pubout -out wnav_jwt_pub.pem
# PEM ファイルの改行を \n に変換して 1 行にする:
#   awk 'NF{printf "%s\\n", $0}' wnav_jwt.pem
WNAV_BE_JWT_SECRET=CHANGE_ME
WNAV_BE_JWT_PUBLIC_KEY=CHANGE_ME

# ── Webhook HMAC 署名キー（高機密） ────────────────────────────────
WNAV_BE_WEBHOOK_SECRET=CHANGE_ME

# ── バックアップ通知 URL（中機密） ──────────────────────────────────
# dev/local では未使用。staging/prod で設定する。
# WNAV_BE_BACKUP_NOTIFICATION_URL=https://hooks.example.local/wnav-backup

# ── インフラ TLS（staging/prod のみ） ──────────────────────────────
# local/dev では TLS 不要（ssl_mode: disable）
# WNAV_INFRA_TLS_CERT=/etc/wnav/tls/server.crt
# WNAV_INFRA_TLS_KEY=/etc/wnav/tls/server.key

# ── sqlx CLI 専用 DATABASE_URL ─────────────────────────────────────
# ランタイムでは YAML から接続先を組み立てる（このキーは sqlx prepare など CLI ツール用）
DATABASE_URL=postgres://wnav_write:CHANGE_ME@localhost:5432/wnav_local

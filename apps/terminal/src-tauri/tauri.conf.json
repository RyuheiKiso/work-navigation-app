{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "work-navigation-app terminal",
  "version": "0.1.0",
  "identifier": "app.work-navigation-app.terminal",
  "build": {
    "beforeDevCommand": "pnpm --filter @wna/terminal dev",
    "beforeBuildCommand": "pnpm --filter @wna/terminal build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "work-navigation-app — 端末",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Manufacturing work navigation terminal",
    "longDescription": "Tauri+React terminal app for manufacturing work navigation (Android / Windows).",
    "publisher": "work-navigation-app contributors",
    "homepage": "https://github.com/RyuheiKiso/work-navigation-app",
    "icon": []
  }
}

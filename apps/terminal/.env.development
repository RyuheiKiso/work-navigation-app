# 対応 §: ロードマップ §11.4 ／ ADR-0007
# 開発時の利便性のため、デモ既定値を埋める。本番ビルド (vite build) では
# このファイルは読まれない（Vite は import.meta.env.MODE === 'development'
# のときだけ .env.development を解決する）。
#
# 本番では VITE_DEMO_MODE 未設定または 'false' とし、ID/パスワードを
# 空欄出荷する。
VITE_DEMO_MODE=true
VITE_DEMO_USER_ID=alice
VITE_DEMO_PASSWORD=hello-world
